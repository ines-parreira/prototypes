      >
        Manage
      </a>
    </nav>
    <header
      class="hero"
    >
      
      <i
        class="icon material-icons-outlined"
      >
        live_help
      </i>
      <div>
        <h1
          class="heroHeading"
        >
          Help Center
        </h1>
        <p
          class="heroDescription"
        >
          Set up a free Help Center/FAQ site and let your customers find answers.
        </p>
        <div
          class="heroMeta"
        >
          <span
            class="by"
          >
            by
             
            <a
              href="https://gorgias.com"
              rel="noopener noreferrer"
              target="_blank"
            >
              Gorgias
            </a>
          </span>
        </div>
      </div>
    </header>
    <main
      class="main"
    >
      <section
        class="longDescription"
      >
        <h2
          class="categoryTitle"
        >
          About
        </h2>
        <div>
          <p>
            With the Gorgias native Help Center, you can set up help articles on your website for free. This is a great way to allow your customers to self serve and get instant answers before reaching out to your Support team. You can add images, videos, and GIFs to help your customers learn about your products and services in-depth!
          </p>
          <h2>
            Highlights
          </h2>
          <p />
          <ul>
            <li>
              Multilingual, customizable settings to match with your brand;
            </li>
            <li>
              Contact cards (including contact form) to direct inquiries to one central location;
            </li>
            <li>
              Google Analytics to get insights about your shoppers behavior;
            </li>
            <li>
              Internal knowledge base to transfer knowledge with your team.
            </li>
          </ul>
          <p />
          <p />
          <h2>
            For Automation Add-on subscribers only:
          </h2>
          <ul>
            <li>
              Self-Service flows available in the Help Center to deflect even more tickets;
            </li>
            <li>
              Articles recommendations in chat.
            </li>
          </ul>
          <p />
        </div>
        <ul
          class="screenshotList"
        >
          <li
            class="screenshotListItem"
          >
            <img
              alt="Screenshot number 1 of things this app allows you to do in Gorgias"
              class="screenshot"
              src="/assets/img/integrations/screenshots/helpcenter-1.png"
            />
          </li>
        </ul>
      </section>
      <div
        class="infoCard card"
      >
        <div
          class="card-body"
        >
          <div
            class="connectWrapper"
          >
            <a
              class="connectButtonWrapper"
              href="http://localhost/app/settings/help-center/new?account=undefined"
              rel="noopener noreferrer"
              target="_blank"
            >
              <button
                class="wrapper actionButton fill primary medium"
                type="button"
              >
                Create New
              </button>
            </a>
          </div>
          <h2
            class="categoryTitle cardTitle"
          >
            Pricing
          </h2>
          <ul
            class="cardList"
          >
            <li>
              Free
            </li>
          </ul>
          <h2
            class="categoryTitle cardTitle"
          >
            Resources
          </h2>
          <ul
            class="cardList"
          >
            <li>
              <a
                class="actionLink"
                href="https://docs.gorgias.com/en-US/articles/help-center-18396"
                rel="noopener noreferrer"
                target="_blank"
              >
                <i
                  class="material-icons-outlined actionIcon actionIconBigger"
                >
                  description
                </i>
                Documentation
              </a>
            </li>
            <li>
              <a
                class="actionLink"
                href="https://app.livestorm.co/gorgias-1/help-center-on-demand?utm_source=Livestorm+company+page"
                rel="noopener noreferrer"
                target="_blank"
              >
                <i
                  class="material-icons actionIcon"
                >
                  ondemand_video
                </i>
                Monthly Webinar
              </a>
            </li>
            
          </ul>
          <h2
            class="categoryTitle cardTitle"
          >
            Support
          </h2>
          <ul
            class="cardList"
          >
            <li>
              <a
                class="actionLink"
                href="mailto:support@gorgias.com"
                rel="noopener noreferrer"
                target="_blank"
              >
                <i
                  class="material-icons actionIcon"
                >
                  mail
                </i>
                support@gorgias.com
              </a>
            </li>
            
          </ul>
        </div>
      </div>
    </main>
  </div>
</div>
`;

