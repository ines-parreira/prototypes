              to="/app/settings/channels/gorgias_chat"
            >
              Chat
            </a>
          </li>
          <li
            class="breadcrumb-item"
          >
            hellochatintegration
          </li>
        </ol>
      </nav>
    </div>
    <div
      data-testid="GorgiasChatIntegrationNavigation"
    />
