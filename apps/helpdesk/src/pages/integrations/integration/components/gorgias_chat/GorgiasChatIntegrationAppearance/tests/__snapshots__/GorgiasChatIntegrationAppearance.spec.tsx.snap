      data-testid="GorgiasChatIntegrationHeader"
    />
    <div
      class="pageContainer container-fluid"
    >
      <div
        class="row row"
      >
        <div
          class="col"
        >
          <form
            class=""
          >
            <div
              class="form"
            >
              <div
                class="formSection"
              >
                <div
                  class="InputField formGroup required form-group"
                  color=""
                >
                  <label
                    class="control-label"
                    for="id-input-42"
