// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`<GorgiasChatIntegrationList/> should display correcty the list of chat integrations 1`] = `
<div
  className="w-100"
>
  <PageHeader
    title={
      <Breadcrumb
        aria-label="breadcrumb"
        listTag="ol"
        tag="nav"
      >
        <BreadcrumbItem
          tag="li"
        >
          <Link
            to="/app/settings/integrations"
          >
            Integrations
          </Link>
        </BreadcrumbItem>
        <BreadcrumbItem
          active={true}
          tag="li"
        >
          Chat
        </BreadcrumbItem>
      </Breadcrumb>
    }
  >
    <Button
      color="success"
      onClick={[Function]}
      tag="button"
      type="submit"
    >
      <div
        className="createIntegrationBtn"
      >
        <i
          className="material-icons mr-2"
        >
          add
        </i>
        Add New
      </div>
    </Button>
  </PageHeader>
  <Container
    className="pageContainer pb0"
    data-candu-id="integration-container"
    fluid={true}
    tag="div"
  >
    <div
      className="mb-3"
    >
      <div>
        Chat with your customers by adding our Chat widget on your website. Every time a customer starts a conversation on your website, it opens a ticket in Gorgias.
      </div>
    </div>
    <div>
      <Alert
        className="mb-4"
        icon={true}
        onClose={[Function]}
        type="info"
      >
        The toggle to hide the chat from your website was moved to the
         
        <b>
          Installation tab
        </b>
         tab of your chat's settings.
      </Alert>
    </div>
  </Container>
  <TableWrapper
    className="table"
  >
    <TableHead
      className="header"
    >
      <HeaderCellProperty
        title="Chat name"
      />
      <HeaderCellProperty
        title="Store"
      />
      <HeaderCellProperty
        title="Language"
      />
      <HeaderCell />
    </TableHead>
    <ForwardRef(TableBody)>
      <ForwardRef(TableBodyRow)
        onClick={[Function]}
      >
        <ForwardRef
          innerClassName="chatName"
        >
          my chat enabled
        </ForwardRef>
        <ForwardRef
          size="small"
        >
          <div
            className="shopifyStoreDiv"
          >
            <span
              className="shopifyStoreName"
            >
              <img
                alt="logo Shopify"
                src="test-file-stub"
              />
              <span>
                my associated Shopify store
              </span>
            </span>
            <img
              alt="warning icon"
              className="material-icons warningIcon"
              id="store-disconnected-1"
              src="test-file-stub"
            />
            <Tooltip
              placement="top"
              target="store-disconnected-1"
            >
              This store is currently disconnected
            </Tooltip>
          </div>
        </ForwardRef>
        <ForwardRef
          size="small"
        >
          <LanguageBullet />
        </ForwardRef>
        <ForwardRef
          size="smallest"
        >
          <ForwardIcon
            href="/app/settings/integrations/gorgias_chat/1/campaigns"
          />
        </ForwardRef>
      </ForwardRef(TableBodyRow)>
    </ForwardRef(TableBody)>
  </TableWrapper>
</div>
`;
