exports[`<GorgiasChatIntegrationPreferences/> render() should render buttons in loading state because preferences are being submitted 1`] = `
<Fragment>
  <NavigatedSuccessModal
    buttonLabel="See Chat Settings"
    icon="party-popper"
    name="gorgias-chat-auto-installation"
  >
    <div
      className="heading-page-semibold mb-2"
    >
      All set!
    </div>
    <div
      className="heading-subsection-regular"
    >
      Your chat is now available on your website.
    </div>
  </NavigatedSuccessModal>
  <div
    className="full-width"
  >
    <PageHeader
      title={
        <Breadcrumb
          aria-label="breadcrumb"
          listTag="ol"
          tag="nav"
        >
          <BreadcrumbItem
            tag="li"
          >
            <Link
              to="/app/settings/channels/gorgias_chat"
            >
              Chat
            </Link>
          </BreadcrumbItem>
          <BreadcrumbItem
            tag="li"
          />
        </Breadcrumb>
      }
    >
      <Component
        integration={
          Immutable.Map {
            "id": 2,
            "type": "gorgias_chat",
            "meta": Immutable.Map {
              "language": "en-US",
              "shop_integration_id": 1,
            },
            "decoration": Immutable.Map {
