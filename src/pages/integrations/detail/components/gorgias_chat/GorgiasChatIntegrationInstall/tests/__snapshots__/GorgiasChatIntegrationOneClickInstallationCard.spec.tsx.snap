            src="test-file-stub"
          />
          <b>
            mylittleintegration3
          </b>
        </div>
        <div
          class="actions-wrapper"
        >
          <button
            class="btn btn-primary"
            type="button"
          >
            Install
          </button>
          <div
            class="component d-inline-block disconnect-button"
            id="disconnect-button-3"
          >
            <button
              class="btn btn-secondary"
              id="confirm-button-disconnect-button-3"
              type="button"
            >
              <i
                class="material-icons"
              >
                delete
              </i>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
`;

