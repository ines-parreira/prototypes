      <div
        class="row"
      >
        <div
          class="content col-sm-8"
        >
          No credit card registered
        </div>
        <div
          class="text-right col-sm-4"
        >
          <div
            id="add-payment-method-button"
            style="display: inline-block;"
          >
            <a
              class=""
              to="/app/settings/billing/add-payment-method"
            >
              <button
                class="wrapper fill primary medium"
                type="button"
              >
                Add payment method
              </button>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
`;

