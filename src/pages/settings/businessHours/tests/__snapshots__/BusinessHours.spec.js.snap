              >
                <i
                  className="material-icons red"
                >
                  clear
                </i>
              </div>
            </div>
            <Button
              color="secondary"
              onClick={[Function]}
              tag="button"
              type="button"
            >
              <i
                className="material-icons"
              >
                add
              </i>
               
              Add business hours
            </Button>
          </div>
          <InputField
            label="Timezone"
            name="timezone"
            onChange={[Function]}
            type="select"
            value="UTC"
          >
            <option
              key="UTC"
              value="UTC"
            >
              UTC
            </option>
            <option
              key="US/Pacific"
              value="US/Pacific"
