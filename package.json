{
    "name": "@repo/root",
    "version": "1.0.0",
    "description": "Gorgias Helpdesk web app monorepo",
    "repository": "https://github.com/gorgias/helpdesk-web-app",
    "author": "Gorgias Engineering <engineering@gorgias.com>",
    "license": "UNLICENSED",
    "private": true,
    "scripts": {
        "oxlint:watch": "tsx scripts/oxlint/oxlint.watch.ts",
        "oxlint:bridge": "tsx scripts/oxlint/oxlint.bridge.ts",
        "format:check": "pnpm --filter @repo/helpdesk format:check",
        "lint": "run-p lint:*",
        "lint:helpdesk": "pnpm --filter @repo/helpdesk lint",
        "lint:deprecated": "tsx scripts/deprecated-monitoring/deprecated.monitoring.ts",
        "prelint": "pnpm oxlint:bridge",
        "test:ci:cover": "pnpm --filter @repo/helpdesk test:ci:cover",
        "typecheck": "pnpm --filter @repo/helpdesk typecheck",
        "build": "pnpm --filter @repo/helpdesk build",
        "dev:proxy": "pnpm --filter @repo/helpdesk dev:proxy",
        "dev:local": "pnpm --filter @repo/helpdesk dev:local",
        "platform:chromatic": "pnpm --filter @repo/helpdesk chromatic",
        "platform:deprecated-analysis": "pnpm static-analysis",
        "platform:check-node-engines": "tsx scripts/dependencies-management/dependencies-engines.ts",
        "postinstall": "pnpm oxlint:bridge"
    },
    "devDependencies": {
        "@gorgias/config": "^0.2.4",
        "@gorgias/static-analysis": "0.3.7",
        "@sentry/cli": "^2.47.0",
        "@trivago/prettier-plugin-sort-imports": "^5.2.2",
        "@types/node": "22.13.13",
        "@types/semver": "^7.7.0",
        "chokidar": "^4.0.3",
        "deepmerge": "^4.3.1",
        "npm-run-all": "4.1.5",
        "oxlint": "^0.17.0",
        "prettier": "^3.5.2",
        "semver": "^7.7.1",
        "tsx": "^4.19.2",
        "typescript": "5.3.3"
    },
    "engines": {
        "node": "22"
    },
    "packageManager": "pnpm@10.8.0",
    "overrides": {
        "@tanstack/react-query": "4.36.1",
        "@types/escodegen": "^0.0.10",
        "@types/react": "^17.0.2",
        "@formatjs/ecma402-abstract": "1.11.4",
        "jquery": "3.5.1",
        "json-schema": "0.4.0",
        "@emotion/styled-base": "10.0.31",
        "isomorphic-fetch": "^3.0.0"
    },
    "peerDependenciesMeta": {
        "react-native": {
            "optional": true
        }
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@sentry/cli",
            "@swc/core",
            "core-js",
            "core-js-pure",
            "esbuild",
            "postinstall-postinstall"
        ]
    }
}
