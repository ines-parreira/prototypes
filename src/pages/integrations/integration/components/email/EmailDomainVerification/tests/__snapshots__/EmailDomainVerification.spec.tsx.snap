exports[`<EmailDomainVerification/> render() should render a delete button to account admins 1`] = `
<div>
  <div>
    The domain 
    <strong>
      gorgias.com
    </strong>
     has been verified.
  </div>
  <table
    class="table records-table"
  >
    <thead
      class=""
