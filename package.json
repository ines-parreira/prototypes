{
    "name": "@repo/root",
    "version": "1.0.0",
    "description": "Gorgias Helpdesk web app monorepo",
    "repository": "https://github.com/gorgias/helpdesk-web-app",
    "author": "Gorgias Engineering <engineering@gorgias.com>",
    "license": "UNLICENSED",
    "private": true,
    "scripts": {
        "ai:rulesync": "rulesync install --frozen && rulesync generate",
        "build": "pnpm --filter @repo/helpdesk build",
        "dev:proxy": "pnpm --filter @repo/helpdesk dev:proxy",
        "dev:local": "pnpm --filter @repo/helpdesk dev:local",
        "oxlint:watch": "tsx scripts/oxlint/oxlint.watch.ts",
        "format:check": "nx format:check",
        "format:check:all": "nx run-many --target=format:check",
        "format:check:affected": "nx affected --target=format:check",
        "format:fix": "nx format:fix",
        "format:fix:all": "nx run-many --target=format:fix",
        "format:fix:affected": "nx affected --target=format:fix",
        "lint": "nx lint",
        "lint:helpdesk": "pnpm --filter @repo/helpdesk lint && pnpm lint:deprecated",
        "lint:code:all": "nx run-many --target=lint",
        "lint:code:affected": "nx affected --target=lint",
        "lint:unused": "nx run-many --target=lint:unused --exclude=@repo/helpdesk",
        "lint:unused:affected": "nx affected --target=lint:unused --exclude=@repo/helpdesk",
        "lint:deprecated": "tsx scripts/deprecated-monitoring/deprecated.monitoring.ts",
        "test": "nx test",
        "test:all": "nx run-many --target=test",
        "test:affected": "nx affected --target=test",
        "test:helpdesk:ci:cover": "pnpm --filter @repo/helpdesk test:ci:cover",
        "react-doctor": "node scripts/react-doctor/run-react-doctor.mjs",
        "react-doctor:compare": "node scripts/react-doctor/compare-reports.mjs",
        "typecheck": "nx typecheck",
        "typecheck:all": "nx run-many --target=typecheck",
        "typecheck:affected": "nx affected --target=typecheck",
        "platform:deprecated-analysis": "pnpm static-analysis",
        "platform:check-node-engines": "tsx scripts/dependencies-management/dependencies-engines.ts",
        "platform:update:sdk": "scripts/update-sdk.sh",
        "platform:test:memory-analysis": "tsx scripts/test-memory-analysis/analyze.ts",
        "postinstall": "pnpm ai:rulesync"
    },
    "devDependencies": {
        "@gorgias/config": "^0.6.0",
        "@gorgias/static-analysis": "0.5.0",
        "@sentry/cli": "catalog:sentry",
        "@trivago/prettier-plugin-sort-imports": "catalog:prettier",
        "@types/node": "22.13.13",
        "@types/semver": "^7.7.0",
        "chokidar": "^4.0.3",
        "deepmerge": "^4.3.1",
        "fast-glob": "^3.3",
        "knip": "5.84.1",
        "npm-run-all": "4.1.5",
        "nx": "21.3.2",
        "oxlint": "catalog:oxlint",
        "prettier": "catalog:prettier",
        "react-doctor": "^0.0.29",
        "rulesync": "^7.18.0",
        "semver": "^7.7.1",
        "taze": "^19.1.0",
        "tsx": "^4.20.3",
        "typescript": "catalog:typescript"
    },
    "engines": {
        "node": "22.22.0"
    },
    "packageManager": "pnpm@10.18.3",
    "peerDependenciesMeta": {
        "react-native": {
            "optional": true
        }
    }
}
