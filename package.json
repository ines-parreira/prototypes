    "scripts": {
        "types": "flow check g/static/private/js && tsc -p ./tsconfig.json --allowJs false --noEmit true",
        "types:update": "flow-typed install",
        "eslint:opts": "func() { eslint -c ./.eslintrc.\"$1\".js --quiet --ext \"$2\" g/static/private/js/\"$3\"; }; func",
        "eslint:js": "func() { yarn eslint:opts javascript .js \"$1\"; }; func",
        "eslint:ts": "func() { yarn eslint:opts typescript .ts,.tsx \"$1\"; }; func",
        "lint": "run-p eslint:js eslint:ts",
        "quality": "run-s lint types",
        "jest": "export TZ=America/Creston; jest",
        "test": "run-s quality jest",
        "test:debug": "node --inspect-brk ./node_modules/.bin/jest -i",
        "test:cover": "run-s quality \"jest --coverage\"",
        "test:update": "yarn jest -u",
        "test:watch": "yarn jest --watch",
        "test:ci": "run-s quality test:ci:cover",
        "test:ci:cover": "yarn run jest --coverage --no-cache --ci --runInBand",
        "dll": "webpack --env.dll",
        "postinstall": "run-s dll",
        "build": "(export NODE_ENV=production; run-s dll && webpack && webpack --config webpack.sharedWorker.config.js)",
        "serve": "webpack --config webpack.sharedWorker.config.js; webpack-dev-server --inline --hot --progress --debug",
        "serve:sharedWorker": "webpack -w --config webpack.sharedWorker.config.js",
        "uglify-file": "terser --compress --mangle --"
    },
