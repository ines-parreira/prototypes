{
    "name": "@repo/ecommerce",
    "version": "1.0.0",
    "description": "Ecommerce",
    "private": true,
    "exports": {
        ".": "./src/index.ts"
    },
    "scripts": {
        "format:check": "prettier --check .",
        "format:fix": "prettier --write .",
