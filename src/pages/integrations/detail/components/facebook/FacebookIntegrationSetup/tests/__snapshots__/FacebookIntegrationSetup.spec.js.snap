          We found 
          1
           pages associated with your account.
           
          Please activate the pages you want to use with Gorgias:
        </p>
        <div
          className="mb-2"
        >
          <div
            className="page"
            key="1"
          >
            <div
              className="d-flex flex-wrap flex-md-nowrap"
            >
              <div
                className="mr-auto"
              >
                <div>
                  <img
                    className="image rounded mr-3 mb-2 mb-md-0 icon"
                    src="https://gorgias.io/page-image-link.png"
                  />
                  <div
                    className="details mr-3 text-faded"
                  >
                    <h3
                      className="name mr-3"
                    >
                      My page
                    </h3>
                    <span>
                      A page about stuff
                    </span>
                  </div>
                </div>
              </div>
              <ToggleButton
                onChange={[Function]}
                value={false}
              />
            </div>
            <div
              className="settings"
            >
              <p
                className="font-weight-medium"
              >
                Choose the Facebook channels you want to use to communicate with your customers:
              </p>
              <div
                className="d-md-flex"
              >
                <FormGroup
                  className="mr-5"
                  tag="div"
                >
                  <BooleanField
                    label="Enable Messenger"
                    name="1.messenger_enabled"
                    onChange={[Function]}
                    type="checkbox"
                    value={false}
                  />
                  <BooleanField
                    label="Enable Facebook posts & comments"
                    name="1.posts_enabled"
                    onChange={[Function]}
                    type="checkbox"
                    value={false}
                  />
                </FormGroup>
                <div>
                  <Alert
                    className="d-flex align-items-center"
                    closeAriaLabel="Close"
                    color="warning"
                    isOpen={true}
                    tag="div"
                    transition={
                      Object {
                        "appear": true,
                        "baseClass": "fade",
                        "baseClassActive": "show",
                        "enter": true,
                        "exit": true,
                        "in": true,
                        "mountOnEnter": false,
                        "onEnter": [Function],
