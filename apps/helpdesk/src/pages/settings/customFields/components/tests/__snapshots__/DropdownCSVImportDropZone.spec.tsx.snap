exports[`<DropdownCSVImportDropZone/> should render with a file 1`] = `
<div>
  <input
    accept=".csv"
    style="display: none;"
    type="file"
  />
  <div>
    <div
      class="fileSelectedArea"
    >
      <div>
        <i
          class="material-icons mr-2"
        >
          insert_drive_file
        </i>
        file.csv
      </div>
      <div>
        <button
          aria-disabled="false"
          class="ui-button-wrapper-cef1 ui-button-fill-cef1 ui-button-secondary-cef1 ui-button-small-cef1"
          type="button"
        >
          <span
            class="ui-button-content-cef1"
          >
            Replace File
          </span>
        </button>
      </div>
    </div>
  </div>
</div>
`;

exports[`<DropdownCSVImportDropZone/> should render without file 1`] = `
