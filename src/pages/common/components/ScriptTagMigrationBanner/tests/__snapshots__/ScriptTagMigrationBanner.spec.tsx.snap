exports[`<ScriptTagMigrationBanner /> should contain both re-install and permission update link for a single store 1`] = `
<div>
  <div
    aria-label=""
    class="ui-banner-banner-e3eb ui-banner-error-e3eb ui-banner-full-e3eb ui-banner-fill-e3eb"
  >
    <div
      class="ui-banner-content-e3eb"
    >
      <div
        class="ui-banner-icon-e3eb"
      >
        <img
          alt="icon"
          src="data:image/svg+xml,%3csvg%20width='24'%20height='24'%20viewBox='0%200%2024%2024'%20fill='none'%20xmlns='http://www.w3.org/2000/svg'%3e%3cg%20id='Lead%20Icon'%3e%3cpath%20id='Vector'%20d='M12%202C6.48%202%202%206.48%202%2012C2%2017.52%206.48%2022%2012%2022C17.52%2022%2022%2017.52%2022%2012C22%206.48%2017.52%202%2012%202ZM12%2013C11.45%2013%2011%2012.55%2011%2012V8C11%207.45%2011.45%207%2012%207C12.55%207%2013%207.45%2013%208V12C13%2012.55%2012.55%2013%2012%2013ZM13%2017H11V15H13V17Z'%20fill='%23D6384D'/%3e%3c/g%3e%3c/svg%3e"
        />
      </div>
      <span
        class="ui-banner-text-e3eb"
      >
        <span>
          <b>
            Action required
          </b>
          :
           
          <a
            href="#"
          >
            Update your Shopify permissions
          </a>
           
          and 
          <span
            class=""
          >
            re-install
          </span>
           
          your chat using the
           
          1-click install method
           
          to ensure better chat stability by 
          <b>
            Scary Deadline
          </b>
        </span>
      </span>
    </div>
    <div
      class="ui-banner-rightitems-e3eb"
    />
  </div>
</div>
`;

