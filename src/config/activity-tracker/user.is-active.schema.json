{
  "$ref": "#/definitions/UserIsActiveSchema",
  "definitions": {
    "UserIsActiveSchema": {
      "type": "object",
      "properties": {
        "accountId": {
          "type": "integer"
        },
        "userId": {
          "type": "integer"
        },
        "sessionId": {
          "type": "string",
          "format": "uuid"
        },
        "sessionStartedAt": {
          "type": "string",
          "format": "date-time"
        },
        "clientId": {
          "type": "string",
          "minLength": 6,
          "maxLength": 6,
          "description": "The id of the tab / client where the event was captured. On mobile, this will be the device id."
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "The path of the page where the event was captured."
        }
      },
      "required": [
        "accountId",
        "userId",
        "sessionId",
        "sessionStartedAt",
        "clientId",
        "path"
      ],
      "additionalProperties": false,
      "description": "1.0.0 ### Event sent regularly to indicate that the user is active."
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}