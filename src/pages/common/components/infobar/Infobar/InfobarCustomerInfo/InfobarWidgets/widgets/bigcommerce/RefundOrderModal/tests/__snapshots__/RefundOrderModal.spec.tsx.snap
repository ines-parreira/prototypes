exports[`RefundOrderModal should render Refund Order - ERROR popup 1`] = `
<body>
  <div />
  <div
    aria-describedby="modal-6-desc"
    aria-labelledby="modal-6-title"
    aria-modal="true"
    class="modal default open"
    role="dialog"
  >
    <div
      class="dialog medium scrollableDialog"
    >
      <div
        class="modalContent scrollableContent default"
      >
        <div
          class="wrapper"
        >
          <div>
            <div
              class="title"
              id="modal-6-title"
            >
              Refund Order #123
            </div>
            <div
              class="subtitle"
            />
          </div>
          <i
            class="material-icons icon"
          >
            close
          </i>
        </div>
        <div
          class="formBody"
        >
          <div
            class="flex"
          >
            <div
              aria-checked="true"
              aria-label="Entire order"
              class="wrapper selected previewRadioButtonWrapper"
              role="radio"
              tabindex="0"
            >
              <div>
                <label
                  class="label label"
                  for="Entire order"
                >
                  <input
                    checked=""
                    class="input"
                    id="Entire order"
                    role="checkbox"
                    tabindex="-1"
                    type="radio"
                  />
                  Entire order
                </label>
              </div>
            </div>
            <div
              aria-checked="false"
              aria-label="Manual amount"
              class="wrapper previewRadioButtonWrapper"
              role="radio"
              tabindex="0"
            >
              <div>
                <label
                  class="label label"
                  for="Manual amount"
                >
                  <input
                    class="input"
                    id="Manual amount"
                    role="checkbox"
                    tabindex="-1"
                    type="radio"
                  />
                  Manual amount
                </label>
              </div>
            </div>
          </div>
          <div
            class="modalSection"
          >
            <p
              class="modalSectionHeader"
            >
              Refundable items
            </p>
          </div>
          <div
            class="modalSection"
          >
            <p
              class="modalSectionHeader"
            >
              Refund method
            </p>
            <p
              class=""
            >
              Select items to refund.
            </p>
          </div>
          <div
            class="modalSectionSmall"
          >
            <p
              class="modalSectionHeader"
            >
              Other
            </p>
            <label
              class="label label"
              for="refundReason"
            >
              Reason for refund
            </label>
            <div
              class="textAreaWrapper"
            >
              <textarea
                aria-describedby="refundReason-caption"
                class="textarea"
                id="refundReason"
                maxlength="1000"
                name="refundReason"
                rows="1"
                style="height: 2px;"
              />
              <div
                class="caption"
                id="refundReason-caption"
              >
                Maximum length is 1000 characters.
              </div>
            </div>
            <label
              class="label label smallSpacingMarginTop"
              for="newOrderStatus"
            >
              New status
            </label>
            <div
              class="wrapper"
              role="listbox"
              tabindex="0"
            >
              <div
                class="inputWrapper"
              >
                <div
                  class="input isGreyed"
                >
                  Select order status
                </div>
                <i
                  class="affix suffix toggle material-icons"
                >
                  arrow_drop_down
                </i>
              </div>
            </div>
            <p
              class="caption"
            >
              If the field is left empty, Refunded or Partially Refunded status will be assigned to order.
            </p>
          </div>
        </div>
        <div
          class="wrapper modalFooterWrapper"
        >
          <button
            aria-disabled="false"
            class="wrapper fill secondary medium"
            tabindex="0"
            type="button"
          >
            Cancel
          </button>
          <button
            aria-disabled="true"
            class="wrapper fill primary medium isDisabled"
            tabindex="0"
            type="button"
          >
            Refund €0.00
          </button>
        </div>
      </div>
    </div>
  </div>
  <div
    data-floating-ui-portal=""
    id="floating-ui-1"
  />
  <div
    aria-describedby="modal-8-desc"
    aria-labelledby="modal-8-title"
    aria-modal="true"
    class="modal default open"
    role="dialog"
  >
    <div
      class="dialog small"
    >
      <div
        class="modalContent default"
      >
        <div
          class="wrapper"
        >
          <div>
            <div
              class="title"
              id="modal-8-title"
            >
              Error
            </div>
            <div
              class="subtitle"
            />
          </div>
          <i
            class="material-icons icon"
          >
            close
          </i>
        </div>
        <div
          class="wrapper"
          id="modal-8-desc"
        >
          An unexpected error occurred. Please try again later.
        </div>
        <div
          class="wrapper wrapper"
        >
          <div
            class="actions"
          >
            <div
              class="childWrapper"
            >
              <button
                aria-disabled="false"
                class="wrapper fill primary medium"
                type="button"
              >
                Got it
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
`;

