                      class="name mr-3"
                    >
                      My page
                    </h3>
                    <span
                      class="mr-3"
                    >
                      [
                      Moderator
                      ]
                    </span>
                    <span>
                      A page about stuff
                    </span>
                  </div>
                </div>
              </div>
              <div>
                <label
                  aria-checked="false"
                  class="ui-label-label-3864 ui-togglefield-label-52f1"
                  role="switch"
                >
                  <input
                    class="ui-togglefield-input-52f1"
                    disabled=""
                    type="checkbox"
                  />
                  <div
                    class="ui-togglefield-slider-52f1"
                  />
                  <div />
                </label>
              </div>
            </div>
            <div
              class="settings"
            >
              <p
                class="font-weight-medium"
              >
                Choose the Facebook channels you want to use to communicate with your customers:
