exports[`KeyMetricStat should render a key metrics chart with distribution and donut components 1`] = `
<div
  className="metrics"
>
  <div
    className="metric"
    key="total_sent"
  >
    <div
      className="label"
    >
      Survey sent
      <span>
        <i
          className="info-icon help-icon material-icons ml-2"
          id="title-total_sent"
        >
          info_outline
        </i>
        <Tooltip
          delay={0}
          placement="top"
          target="title-total_sent"
        >
          Total number of customer satisfaction surveys sent.
        </Tooltip>
      </span>
    </div>
    <div
      className="mt-3 statsDisplay"
    >
      -
    </div>
  </div>
  <div
    className="metric"
    key="response_rate"
  >
    <div
      className="label"
    >
      Response rate
      <span>
        <i
          className="info-icon help-icon material-icons ml-2"
          id="title-response_rate"
        >
          info_outline
        </i>
        <Tooltip
          delay={0}
          placement="top"
          target="title-response_rate"
        >
          Total number of responses for surveys sent.
        </Tooltip>
      </span>
    </div>
    <div
      className="mt-3 statsDisplay"
    >
      -
    </div>
  </div>
  <div
    className="metric"
    key="average_rating"
  >
    <div
      className="label"
    >
      Average rating
      <span>
        <i
          className="info-icon help-icon material-icons ml-2"
          id="title-average_rating"
        >
          info_outline
        </i>
        <Tooltip
          delay={0}
          placement="top"
          target="title-average_rating"
        >
          Average score given by the customers.
        </Tooltip>
      </span>
    </div>
    <div
      className="mt-3 statsDisplay"
    >
      <DonutKeyMetricStat
        differenceComponent={
          <span
            className="diff"
            id="value-average_rating"
          >
            <span>
              <i
                className="stats-difference  material-icons font-weight-bold mr-1"
                style={
                  Object {
                    "fontSize": "15px",
                  }
                }
              >
                arrow_upward
              </i>
              10
              %
            </span>
            <Tooltip
              delay={0}
              placement="top"
              target="value-average_rating"
            >
              Compared to : Sep 05, 2017 - Sep 06, 2017
            </Tooltip>
          </span>
        }
        fill="warning"
        formattedValue={20}
        height={320}
        innerRadius={0.83}
        label="10%"
        maxValue={5}
        outerRadius={0.95}
        startAngle={0}
        total={null}
        value={20}
        width={320}
      />
    </div>
  </div>
  <div
    className="metric"
    key="response_distribution"
  >
    <div
      className="label"
    >
      Response Distribution
      <span>
        <i
          className="info-icon help-icon material-icons ml-2"
          id="title-response_distribution"
        >
          info_outline
        </i>
        <Tooltip
          delay={0}
          placement="top"
          target="title-response_distribution"
        >
          Percentage of responses, grouped by the given score.
        </Tooltip>
      </span>
    </div>
    <div
      className="mt-3 statsDisplay"
    >
      <DistributionKeyMetricStat
        config={
          Immutable.Map {
            "name": "response_distribution",
            "label": "Response Distribution",
            "tooltip": "Percentage of responses, grouped by the given score.",
            "type": "distribution",
            "variant": "star",
            "minValue": 1,
            "maxValue": 5,
          }
        }
        formattedValue={
          Immutable.Map {
            "1": 12,
            "2": 38,
            "3": 14.5,
            "4": 14.5,
            "5": 21,
          }
        }
      />
    </div>
  </div>
</div>
`;
