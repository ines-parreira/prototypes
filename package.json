  "scripts": {
    "lint": "eslint --quiet g/static/private/js",
    "pretest": "npm run lint",
    "test": "mocha --compilers js:babel-register,css:g/static/private/js/test/exclude-css.js -r jsdom-global/register --recursive g/static/**/*.spec.js",
    "test:debug": "mocha --compilers js:babel-register,css:g/static/private/js/test/exclude-css.js -r jsdom-global/register --debug --recursive g/static/**/*.spec.js",
    "test:cover": "npm run lint && babel-node ./node_modules/.bin/isparta cover ./node_modules/.bin/_mocha -- --compilers js:babel-register,css:g/static/private/js/test/exclude-css.js -r jsdom-global/register --recursive g/static/**/*.spec.js",
    "test:watch": "npm test -- --watch",
    "build": "NODE_ENV=production webpack -p",
    "serve": "webpack-dev-server --progress --colors --inline --host 0.0.0.0",
    "serve-maps": "webpack-dev-server --progress --colors --inline -d --host 0.0.0.0"
  },
