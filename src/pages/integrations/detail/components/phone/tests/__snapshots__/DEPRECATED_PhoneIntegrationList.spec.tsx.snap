    <div>
      <button
        class="btn btn-success"
        type="submit"
      >
        Add Phone Number
      </button>
    </div>
  </div>
  <div
    class="pageContainer pb0 container-fluid"
    data-candu-id="integration-container"
  >
    <div
      class="mb-3"
    >
      Chat with your customers over the phone from Gorgias.
    </div>
