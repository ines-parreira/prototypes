exports[`<AutomationAddonOverview /> should display paywall 1`] = `
<div
  class="full-width pageWrapper"
>
  <div
    class="page-header pageHeader"
  >
    <h1
      class="align-items-center"
    >
      <span>
        Automate overview
      </span>
    </h1>
  </div>
  <div
    class="page container-fluid"
  >
    <div
      class="paywallContainer"
    >
      <div
        class="align-items-center mx-0 row"
      >
        <svg
          class="svg default"
          height="auto"
          viewBox="0 0 824 900"
          width="824"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M0 0H374C622.528 0 824 201.472 824 450V450C824 698.528 622.528 900 374 900H0V0Z"
          />
        </svg>
        <div
          class="mt-5 mt-lg-0 mb-5 mb-lg-0 pl-lg-4 pt-5 pt-lg-0 preview col-12 col-lg-6 col-xl-6"
        >
          <div
            class=""
          >
            <img
              alt="Feature preview"
              class="img-fluid"
              src="/assets/img/paywalls/screens/automate-overview.png"
            />
          </div>
        </div>
        <div
          class="pl-lg-5 col-12 col-lg-5 col-xl-5"
        >
          <div
            class="content"
          >
            <div
              class="flex align-items-center"
            >
              <div
                class="badge"
              >
                GORGIAS AUTOMATE 
              </div>
            </div>
            <h1
              class="contentTitle"
            >
              Automate overview
            </h1>
            <div
              class="description"
            >
              <p>
                <div>
                  With Gorgias Automate, you can track your automation performance and leverage insights to improve.
                </div>
              </p>
            </div>
            <div
