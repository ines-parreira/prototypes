exports[`FacebookIntegrationSetup should render a loader because integrations are currently being fetched 1`] = `
<div
  className="full-width"
>
  <PageHeader
    title={
      <Breadcrumb
        aria-label="breadcrumb"
        listTag="ol"
        tag="nav"
      >
        <BreadcrumbItem
          tag="li"
        >
          <Link
            to="/app/settings/integrations"
          >
            Integrations
          </Link>
        </BreadcrumbItem>
        <BreadcrumbItem
          tag="li"
        >
          <Link
            to="/app/settings/integrations/facebook"
          >
            Facebook
          </Link>
        </BreadcrumbItem>
        <BreadcrumbItem
          active={true}
          tag="li"
        >
          Facebook Pages setup
        </BreadcrumbItem>
      </Breadcrumb>
    }
  />
  <Container
    className="page-container"
    fluid={true}
    tag="div"
  >
    <h1>
      Facebook Pages setup
    </h1>
    <p>
      One last step: choose the pages you want to manage with Gorgias.
      <br />
      If you just wanted to re-activate your Facebook integration or update your permissions: it's done, you can leave this page.
    </p>
    <Form
      onSubmit={[Function]}
      tag="form"
    >
      <div
        className="mb-4"
      >
        <p
          className="font-weight-medium"
        >
          We found 
          1
           pages associated with your account. Please activate the pages you want to use with Gorgias:
        </p>
        <div
          className="mb-2"
        >
          <Loader
            inline={false}
            minHeight="500px"
            size="40px"
          />
        </div>
        <Pagination
          currentPage={1}
          onChange={[Function]}
          pageCount={1}
        />
      </div>
      <div>
        <Button
          className=""
          color="success"
          disabled={true}
          tag="button"
          type="submit"
        >
          Save changes
        </Button>
      </div>
    </Form>
  </Container>
</div>
`;

