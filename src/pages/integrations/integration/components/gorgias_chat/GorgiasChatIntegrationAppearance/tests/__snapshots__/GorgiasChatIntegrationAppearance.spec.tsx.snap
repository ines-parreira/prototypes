              Chat
            </a>
          </li>
          <li
            class="breadcrumb-item"
          >
            New chat integration
          </li>
        </ol>
      </nav>
    </div>
    <div
      class="pageContainer container-fluid"
    >
      <div
        class="row"
      >
        <div
          class="col"
        >
          <form
            class=""
          >
            <div
              class="selectStoreTypeContainer"
            >
              <label
                class="bold"
              >
                Where will you use this chat?
                <span
                  class="redStar"
                >
                  *
                </span>
              </label>
              <div
                class="radioButtonGroup"
              >
                <div
                  aria-checked="true"
                  aria-label="Shopify store"
                  class="wrapper selected radioButton"
                  id="store-radio-button-42"
                  role="radio"
                  tabindex="0"
                >
                  <div>
                    <label
                      class="label label"
                      for="shopify"
                    >
                      <input
                        checked=""
                        class="input"
                        id="shopify"
                        tabindex="-1"
                        type="radio"
                      />
                      Shopify store
                    </label>
                  </div>
                </div>
                <div
                  aria-checked="false"
                  aria-label="Any other website"
                  class="wrapper radioButton"
                  id="store-radio-button-42"
                  role="radio"
                  tabindex="0"
                >
                  <div>
                    <label
                      class="label label"
                      for="website"
                    >
                      <input
                        class="input"
                        id="website"
                        tabindex="-1"
                        type="radio"
                      />
