    fluid={true}
    tag="div"
  >
    <div
      className="body-regular contentWrapper"
    >
      <div
        className="mb32"
      >
        <p>
          Let customers know when your team is online.
          <br />
          This way, you can set different auto-responders in the rules based on when your team is working.
        </p>
        <p>
          The appearance of your
           
          <Link
            to="/app/settings/integrations/gorgias_chat"
          >
            Chat integrations
          </Link>
           
          will change when outside business hours.
        </p>
      </div>
      <Form
        onSubmit={[Function]}
        tag="form"
      >
        <Row
          tag="div"
          widths={
            Array [
              "xs",
              "sm",
              "md",
              "lg",
              "xl",
            ]
          }
        >
          <Col
            tag="div"
            widths={
              Array [
                "xs",
                "sm",
                "md",
                "lg",
                "xl",
              ]
            }
          >
            <div
              className="inputField mb32"
            >
              <Label
                className="control-label"
                tag="label"
                widths={
                  Array [
                    "xs",
                    "sm",
                    "md",
                    "lg",
                    "xl",
                  ]
                }
              >
                Business hours
              </Label>
              <div
                className="flex mb24"
                key="0"
              >
                <BusinessHoursForm
                  businessHour={
                    Immutable.Map {
                      "days": "1,2,3,4,5",
                      "from_time": "09:00",
                      "to_time": "17:00",
                    }
                  }
                  onChange={[Function]}
                />
                <div
                  className="deleteButton"
                  onClick={[Function]}
                >
                  <i
                    className="material-icons red"
                  >
                    clear
                  </i>
                </div>
              </div>
              <ForwardRef
                intent="secondary"
                onClick={[Function]}
              >
                <ButtonIconLabel
                  icon="add"
                >
                  Add business hours
                </ButtonIconLabel>
              </ForwardRef>
            </div>
            <InputField
              className="inputField mb40"
              label="Time zone"
              name="timezone"
              onChange={[Function]}
              type="select"
              value="UTC"
            >
              <option
                key="UTC"
                value="UTC"
              >
                UTC
              </option>
              <option
                key="US/Pacific"
                value="US/Pacific"
              >
                US/Pacific
              </option>
              <option
                key="Australia/AUR"
                value="Australia/AUR"
              >
                Australia/AUR
              </option>
            </InputField>
          </Col>
        </Row>
        <ForwardRef
          isDisabled={false}
          isLoading={false}
          type="submit"
        >
          Save changes
        </ForwardRef>
      </Form>
    </div>
  </Container>
</div>
`;

