exports[`<EmailDomainVerification/> render() should render the page with an optional verification information box when there is no domain 1`] = `
<div>
  <div
    class="alert info mb16"
  >
    <div
      class="content"
    >
      <span
        class="label"
      >
        Domain verification is 
        <b>
          not required
        </b>
         
        for 
        <b>
          Gmail and Outlook
        </b>
         integrations
         
        <i>
          unless you have disabled the "email sending" setting in Gorgias for a Gmail integration.
        </i>
        <br />
        <br />
        While it is not required, you can verify the domain of a Gmail or Outlook integration, which may allow you to continue to send emails in the event of an outage on either platform, as we will be able to attempt to route your emails through our system as a backup.
      </span>
    </div>
  </div>
  <p>
    No domain and DKIM configuration has been created yet.
  </p>
  <div
    class="keySelectionSection form-group"
  >
    <label
      class="control-label"
    >
      DKIM key size
    </label>
    <div>
      <div
        class="dropdown"
      >
        <div
          aria-expanded="false"
          aria-haspopup="true"
          class=""
          data-toggle="dropdown"
        >
          <div
            class="select dropdown-toggle selectFullWidth"
          >
            <span
              class="label"
              style="min-width: 10px; opacity: 1;"
            >
              1024 (Default)
            </span>
            <input
              autocomplete="chrome-off"
              class="input"
              style="min-width: 10px;"
              type="text"
              value=""
            />
            <i
              class="material-icons dropdownIcon"
            >
              arrow_drop_down
            </i>
          </div>
        </div>
        <div
          aria-hidden="true"
          class="options optionsFullWidth dropdown-menu"
          role="menu"
          tabindex="-1"
        >
          
          <button
            class="option option--focused dropdown-item"
            role="menuitem"
            tabindex="0"
            type="button"
          >
            <span>
              2048
            </span>
          </button>
        </div>
      </div>
    </div>
  </div>
  <button
    class="wrapper fill primary medium"
    color="primary"
    type="submit"
  >
    Add Domain
  </button>
</div>
`;

