                              disabled={false}
                              id="confirm-button-delete-campaign-button"
                              onClick={[Function]}
                              type="button"
                            >
                              Delete campaign
                            </button>
                          </ei>
                          <ei
                            isOpen={false}
                            placement="bottom right"
                            target="confirm-button-delete-campaign-button"
                            toggle={[Function]}
                          />
                        </div>
                      </ConfirmButton>
                    </form>
                  </rl>
                </div>
              </Ot>
              <Ot
                tag="div"
                widths={
                  Array [
                    "xs",
                    "sm",
                    "md",
                    "lg",
                    "xl",
                  ]
                }
              >
                <div
                  className="col"
                >
                  <CampaignPreview
                    mainColor="#fefefe"
                  >
                    <div>
                      <div />
                      <div>
                        <div>
                          <div>
                            <img
                              src="https://www.gravatar.com/avatar/0?d=mm"
                            />
                          </div>
                          <div>
                            <div>
                              <b>
                                [Random agent's name]
                              </b>
                            </div>
                            <div
                              dangerouslySetInnerHTML={
                                Object {
                                  "__html": undefined,
                                }
                              }
                            />
                          </div>
                        </div>
                        <div>
                          Click to reply
                        </div>
                      </div>
                      <div
                        style={
                          Object {
                            "backgroundColor": "#fefefe",
                          }
                        }
                      >
                        <img
                          src="/static/private/img/icons/DefaultCloseIcon.svg"
                        />
                      </div>
                    </div>
                  </CampaignPreview>
                </div>
              </Ot>
            </div>
          </bt>
        </div>
      </gt>
    </div>
  </CampaignDetail>
</Connect(CampaignDetail)>
`;
