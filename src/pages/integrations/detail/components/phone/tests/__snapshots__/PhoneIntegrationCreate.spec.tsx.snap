exports[`<PhoneIntegrationCreate/> render() should render 1`] = `
<div
  class="full-width"
>
  <div
    class="d-flex align-items-center justify-content-between flex-wrap page-header"
  >
    <nav
      aria-label="breadcrumb"
      class=""
    >
      <ol
        class="breadcrumb"
      >
        <li
          class="breadcrumb-item"
        >
          <a
            to="/app/settings/integrations"
          >
            Integrations
          </a>
        </li>
        <li
          class="breadcrumb-item"
        >
          <a
            to="/app/settings/integrations/phone"
          >
            Phone
          </a>
        </li>
        <li
          aria-current="page"
          class="active breadcrumb-item"
        >
          Add Phone Number
        </li>
      </ol>
    </nav>
  </div>
  <div
    class="page-container container-fluid"
  >
    <div
      class="row"
    >
      <div
        class="col-lg-6"
      >
        <p>
          Create a new phone number in Gorgias or forward calls from an existing number to a Gorgias internal number. To learn more about forwarding existing calls, check out
           
          <a
            href="https://docs.gorgias.com/voice-and-phone/gorgias-phone-integration"
            rel="noopener noreferrer"
            target="_blank"
          >
            our phone docs
          </a>
          .
        </p>
      </div>
    </div>
    <div
      class="row"
    >
      <div
        class="col-lg-6 col-xl-4"
      >
        <form
          class=""
        >
          <div
            class="form-group"
          >
            <label
              class="control-label"
              for="title"
            >
              Phone title
            </label>
            <div
              class="container"
            >
              <div
                class="picker emojiPicker"
              >
                <span
                  class="material-icons empty icon"
                >
                  insert_emoticon
                </span>
              </div>
              <input
