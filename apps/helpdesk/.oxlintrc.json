{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "env": {
        "browser": true,
        "es6": true,
        "jest": true,
        "node": true
    },
    "globals": {
        "$": "off",
        "amplitude": "off",
        "FB": "off",
        "Stripe": "off"
    },
    "ignorePatterns": [
        "build/**",
        "src/coverage/**",
        "src/rest_api/help_center_api/**",
        "src/rest_api/migration_api/client.generated.d.ts",
        "src/rest_api/revenue_addon_api/client.generated.d.ts",
        "src/rest_api/ssp_api/client.generated.d.ts",
        "src/rest_api/workflows_api/client.generated.d.ts",
        "src/types/**",
        "storybook-static/**"
    ],
    "overrides": [
        {
            "files": ["**/*.spec.ts", "**/*.spec.tsx"],
            "rules": {
                "react/no-unescaped-entities": "off"
            }
        },
        {
            "files": [
                "src/hooks/useAppDispatch.ts",
                "src/hooks/useAppSelector.ts",
                "src/utils/testing/renderHook.tsx",
                "src/utils/wrappers/DateRangePicker.tsx",
                "src/utils/wrappers/DndProvider.tsx",
                "src/utils/wrappers/Draggable.tsx",
                "src/utils/wrappers/Slider.tsx"
            ],
            "rules": {
                "no-restricted-imports": "off"
            }
        },
        {
            "files": [
                "src/domains/reporting/**/*.ts",
                "src/domains/reporting/**/*.tsx"
            ],
            "rules": {
                "no-restricted-imports": [
                    "error",
                    {
                        "patterns": [
                            {
                                "group": ["../*", "./*"],
                                "message": "Relative imports are not allowed in domains/reporting. Use absolute imports instead (e.g., 'domains/reporting/...'), cf RFC https://github.com/gorgias/architectural-decision-records/blob/main/project/helpdesk-web-app/0007-dont-use-relative-parent-imports.md"
                            }
                        ]
                    }
                ]
            }
        }
    ],
    "plugins": ["import", "jsx-a11y", "react", "react-hooks", "typescript"],
    "rules": {
        "typescript/ban-ts-comment": "off",
        "typescript/no-explicit-any": "off",
        "typescript/no-unused-vars": [
            "error",
            {
                "argsIgnorePattern": "^__",
                "varsIgnorePattern": "^__"
            }
        ],
        "typescript/consistent-type-imports": [
            "error",
            {
                "prefer": "type-imports",
                "fixStyle": "separate-type-imports",
                "disallowTypeAnnotations": false
            }
        ],
        "eqeqeq": [
            "error",
            "always",
            {
                "null": "ignore"
            }
        ],
        "import/default": "off",
        "import/namespace": "off",
        "import/no-duplicates": "error",
        "import/no-anonymous-default-export": "error",
        "import/no-named-as-default-member": "error",
        "import/no-default-export": "warn",
        "import/no-named-as-default": "warn",
        "oxc/no-barrel-file": "error",
        "import/consistent-type-specifier-style": ["error", "prefer-top-level"],
        "jsx-a11y/alt-text": ["error"],
        "jsx-a11y/anchor-is-valid": "off",
        "jsx-a11y/click-events-have-key-events": "off",
        "jsx-a11y/no-autofocus": "off",
        "jsx-a11y/no-noninteractive-tabindex": "off",
        "jsx-a11y/tabindex-no-positive": "off",
        "no-async-promise-executor": "off",
        "no-console": [
            "error",
            {
                "allow": ["error", "warn"]
            }
        ],
        "no-else-return": ["error"],
        "no-empty": [
            "error",
            {
                "allowEmptyCatch": true
            }
        ],
        "no-extra-boolean-cast": ["off"],
        "no-param-reassign": ["error"],
        "no-prototype-builtins": "off",
        "no-restricted-imports": [
            "error",
            {
                "paths": [
                    {
                        "importNames": ["act"],
                        "message": "Do not import directly from @testing-library/react-hooks. Use renderHook from utils/testing/renderHook instead.",
                        "name": "@testing-library/react-hooks"
                    },
                    {
                        "importNames": [
                            "DateRangePicker",
                            "default",
                            "EventHandler",
                            "Props"
                        ],
                        "message": "Please use DateRangePicker from /utils/wrappers/DateRangePicker instead.",
                        "name": "react-bootstrap-daterangepicker"
                    },
                    {
                        "importNames": ["default", "DraggableEventHandler"],
                        "message": "Please use the wrapper component from 'utils/wrappers/Draggable' instead.",
                        "name": "react-draggable"
                    },
                    {
                        "importNames": ["default", "Settings"],
                        "message": "Please use the wrapper component from 'utils/wrappers/Slider' instead.",
                        "name": "react-slick"
                    },
                    {
                        "importNames": ["DndProvider"],
                        "message": "Please use the wrapper component from 'utils/wrappers/DndProvider' instead.",
                        "name": "react-dnd"
                    },
                    {
                        "importNames": ["renderHook"],
                        "message": "Import 'renderHook' from '@repo/testing' using alias: import { renderHook } from '@repo/testing'",
                        "name": "@testing-library/react-hooks"
                    },
                    {
                        "importNames": ["useDispatch"],
                        "message": "Please use useAppDispatch from /hooks/useAppDispatch instead.",
                        "name": "react-redux"
                    },
                    {
                        "importNames": ["useSelector"],
                        "message": "Please use useAppSelector from /hooks/useAppSelector instead.",
                        "name": "react-redux"
                    }
                ]
            }
        ],
        "no-unused-vars": "off",
        "no-useless-escape": "off",
        "react-hooks/exhaustive-deps": "error",
        "react-hooks/rules-of-hooks": "error",
        "react/jsx-key": [
            "error",
            {
                "checkFragmentShorthand": true
            }
        ],
        "react/no-find-dom-node": "off",
        "react/no-unescaped-entities": "error",
        "unicorn/no-new-array": "error",
        "unicorn/no-useless-spread": "error",
        "unicorn/*": "off"
    },
    "extends": ["../../node_modules/@gorgias/config/oxlint-react.json"]
}
