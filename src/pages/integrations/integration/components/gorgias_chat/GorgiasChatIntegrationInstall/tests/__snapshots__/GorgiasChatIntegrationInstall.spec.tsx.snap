                          class="code"
                          id="code-snippet-4"
                        >
                          &lt;!--Gorgias Chat Widget Start--&gt;&lt;script id="gorgias-chat-widget-install-v2" src="https:///gorgias-chat-bundle-loader.js?applicationId=undefined"&gt;&lt;/script&gt;&lt;!--Gorgias Chat Widget End--&gt;
                        </pre>
                      </div>
                    </div>
                  </div>
                </div>
                <div
                  class="tab-pane"
                >
                  <div
                    class="wrapper"
                  >
                    <div
                      class="instruction"
                    >
                      <div>
                        <span
                          class="instruction-number"
                        >
                          1
                        </span>
                      </div>
                      <div
                        class="instruction-text"
                      >
                        Edit the source code of your website which contains the closing HTML tag 
                        <b>
                          &lt;/body&gt;
                        </b>
                      </div>
                    </div>
                    <div
                      class="instruction"
                    >
                      <div>
                        <span
                          class="instruction-number"
                        >
                          2
                        </span>
                      </div>
                      <div
                        class="instruction-text"
                      >
                        Just above this tag, copy and paste the code snippet below
                      </div>
                    </div>
                    <div
                      class="instruction"
                    >
                      <div>
                        <span
                          class="instruction-number"
                        >
                          3
                        </span>
                      </div>
                      <div
                        class="instruction-text"
                      >
                        Save the file and commit the changes
                      </div>
                    </div>
                    <div
                      class="alert warning"
                    >
                      <div
                        class="content"
                      >
                        <span
                          class="label"
                        >
                          Please note that by inserting this snippet on your webpage, it will load the chat on that specific webpage only. Make sure to insert the snippet on all the pages for which you wish to display the chat widget.
                        </span>
                      </div>
                    </div>
                    <div
                      class="container"
                    >
                      <div
                        class="wrapper alert alert-success fade"
                        role="alert"
                      >
                        <pre
                          class="code"
                          id="code-snippet-5"
                        >
                          &lt;!--Gorgias Chat Widget Start--&gt;&lt;script id="gorgias-chat-widget-install-v2" src="https:///gorgias-chat-bundle-loader.js?applicationId=undefined"&gt;&lt;/script&gt;&lt;!--Gorgias Chat Widget End--&gt;
                        </pre>
                      </div>
                    </div>
                  </div>
                </div>
                <div
                  class="tab-pane"
                >
                  <div
                    class="wrapper"
                  >
                    <div
                      class="instruction"
                    >
                      <div>
                        <span
                          class="instruction-number"
                        >
                          1
                        </span>
                      </div>
                      <div
                        class="instruction-text"
                      >
                        In Google Tag Manager, click "Tags" in the menu.
                      </div>
                    </div>
                    <div
                      class="instruction"
                    >
                      <div>
                        <span
                          class="instruction-number"
                        >
                          2
                        </span>
                      </div>
                      <div
                        class="instruction-text"
                      >
                        <b>
                          Click "New" to create a new tag.
                        </b>
                      </div>
                    </div>
                    <div
                      class="instruction"
                    >
                      <div>
                        <span
                          class="instruction-number"
                        >
                          3
                        </span>
                      </div>
                      <div
                        class="instruction-text"
                      >
                        Search for "Gorgias Chat" and select it.
                      </div>
                    </div>
                    <div
                      class="instruction"
                    >
                      <div>
                        <span
                          class="instruction-number"
                        >
                          4
                        </span>
                      </div>
                      <div
                        class="instruction-text"
                      >
                        <b>
                          Enter your
                        </b>
                         Gorgias Chat App ID : 
                      </div>
                    </div>
                    <div
                      class="instruction"
                    >
                      <div>
                        <span
                          class="instruction-number"
                        >
                          5
                        </span>
                      </div>
                      <div
                        class="instruction-text"
                      >
                        Select "All Pages - Page view" in the Trigger section.
                      </div>
                    </div>
                    <div
                      class="instruction"
                    >
                      <div>
                        <span
                          class="instruction-number"
                        >
                          6
                        </span>
                      </div>
                      <div
                        class="instruction-text"
                      >
                        Save and publish.
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div
          class="installationOptions"
        >
          <div
            class="formGroup d-flex"
          >
            <div>
              <label
                aria-label="Hide chat"
                class="label label"
                for="toggle-button-6"
                role="switch"
              >
                <input
                  aria-label="Hide chat"
                  class="input"
                  disabled=""
                  id="toggle-button-6"
                  name="toggle-button-6"
                  type="checkbox"
                />
                <div
                  class="slider"
                />
              </label>
            </div>
            <div
              class="ml-2"
            >
              <b>
                Hide Chat
              </b>
               
              <i
                class="material-icons-outlined"
                id="hide-chat-help"
              >
                error_outline
              </i>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
`;

