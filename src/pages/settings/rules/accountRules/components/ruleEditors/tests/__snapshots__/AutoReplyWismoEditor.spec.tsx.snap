                        format_italic
                      </i>
                    </button>
                    <button
                      class="wrapper button wrapper small fill secondary small"
                      id="format_underline"
                      type="button"
                    >
                      <i
                        class="material-icons icon"
                      >
                        format_underline
                      </i>
                    </button>
                    <span
                      class="popoverWrapper"
                    >
                      <button
                        class="wrapper button wrapper small fill secondary small"
                        id="insert_link"
                        type="button"
                      >
                        <i
                          class="material-icons icon"
                        >
                          link
                        </i>
                      </button>
                      <div
                        class="popover top-left hidden"
                      />
                    </span>
                    <span
                      class="popoverWrapper"
                    >
                      <button
                        class="wrapper button wrapper small fill secondary small"
                        id="insert_photo"
                        type="button"
                      >
                        <i
                          class="material-icons icon"
                        >
                          insert_photo
                        </i>
                      </button>
                      <div
                        class="popover top-left hidden"
                      />
                    </span>
                    <span
                      class="popoverWrapper"
                    >
                      <button
                        class="wrapper button wrapper small fill secondary small"
                        id="insert_emoticon"
                        type="button"
                      >
                        <i
                          class="material-icons icon"
                        >
                          insert_emoticon
                        </i>
                      </button>
                      <div
                        class="p-0 d-flex popover top-left hidden"
                      />
                    </span>
                    <span
                      class="popoverWrapper"
                    >
                      <button
                        class="wrapper button wrapper small fill secondary small"
                        id="insert_shopify_product"
                        type="button"
                      >
                        <i
                          class="material-icons icon"
                        >
                          shopify
                        </i>
                      </button>
                      <div
                        class="productLinkToolTip p-0 d-flex popover top-left hidden"
                      />
                    </span>
                  </div>
                  <div
                    class="hoverOverlay"
                  >
                    Add files as attachments
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
`;
