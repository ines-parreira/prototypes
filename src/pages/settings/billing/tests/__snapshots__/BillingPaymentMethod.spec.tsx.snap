exports[`BillingPaymentMethod Shopify should render a button 1`] = `
<div
  class="wrapper"
>
  <h4
    class="header"
  >
    <i
      class="icon material-icons"
    >
      credit_card
    </i>
    Payment method
  </h4>
  <div
    class="card"
  >
    <div
      class="card-body"
    >
      <div
        id="activate-shopify-billing-button"
        style="display: inline-block;"
      >
        <a
          class=""
