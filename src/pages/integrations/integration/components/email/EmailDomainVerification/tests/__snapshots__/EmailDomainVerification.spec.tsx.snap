              >
                Status
              </span>
              <i
                class="material-icons md-1 directionIcon"
              >
                arrow_upward
              </i>
            </div>
          </div>
        </td>
        <td
          class="wrapper recordTypeHeader normal"
        >
          <div
            class="content"
          >
            <div
              class="cell"
            >
              <span
                class="title"
              >
                Type
              </span>
              <i
                class="material-icons md-1 directionIcon"
              >
                arrow_upward
              </i>
            </div>
          </div>
        </td>
        <td
          class="wrapper normal"
        >
          <div
            class="content"
          >
            <div
              class="cell"
            >
              <span
                class="title"
              >
                Host
              </span>
              <i
                class="material-icons md-1 directionIcon"
              >
                arrow_upward
              </i>
            </div>
          </div>
        </td>
        <td
          class="wrapper normal"
        >
          <div
            class="content"
          >
            <div
              class="cell"
            >
              <span
                class="title"
              >
                Value
              </span>
              <i
                class="material-icons md-1 directionIcon"
              >
                arrow_upward
              </i>
            </div>
          </div>
        </td>
        <td
          class="wrapper normal"
        >
          <div
            class="content"
          >
            <div
              class="cell"
            >
              <span
                class="title"
              >
                Current Values
              </span>
              <i
                class="material-icons md-1 directionIcon"
              >
                arrow_upward
              </i>
            </div>
          </div>
        </td>
      </tr>
    </thead>
    <tbody
      class="tableBody"
    />
  </table>
  <button
    aria-disabled="false"
    class="wrapper fill destructive medium"
    id="confirm-1"
    type="button"
  >
    <span
      class="wrapper"
    >
      <i
        class="material-icons icon isLeft medium"
      >
        delete
      </i>
      Delete domain
    </span>
  </button>
</div>
`;

