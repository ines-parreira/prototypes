exports[`<GorgiasChatIntegrationPreferences/> render() should render the Chat preferences 1`] = `
<div
  class="full-width"
>
  <div
    class="page-header pageHeader"
  >
    <nav
      aria-label="breadcrumb"
      class=""
    >
      <ol
        class="breadcrumb"
      >
        <li
          class="breadcrumb-item"
        >
          <a
            href="/app/settings/channels/gorgias_chat"
          >
            Chat
          </a>
        </li>
        <li
          class="breadcrumb-item"
        />
      </ol>
    </nav>
  </div>
  <div
    data-testid="GorgiasChatIntegrationHeader"
  />
  <div
    class="pageContainer container-fluid"
  >
    <div
      class="row row"
    >
      <div
        class="col"
      >
        <form
          class=""
        >
          <div>
            <div
              class="formSection"
            >
              <h4
                class="title mb-1"
              >
                Live chat
              </h4>
              <div>
                <p
                  class="mb-4"
                >
                  Choose when customers can send live chat messages to your team during
                   
                  <a
                    href="/app/settings/business-hours"
                  >
                    business hours
                  </a>
                  .
                   
                </p>
                <fieldset
                  class="mb-3 radioFieldSet"
                  name="radio-field-52"
                >
                  <div
                    class="option"
                  >
                    <label
                      class="ui-label-label-a11c label"
                      for="auto-based-on-agent-availability"
                    >
                      <input
                        checked=""
                        class="input"
                        id="auto-based-on-agent-availability"
                        name="radio-field-52"
                        type="radio"
                      />
                      Live when agents are available
                    </label>
                    <div
                      class="caption caption"
                    >
                      Customers can only send live chat messages when an agent is available in Gorgias
                    </div>
                  </div>
                  <div
                    class="option"
                  >
                    <label
                      class="ui-label-label-a11c label"
                      for="always-live-during-business-hours"
                    >
                      <input
                        class="input"
                        id="always-live-during-business-hours"
                        name="radio-field-52"
                        type="radio"
                      />
                      Always live during business hours
                    </label>
                    <div
                      class="caption caption"
                    >
                      Customers can always send live chat messages during business hours
                    </div>
                  </div>
                  <div
                    class="option"
                  >
                    <label
                      class="ui-label-label-a11c label"
                      for="offline"
                    >
                      <input
                        class="input"
                        id="offline"
                        name="radio-field-52"
                        type="radio"
                      />
                      Offline
                    </label>
                    <div
                      class="caption caption"
                    >
                      Customers can only send messages using the contact form
                    </div>
                  </div>
                </fieldset>
                <p
                  class="mb-3"
                >
                  AI Agent features are always available, if enabled. When live chat is unavailable, customers can message your team with
                   
                  <a
                    href="https://docs.gorgias.com/en-US/gorgias-chat---contact-form-88573"
                    rel="noopener noreferrer"
                    target="_blank"
                  >
                    contact form
                  </a>
                   
                  to receive an email response.
                   
                  Live chat is always unavailable outside business hours.
                </p>
              </div>
            </div>
            <div
              class="formSection"
            >
              <h4
                class="title mb-1"
              >
                Require automated interaction
              </h4>
              <div>
                <p
                  class="mb-4"
                >
                  Hide “Send us a message” so customers must start with an automation button before they can send a message. Requiring automated interactions may lower the volume of live chat and offline capture tickets your team must answer manually.
                </p>
                <div
                  class="formGroup d-inline-block"
                >
                  <div>
                    <label
                      aria-checked="false"
                      class="ui-label-label-a11c ui-togglefield-label-9b7c"
                      role="switch"
                    >
                      <input
                        class="ui-togglefield-input-9b7c"
                        disabled=""
                        type="checkbox"
                      />
                      <div
                        class="ui-togglefield-slider-9b7c"
                      />
                      <div>
                        Remove “Send us a message” button
                      </div>
                    </label>
                  </div>
                </div>
              </div>
            </div>
            <div
              class="formSection"
            >
              <h4
                class="title"
              >
                Visibility options
              </h4>
              <div
                class="formGroup d-flex"
              >
                <div>
                  <label
                    aria-checked="false"
                    aria-label="Hide chat"
                    class="ui-label-label-a11c ui-togglefield-label-9b7c"
                    role="switch"
                  >
                    <input
                      aria-label="Hide chat"
                      class="ui-togglefield-input-9b7c"
                      disabled=""
                      type="checkbox"
                    />
                    <div
                      class="ui-togglefield-slider-9b7c"
                    />
                    <div />
                  </label>
                </div>
                <div
                  class="toggleInfo ml-1"
                >
                  <b>
                    Hide chat
                  </b>
                  <span
                    class="tooltipIcon"
                    id="hide-chat-help"
                  >
                    <i
                      class="material-icons-outlined"
                    >
                      error_outline
                    </i>
                  </span>
                  <div
                    class="form-text text-muted"
                  >
                    Remove widget from your website without uninstalling it
                  </div>
                </div>
              </div>
              <div
                class="formGroup d-flex"
              >
                <div>
                  <label
                    aria-checked="false"
                    class="ui-label-label-a11c ui-togglefield-label-9b7c"
                    role="switch"
                  >
                    <input
                      class="ui-togglefield-input-9b7c"
                      disabled=""
                      type="checkbox"
                    />
                    <div
                      class="ui-togglefield-slider-9b7c"
                    />
                    <div />
                  </label>
                </div>
                <div
                  class="toggleInfo ml-1"
                >
                  <b>
                    Hide outside of business hours
                  </b>
                  <span
                    class="tooltipIcon"
                    id="hide-outside-business-hours-help"
                  >
                    <i
                      class="material-icons-outlined"
                    >
                      info
                    </i>
                  </span>
                  <div
                    class="form-text text-muted"
                  >
                    Remove widget from your website after business hours
                  </div>
                </div>
              </div>
              <div
                class="formGroup d-flex"
              >
                <div>
                  <label
                    aria-checked="false"
                    class="ui-label-label-a11c ui-togglefield-label-9b7c"
                    role="switch"
                  >
                    <input
                      class="ui-togglefield-input-9b7c"
                      disabled=""
                      type="checkbox"
                    />
                    <div
                      class="ui-togglefield-slider-9b7c"
                    />
                    <div />
                  </label>
                </div>
                <div
                  class="toggleInfo ml-1"
                >
                  <b>
                    Hide on mobile
                  </b>
                </div>
              </div>
            </div>
            <div
              class="formSection"
            >
              <h4
                class="title mb-1"
              >
                Email capture
              </h4>
              <p
                class="mb-4"
              >
                Collecting customer emails helps grow your email list and send follow-up messages. However, only around 30% of customers will send a message if they must provide an email.
              </p>
              <div
                class="mb-4 d-flex align-items-center"
              >
                <div>
                  <label
                    aria-checked="true"
                    class="ui-label-label-a11c ui-togglefield-label-9b7c"
                    role="switch"
                  >
                    <input
                      checked=""
                      class="ui-togglefield-input-9b7c"
                      disabled=""
                      name="disable-email-capture-toggle"
                      type="checkbox"
                    />
                    <div
                      class="ui-togglefield-slider-9b7c"
                    />
                    <div>
                      <b>
                        Enable email capture
                      </b>
                    </div>
                  </label>
                </div>
              </div>
              <fieldset
                class=""
                name="radio-field-53"
              >
                <div
                  class="option"
                >
                  <label
                    class="ui-label-label-a11c label"
                    for="optional"
                  >
                    <input
                      checked=""
                      class="input"
                      id="optional"
                      name="radio-field-53"
                      type="radio"
                    />
                    Optional
                  </label>
                </div>
                <div
                  class="option"
                >
                  <label
                    class="ui-label-label-a11c label"
                    for="always-required"
                  >
                    <input
                      class="input"
                      id="always-required"
                      name="radio-field-53"
                      type="radio"
                    />
                    Required
                  </label>
                </div>
              </fieldset>
            </div>
            <div
              class="formSection"
            >
              <h4
                class="title mb-1"
              >
                Auto-reply with wait time
              </h4>
              <p
                class="mb-4"
              >
                During
                 
                <a
                  href="/app/settings/business-hours"
                >
                  business hours
                </a>
                , let customers know how fast they can expect a response with an auto-reply. A message is sent in new chat tickets after 30 seconds without replies from an agent.
              </p>
              <div
                class="mb-4 d-flex align-items-center"
              >
                <div>
                  <label
                    aria-checked="true"
                    aria-label="auto-responder-toggle"
                    class="ui-label-label-a11c ui-togglefield-label-9b7c"
                    role="switch"
                  >
                    <input
                      aria-label="auto-responder-toggle"
                      checked=""
                      class="ui-togglefield-input-9b7c"
                      disabled=""
                      name="auto-responder-toggle"
                      type="checkbox"
                    />
                    <div
                      class="ui-togglefield-slider-9b7c"
                    />
                    <div />
                  </label>
                </div>
                <div
                  class="ml-1"
                >
                  <b>
                    Send auto-reply with wait time
                  </b>
                </div>
              </div>
              <div
                class="mb-3"
              >
                <fieldset
                  class="mb-2 radioFieldSet"
                  name="radio-field-54"
                >
                  <div
                    class="option"
                  >
                    <label
                      class="ui-label-label-a11c label"
                      for="reply-dynamic"
                    >
                      <input
                        checked=""
                        class="input"
                        id="reply-dynamic"
                        name="radio-field-54"
                        type="radio"
                      />
                      <div>
                        Dynamic wait time (recommended)
                        <span
                          class="tooltipIcon"
                          id="dynamic-wait-time-option"
                        >
                          <i
                            class="material-icons"
                          >
                            info_outline
                          </i>
                        </span>
                        <p
                          class="dynamicDescription"
                        >
                          Customers can only send live chat messages when an agent is available in Gorgias
                        </p>
                      </div>
                    </label>
                  </div>
                  <div
                    class="option"
                  >
                    <label
                      class="ui-label-label-a11c label"
                      for="reply-in-minutes"
                    >
                      <input
                        class="input"
                        id="reply-in-minutes"
                        name="radio-field-54"
                        type="radio"
                      />
                      In a few minutes
                    </label>
                  </div>
                  <div
                    class="option"
                  >
                    <label
                      class="ui-label-label-a11c label"
                      for="reply-in-hours"
                    >
                      <input
                        class="input"
                        id="reply-in-hours"
                        name="radio-field-54"
                        type="radio"
                      />
                      In a few hours
                    </label>
                  </div>
                </fieldset>
              </div>
            </div>
            <div
              class="formSection"
            >
              <h4
                class="title mb-1"
              >
                Forward chat replies to customer emails
              </h4>
              <p
                class="mb-3"
              >
                When customers don't see your live chat response after an hour, Gorgias will automatically send your message to the customer's email address (if available). Customers also receive satisfaction surveys for chat tickets via email.
              </p>
              <label
                class="control-label"
                for="linkedEmailIntegration"
              >
                Select which email address sends these messages
              </label>
              <div>
                <div
                  class="dropdown"
                >
                  <div
                    aria-expanded="false"
                    aria-haspopup="true"
                    class=""
                    data-toggle="dropdown"
                  >
                    <div
                      class="select dropdown-toggle selectFullWidth"
                    >
                      <span
                        class="label placeholder"
                        data-testid="selected-linkedEmailIntegration"
                        style="min-width: 10px; opacity: 1;"
                      >
                        Select an email integration
                      </span>
                      <input
                        autocomplete="chrome-off"
                        class="input"
                        id="linkedEmailIntegration"
                        style="min-width: 10px;"
                        type="text"
                        value=""
                      />
                      <i
                        class="material-icons dropdownIcon"
                      >
                        arrow_drop_down
                      </i>
                    </div>
                  </div>
                  <div
                    aria-hidden="true"
                    class="options optionsFullWidth dropdown-menu"
                    role="menu"
                    tabindex="-1"
                  >
                    <h6
                      class="dropdown-header"
                      tabindex="-1"
                    >
                      No result
                    </h6>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <button
            aria-disabled="false"
            class="ui-button-wrapper-a432 ui-button-md-a432 ui-button-primary-a432"
