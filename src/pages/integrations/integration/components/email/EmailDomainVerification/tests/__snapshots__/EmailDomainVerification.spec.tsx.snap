exports[`<EmailDomainVerification/> render() should render a delete button to account admins 1`] = `
<div>
  <div>
    Your domain has been verified.
  </div>
  <table
    class="table records-table"
  >
    <thead
      class=""
    >
      <tr
        class="headerRow"
      >
        <td
          class="wrapper normal"
        >
          Status
        </td>
        <td
          class="wrapper normal"
        >
          Record Type
        </td>
        <td
          class="wrapper normal"
        >
          Host
        </td>
        <td
          class="wrapper normal"
        >
          Value
        </td>
        <td
          class="wrapper normal"
        >
          Current Values
        </td>
      </tr>
    </thead>
    <tbody
      class="tableBody"
    />
  </table>
  <button
    class="wrapper fill destructive medium"
    id="confirm-42"
    type="button"
  >
    <span
      class="wrapper"
    >
      <i
        class="material-icons icon isLeft medium"
      >
        delete
      </i>
      Delete domain
    </span>
  </button>
</div>
`;

exports[`<EmailDomainVerification/> render() should render the page when domain is not verified 1`] = `
<div>
  <div>
    <div
      class="alert warning mb16"
    >
      <div
        class="content"
      >
        <span
          class="label"
        >
          This domain has not yet been verified. You can still send emails from this address but you may be more susceptible to deliverability issues. Please verify your domain to ensure the best possible performance.
        </span>
      </div>
    </div>
    <span>
      To enable DKIM signing for your domain, please add the information below to your DNS records via your DNS registrar. Note that verification of these settings
       
      <strong>
        may take up to 72 hours after submission
      </strong>
      .
       
      <a
        href="https://docs.gorgias.com/en-US/spf-dkim-support-81757"
        rel="noopener noreferrer"
        target="_blank"
      >
        Learn more
      </a>
    </span>
  </div>
  <table
    class="table records-table"
  >
    <thead
      class=""
    >
      <tr
        class="headerRow"
      >
        <td
          class="wrapper normal"
        >
          Status
        </td>
        <td
          class="wrapper normal"
        >
          Record Type
        </td>
        <td
          class="wrapper normal"
        >
          Host
        </td>
        <td
          class="wrapper normal"
        >
          Value
        </td>
        <td
          class="wrapper normal"
        >
          Current Values
        </td>
      </tr>
    </thead>
    <tbody
      class="tableBody"
    />
  </table>
</div>
`;

