exports[`<GorgiasChatIntegrationAppearance/> render() should not mark the file field for team picture as required because the avatar type is \`team-picture\` but there is a team picture set 1`] = `
<div>
  <div
    class="full-width"
  >
    <div
      class="page-header pageHeader"
    >
      <nav
        aria-label="breadcrumb"
        class=""
      >
        <ol
          class="breadcrumb"
        >
          <li
            class="breadcrumb-item"
          >
            <a
              to="/app/settings/channels/gorgias_chat"
            >
              Chat
            </a>
          </li>
          <li
            class="breadcrumb-item"
          >
            hellochatintegration
          </li>
        </ol>
      </nav>
      <div>
        <div
          data-testid="GorgiasChatIntegrationConnectedChannel"
        />
      </div>
    </div>
    <div
      data-testid="GorgiasChatIntegrationNavigation"
    />
    <div
      class="pageContainer container-fluid"
    >
      <div
        class="row"
      >
        <div
          class="col"
        >
          <form
            class=""
          >
            <div
              class="form"
            >
              <div
                class="formSection"
              >
                <div
                  class="InputField formGroup required form-group"
                  color=""
                >
                  <label
                    class="control-label"
                    for="id-input-42"
                  >
                    Chat title
                  </label>
                  <div
                    class=""
                  >
                    <input
                      class="field form-control"
                      id="id-input-42"
                      placeholder="Ex: Company Support"
                      required=""
                      type="text"
                      value="hellochatintegration"
                    />
                  </div>
                </div>
                <div
                  class="InputField formGroup form-group"
                  color=""
                >
                  <label
                    class="control-label"
                    for="id-input-42"
                  >
                    Language
                  </label>
                  <div
                    class="select dropdown-toggle"
                  >
                    <select
                      class="field form-control"
                      id="id-input-42"
                      options="[object Object],[object Object],[object Object],[object Object],[object Object],[object Object],[object Object],[object Object],[object Object],[object Object],[object Object]"
                    >
                      <option
                        value="en-US"
                      >
                        English (US)
                      </option>
                      <option
                        value="fr-FR"
                      >
                        French (France)
                      </option>
                      <option
                        value="fr-CA"
                      >
                        French (Canada)
                      </option>
                      <option
                        value="es"
                      >
                        Spanish
                      </option>
                      <option
                        value="da"
                      >
                        Danish
                      </option>
                      <option
                        value="sv"
                      >
                        Swedish
                      </option>
                      <option
                        value="it"
                      >
                        Italian
                      </option>
                      <option
                        value="nl"
                      >
                        Dutch
                      </option>
                      <option
                        value="de"
                      >
                        German
                      </option>
                      <option
                        value="no"
                      >
                        Norwegian
                      </option>
                      <option
                        value="cz"
                      >
                        Czech
                      </option>
                    </select>
                  </div>
                </div>
              </div>
              <div
                class="formSection"
              >
                <h2
                  class="title"
                >
                  Intro message
                </h2>
                <div
                  class="InputField formGroup form-group"
                  color=""
                >
                  <label
                    class="control-label"
                    for="id-input-42"
                  >
                    During business hours
                  </label>
                  <div
                    class=""
                  >
                    <input
                      class="field form-control"
                      id="id-input-42"
                      maxlength="50"
                      type="text"
                      value="How can we help?"
                    />
                  </div>
                </div>
                <div
                  class="InputField formGroup form-group"
                  color=""
                >
                  <label
                    class="control-label"
                    for="id-input-42"
                  >
                    Outside business hours
                  </label>
                  <div
                    class=""
                  >
                    <input
                      class="field form-control"
                      id="id-input-42"
                      maxlength="50"
                      type="text"
                      value="We'll be back tomorrow"
                    />
                  </div>
                </div>
                <div
                  class="alert info mb-4"
                >
                  <div
                    class="iconContainer"
                  >
                    <img
                      alt="icon"
                      src="test-file-stub"
                    />
                  </div>
                  <div
                    class="content"
                  >
                    <span
                      class="label"
                    >
                      <div>
                        Customize copy for labels, automated messages, and
                         
                        contact form
                         
                        subjects to match your tone of voice.
                      </div>
                    </span>
                    <div
                      class="customActions"
                    >
                      <a
                        class="actionLink"
                        to="/app/settings/channels/gorgias_chat/2/appearance/texts"
                      >
                        Customize Copy
                      </a>
                    </div>
                  </div>
                </div>
              </div>
              <div
                class="formSection"
              >
                <h2
                  class="title"
                >
                  Colors
                </h2>
                <div
                  class="colorPickersWrapper"
                >
                  <div
                    class="InputField colorPicker form-group"
                    color=""
                  >
                    <label
                      class="control-label"
                      for="id-input-42"
                    >
                      Main color
                    </label>
                    <div
                      class=""
                    >
                      <div
                        class="wrapper"
                      >
                        <button
                          aria-disabled="false"
                          class="wrapper button fill secondary medium"
                          id="color-picker-42"
                          type="button"
                        >
                          <div
                            class="color"
                            style="background-color: rgb(17, 92, 181);"
                          />
                        </button>
                        <input
                          class="input form-control"
                          placeholder="ex: #eeeeee"
                          type="text"
                          value="#115cb5"
                        />
                      </div>
                    </div>
                  </div>
                  <div
                    class="InputField colorPicker form-group"
                    color=""
                  >
                    <label
                      class="control-label"
                      for="id-input-42"
                    >
                      Conversation color
                    </label>
                    <div
                      class=""
                    >
                      <div
                        class="wrapper"
                      >
                        <button
                          aria-disabled="false"
                          class="wrapper button fill secondary medium"
                          id="color-picker-42"
                          type="button"
                        >
                          <div
                            class="color"
                            style="background-color: rgb(17, 92, 181);"
                          />
                        </button>
                        <input
                          class="input form-control"
                          placeholder="ex: #eeeeee"
                          type="text"
                          value="#115cb5"
                        />
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <div
                class="formSection"
              >
                <h2
                  class="title"
                >
                  Chat header
                </h2>
                <fieldset
                  class="mb-3"
                  name="type-field"
                >
                  <legend
                    class="legend"
                  >
                    Image
                  </legend>
                  <div
                    class="option"
                  >
                    <label
                      class="label label"
                      for="team-members"
                    >
                      <input
                        checked=""
                        class="input"
                        id="team-members"
                        name="type-field"
                        type="radio"
                      />
                      Use team members' avatars
                    </label>
                  </div>
                  <div
                    class="option"
                  >
                    <label
                      class="label label"
                      for="team-picture"
                    >
                      <input
                        class="input"
                        id="team-picture"
                        name="type-field"
                        type="radio"
                      />
                      Use a single image for the whole team
                    </label>
                    <div
                      class="caption caption"
                    >
                      For example, use your company's logo. The image needs to be a square of 500kb maximum.
                    </div>
                  </div>
                </fieldset>
                <div
                  class="d-flex flex-direction-row mb-2"
                >
                  <img
                    alt="Team avatar"
                    class="mr-3"
                    src="https://gorgias.io/teampicture.png"
                    style="max-width: 100px;"
                  />
                  <div>
                    FileField component is required ? 
                    false
                  </div>
                </div>
              </div>
              <div
                class="formSection"
              >
                <h2
                  class="title"
                >
                  Launcher
                </h2>
                <div
                  class="launcherSettingsGrid"
                >
                  <div
                    class="InputField formGroup form-group"
                    color=""
                  >
                    <label
                      class="control-label"
                      for="id-input-42"
                    >
                      Widget position on page
                    </label>
                    <div
                      class="select dropdown-toggle"
                    >
                      <select
                        class="field form-control"
                        id="id-input-42"
                        options="[object Object],[object Object],[object Object],[object Object]"
                      >
                        <option
                          value="bottom-right"
                        >
                          Bottom right
                        </option>
                        <option
                          value="bottom-left"
                        >
                          Bottom left
                        </option>
                        <option
                          value="top-right"
                        >
                          Top right
                        </option>
                        <option
                          value="top-left"
                        >
                          Top left
                        </option>
                      </select>
                    </div>
                  </div>
                  <div
                    class="positionInputsWrapper"
                  >
                    <div>
                      <label
                        class="bold"
                      >
                        Move left / right
                        <span
                          id="move-widget-left-right"
                        >
                          <i
                            class="material-icons-outlined tooltipIcon"
                          >
                            info
                          </i>
                        </span>
                      </label>
                      <span
                        class="wrapper group horizontal"
                      >
                        <input
                          class="input isAlignedRight"
                          max="200"
                          min="-20"
                          step="1"
                          type="number"
                          value="0"
                        />
                        <span
                          class="suffix"
                        >
                          px
                        </span>
                        <span
                          class="controls group vertical"
                        >
                          <button
                            aria-disabled="false"
                            class="wrapper button wrapper small fill secondary small top"
                            type="button"
                          >
                            <i
                              class="material-icons icon"
                            >
                              arrow_drop_up
                            </i>
                          </button>
                          <button
                            aria-disabled="false"
                            class="wrapper button wrapper small fill secondary small bottom"
                            type="button"
                          >
                            <i
                              class="material-icons icon"
                            >
                              arrow_drop_down
                            </i>
                          </button>
                        </span>
                      </span>
                    </div>
                    <div>
                      <label
                        class="bold"
                      >
                        Move up / down
                        <span
                          id="move-widget-up-down"
                        >
                          <i
                            class="material-icons-outlined tooltipIcon"
                          >
                            info
                          </i>
                        </span>
                      </label>
                      <span
                        class="wrapper group horizontal"
                      >
                        <input
                          class="input isAlignedRight"
                          max="200"
                          min="-20"
                          step="1"
                          type="number"
                          value="0"
                        />
                        <span
                          class="suffix"
                        >
                          px
                        </span>
                        <span
                          class="controls group vertical"
                        >
                          <button
                            aria-disabled="false"
                            class="wrapper button wrapper small fill secondary small top"
                            type="button"
                          >
                            <i
                              class="material-icons icon"
                            >
                              arrow_drop_up
                            </i>
                          </button>
                          <button
                            aria-disabled="false"
                            class="wrapper button wrapper small fill secondary small bottom"
                            type="button"
                          >
                            <i
                              class="material-icons icon"
                            >
                              arrow_drop_down
                            </i>
                          </button>
                        </span>
                      </span>
                    </div>
                  </div>
                </div>
              </div>
              <div>
                <button
                  aria-disabled="false"
                  class="wrapper fill primary medium"
                  type="submit"
                >
                  Save changes
                </button>
              </div>
            </div>
          </form>
        </div>
        <div
          class="col"
        >
          <div
            class="stickyParent"
          >
            <div
              class="preview"
