<div
  class="full-width"
>
  <div
    class="page-header pageHeader"
  >
    <nav
      aria-label="breadcrumb"
      class=""
    >
      <ol
        class="breadcrumb"
      >
        <li
          class="breadcrumb-item"
        >
          <a
            href="/app/settings/integrations"
          >
            All apps
          </a>
        </li>
        <li
          class="breadcrumb-item"
        >
          <a
            href="/app/settings/integrations/magento2/connections"
          >
            Magento 2
          </a>
        </li>
        <li
          aria-current="page"
          class="active breadcrumb-item"
        >
          Connect app
        </li>
      </ol>
    </nav>
  </div>
  <div
    class="pageContainer container-fluid"
  >
    <div
      class="row"
    >
      <div
        class="col-md-8"
      >
        <h2
          class="stepTitle"
        >
          Step 1
        </h2>
        <p>
          Follow
           
          <a
            href="https://docs.gorgias.com/en-US/magento-2-81817"
            rel="noopener noreferrer"
            target="_blank"
          >
            these instructions
          </a>
           
          to install Gorgias extension to your Magento 2 store.
          <br />
          Make sure to complete this step, or else the connection will not work.
        </p>
        <h2
          class="stepTitle"
        >
          Step 2
        </h2>
        <label
          class="ui-label-label-a11c"
        >
          How do you want to connect this app?
          <abbr
            aria-label="required"
            class="ui-label-abbr-a11c"
            title="required"
          >
            *
          </abbr>
        </label>
        <div
          class="selectionButtonGroup"
        >
          <div
            aria-checked="true"
            aria-label="Connect in 1 click"
            class="wrapper selected selectionButton"
            role="radio"
            tabindex="0"
          >
            <div>
              <label
                class="ui-label-label-a11c label"
                for="radio-button-oneStepConnect"
              >
                <input
                  checked=""
                  class="input"
                  id="radio-button-oneStepConnect"
                  tabindex="-1"
                  type="radio"
                />
                Connect in 1 click
              </label>
            </div>
          </div>
          <div
            aria-checked="false"
            aria-label="Connect manually"
            class="wrapper selectionButton"
            id="magento-manual-connect3"
            role="radio"
            tabindex="0"
          >
            <div>
              <label
                class="ui-label-label-a11c label"
                for="radio-button-magento-manual-connect3"
              >
                <input
                  class="input"
                  id="radio-button-magento-manual-connect3"
                  tabindex="-1"
                  type="radio"
                />
                Connect manually
              </label>
            </div>
          </div>
        </div>
        <form
          class=""
        >
          <label
            class="ui-label-label-a11c mb-2"
            for="store-field"
          >
            Store admin URL
            <abbr
              aria-label="required"
              class="ui-label-abbr-a11c"
              title="required"
            >
              *
            </abbr>
          </label>
          <span
            class="mb-4 wrapper group horizontal"
          >
            <span
              class="groupAddon left"
            >
              https://
            </span>
            <div
              class="wrapper right isNested"
            >
              <input
                class="input"
                data-resizable="false"
                id="store-field"
                name="admin-url"
                pattern="^[a-z.0-9-]*\\.[a-z0-9]*(:[0-9]+)?\\/(index\\.php)?[\\/\\w\\d_-]*$"
                placeholder="ex: acme.com/admin_45f1c"
                required=""
                type="text"
                value=""
              />
            </div>
