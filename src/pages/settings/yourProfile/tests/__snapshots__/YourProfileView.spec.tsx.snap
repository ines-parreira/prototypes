              placeholder="Select an option"
              required={false}
              singular="option"
              style={{}}
              value="EST"
            />
          </FormGroup>
          <FormGroup
            className="inputField"
            tag="div"
          >
            <Label
              className="control-label"
              tag="label"
              widths={
                [
                  "xs",
                  "sm",
                  "md",
                  "lg",
                  "xl",
                ]
              }
            >
              Language
            </Label>
            <SelectField
              allowCustomValue={false}
              fixedWidth={false}
              fullWidth={true}
              id={null}
              onChange={[Function]}
              onSearchChange={[Function]}
              options={
                [
                  {
                    "label": "English US",
                    "value": "en",
                  },
                  {
                    "label": "French",
                    "value": "fr",
                  },
                ]
              }
              placeholder="Select an option"
              required={false}
              singular="option"
              style={{}}
              value="en"
            />
            <FormText
              color="muted"
              tag="small"
            >
              Changing the language only changes the time format
            </FormText>
          </FormGroup>
        </div>
        <FormGroup
          className="profilePicture inputField"
          tag="div"
        >
          <Label
            className="control-label"
            tag="label"
            widths={
              [
                "xs",
                "sm",
                "md",
                "lg",
                "xl",
              ]
            }
          >
            Profile picture
          </Label>
          <Avatar
            className="mb16"
            email=""
            name="Alex Plugaru"
            shape="square"
            size={100}
            style={{}}
            url="https://config.gorgias.io/production/picture"
          />
          <Connect(FileFieldContainer)
            className="mb16"
            maxSize={500000}
            noPreview={true}
            onChange={[Function]}
            returnFiles={false}
            uploadType="profile_picture"
          />
          <FormText
            color="muted"
            tag="small"
          >
            The picture must be square and weight less than 500kB.
          </FormText>
          <a
            className="text-danger"
            href="#"
            onClick={[Function]}
          >
            Remove Picture
          </a>
        </FormGroup>
      </div>
      <div
        className="contentWrapper"
      >
        <div
          className="heading-subsection-semibold mb16"
        >
          My Macro Preferences
        </div>
        <FormGroup
          className="inputField mb32 body-regular"
          tag="div"
        >
          <Group
            className="inputField"
            orientation="vertical"
          >
            <ToggleInput
              name="prefill_best_macro"
              onClick={[Function]}
            >
              Macro prediction
            </ToggleInput>
            <FormText
              color="muted"
              tag="small"
            >
              Automatically select macros based on ticket content.
               
              <a
                href="https://docs.gorgias.com/en-US/macros-81846#:~:text=will%20be%20easier.-,Additional%20features,-Still%20not%20fast"
                rel="noopener noreferrer"
                target="_blank"
              >
                Learn more
              </a>
            </FormText>
          </Group>
          <Group
            className="inputField"
            orientation="vertical"
          >
            <ToggleInput
              name="show_macros"
              onClick={[Function]}
            >
              Display macro search view by default
            </ToggleInput>
            <FormText
              color="muted"
              tag="small"
            >
              Always display the macro search view when responding to incoming emails.
               
              <a
                href="https://docs.gorgias.com/en-US/macros-81846#:~:text=will%20be%20easier.-,Additional%20features,-Still%20not%20fast"
                rel="noopener noreferrer"
                target="_blank"
              >
                Learn more
              </a>
            </FormText>
          </Group>
          <Group
            className="inputField"
            orientation="vertical"
          >
            <ToggleInput
              isToggled={true}
              name="show_macros_suggestions"
              onClick={[Function]}
            >
              Macro suggestions
            </ToggleInput>
            <FormText
              color="muted"
              tag="small"
            >
              Display suggested macros that can be applied to tickets with one click.
               
              <a
                href="https://docs.gorgias.com/en-US/macros-81846#:~:text=will%20be%20easier.-,Additional%20features,-Still%20not%20fast"
                rel="noopener noreferrer"
                target="_blank"
              >
                Learn more
              </a>
            </FormText>
          </Group>
        </FormGroup>
        <FormGroup
          className="inputField mb40"
          tag="div"
        >
          <div
            className="heading-subsection-semibold mb16"
          >
            Forward calls to an external number
          </div>
          <p
            className="body-regular"
          >
            When you are routed a call in Gorgias, forward the call to a mobile device or landline.
          </p>
          <ToggleInput
            className="inputField"
            isToggled={false}
            name="forward_calls"
            onClick={[Function]}
          >
            Enable call forwarding
          </ToggleInput>
        </FormGroup>
      </div>
      <ForwardRef
        isLoading={false}
        type="submit"
      >
        Save Changes
      </ForwardRef>
    </Form>
  </Container>
</div>
`;
