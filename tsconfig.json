{
    "compilerOptions": {
        "forceConsistentCasingInFileNames": true,
        "declaration": false,
        "module": "esnext",
        "moduleResolution": "node",
        "pretty": true,
        "sourceMap": false,
        "target": "es5",
        "lib": [
            "es2015",
            "dom"
        ],
        "jsx": "react",
        "allowSyntheticDefaultImports": true,
        "noUnusedLocals": false,
        "allowJs": true,
        "checkJs": false,
        "strict": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "baseUrl": "./src",
        "typeRoots": [
            "./src/types",
            "./node_modules/@types"
        ],
        "resolveJsonModule": true,
        "paths": {
            "react-chartjs-2": [
                "./types/react-chartjs-2.d.ts"
            ]
        },
        "types": [
            "stripe-v2",
            "webpack-env",
            "@types/resize-observer-browser"
        ]
    },
    "include": [
        "**/*.ts",
        "**/*.d.ts",
        "**/*.tsx"
    ]
}
