exports[`<GorgiasChatIntegrationAppearance/> render() should mark the file field for team picture as required because the avatar type is \`team-picture\` and there is no team picture set 1`] = `
<div>
  <div
    class="full-width"
  >
    <div
      class="page-header pageHeader"
    >
      <nav
        aria-label="breadcrumb"
        class=""
      >
        <ol
          class="breadcrumb"
        >
          <li
            class="breadcrumb-item"
          >
            <a
              to="/app/settings/channels/gorgias_chat"
            >
              Chat
            </a>
          </li>
          <li
            class="breadcrumb-item"
          >
            hellochatintegration
          </li>
        </ol>
      </nav>
      <div>
        <div
          data-testid="GorgiasChatIntegrationConnectedChannel"
        />
      </div>
    </div>
    <div
      data-testid="GorgiasChatIntegrationNavigation"
    />
    <div
      class="pageContainer container-fluid"
    >
      <div
        class="row"
      >
        <div
          class="col"
        >
          <form
            class=""
          >
            <div
              class="form"
            >
              <div
                class="formSection"
              >
                <div
                  class="InputField formGroup required form-group"
                  color=""
                >
                  <label
                    class="control-label"
                    for="id-input-42"
                  >
                    Chat title
                  </label>
                  <div
                    class=""
                  >
                    <input
                      class="field form-control"
                      id="id-input-42"
                      placeholder="Ex: Company Support"
                      required=""
                      type="text"
                      value="hellochatintegration"
                    />
                  </div>
                </div>
                <div
                  class="InputField formGroup form-group"
                  color=""
                >
                  <label
                    class="control-label"
                    for="id-input-42"
                  >
                    Language
                  </label>
                  <div
                    class="select dropdown-toggle"
                  >
                    <select
                      class="field form-control"
                      id="id-input-42"
                      options="[object Object],[object Object],[object Object],[object Object],[object Object],[object Object],[object Object],[object Object],[object Object],[object Object],[object Object]"
                    >
                      <option
                        value="en-US"
                      >
                        English (US)
                      </option>
                      <option
                        value="fr-FR"
                      >
                        French (France)
                      </option>
                      <option
                        value="fr-CA"
                      >
                        French (Canada)
                      </option>
                      <option
                        value="es"
                      >
                        Spanish
                      </option>
                      <option
                        value="da"
                      >
                        Danish
                      </option>
                      <option
                        value="sv"
                      >
                        Swedish
                      </option>
                      <option
                        value="it"
                      >
                        Italian
                      </option>
                      <option
                        value="nl"
                      >
                        Dutch
                      </option>
                      <option
                        value="de"
                      >
                        German
                      </option>
                      <option
                        value="no"
                      >
                        Norwegian
                      </option>
                      <option
                        value="cz"
                      >
                        Czech
                      </option>
                    </select>
                  </div>
                </div>
              </div>
              <div
                class="formSection"
              >
                <h2
                  class="title"
                >
                  Intro message
                </h2>
                <div
                  class="InputField formGroup form-group"
                  color=""
                >
                  <label
                    class="control-label"
                    for="id-input-42"
                  >
                    During business hours
                  </label>
                  <div
                    class=""
                  >
                    <input
                      class="field form-control"
                      id="id-input-42"
                      maxlength="50"
                      type="text"
                      value="How can we help?"
                    />
                  </div>
                </div>
                <div
                  class="InputField formGroup form-group"
                  color=""
                >
                  <label
                    class="control-label"
                    for="id-input-42"
                  >
                    Outside business hours
                  </label>
                  <div
                    class=""
                  >
                    <input
                      class="field form-control"
                      id="id-input-42"
                      maxlength="50"
                      type="text"
                      value="We'll be back tomorrow"
                    />
                  </div>
                </div>
                <div
                  class="alert info mb-4"
                >
                  <div
                    class="iconContainer"
                  >
                    <img
                      alt="icon"
                      src="test-file-stub"
                    />
                  </div>
                  <div
                    class="content"
                  >
                    <span
                      class="label"
                    >
                      <div>
                        Customize copy for labels, automated messages, and
                         
