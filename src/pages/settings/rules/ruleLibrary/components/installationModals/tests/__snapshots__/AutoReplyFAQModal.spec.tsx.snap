exports[`<AutoReplyFAQModal/> should render the autoclose spam body when automation add-on is subscribed 1`] = `
<div
  class="managedRule autoReplyFAQ"
>
  <div
    class="container"
  >
    <div
      class="description"
    >
      <div
        class="count"
      >
        <div
          class="targetTitle"
        >
          install to target up to
        </div>
        <div
          class="targetValue"
        >
          <span
            class="bold"
          >
            10
          </span>
           
          <span
            class="ticketsPerMonth"
          >
            tickets/month
          </span>
        </div>
      </div>
      <div
        class="descriptionBlock"
      >
        <h4>
          How it works
        </h4>
        <p>
          This rule detects shopper questions in incoming emails, replies with relevant articles from your help center, and closes the ticket. If shoppers reply, the ticket will reopen so you never miss a response.
        </p>
      </div>
      <div
        class="descriptionBlock"
      >
        <h4>
          Customize it
        </h4>
        <p>
          Personalize the message body and signature.
        </p>
      </div>
      <div
        class="descriptionBlock"
      >
        checkbox
      </div>
    </div>
    <div
      class="example"
    >
      <div
        class="exampleContainer bordered"
      >
        <div
          class="fakeMessage"
        >
          <div
            class="component clientAvatar"
            style="width: 28px; height: 28px;"
          >
            <div
              class="initials"
              style="width: 28px; height: 28px; font-size: 11.666666666666668px;"
            >
              <span
                style="line-height: 30px;"
              >
                Cn
              </span>
            </div>
          </div>
          <div
            class="ml-3"
          >
            <div
              class="name"
            >
              Client Name
            </div>
            <div>
              Hey, I'm not sure what size to order, can you help me out?
            </div>
          </div>
        </div>
        <div
          class="fakeMessage"
        >
          <div>
            <div
              class="component hasImage autoResponderAvatar"
              style="width: 28px; height: 28px;"
            >
              <div
                class="initials"
                style="width: 28px; height: 28px; font-size: 11.666666666666668px;"
              >
                <span
                  style="line-height: 30px;"
                />
              </div>
              <img
                alt="avatar"
                class="gravatar"
                src="/assets/img/icons/logo.png"
              />
            </div>
          </div>
          <div
            class="ml-3"
          >
            <div
              class="name autoResponder"
            >
              Autoresponder
            </div>
            <div>
              <p>
                Hi Client Name,
              </p>
              <p>
                Thank you for contacting us!
              </p>
              <p>
                We found some articles from our help center that might provide the information you’re looking for. Click a preview below to open and read more.
              </p>
              <div
                class="container FAQArticle"
              >
                <div
                  class="articleTitle"
                >
                  What size should I order?
                </div>
                <p
                  class="articleDescription"
                >
                  Unsure what size will work? Check out our sizing guide located above the sizes offered on each product page for exact measure...
                </p>
                <span
                  class="articleLink"
                >
                  Read More
                </span>
              </div>
              <div
                class="container FAQArticle"
              >
                <div
                  class="articleTitle"
                >
                  What shoe size should I buy?
                </div>
                <p
                  class="articleDescription"
                >
                  We recommend looking at the product details on the product page for each item for specific fit information. Each style will have...
                </p>
                <span
                  class="articleLink"
                >
                  Read More
                </span>
              </div>
              <div
                class="container FAQArticle"
              >
                <div
                  class="articleTitle"
                >
                  What size am I in your denim?
                </div>
                <p
                  class="articleDescription"
                >
                  Take a look at our denim size guide for measurement instructions and keep in mind that the fabric will relax during the first...
                </p>
                <span
                  class="articleLink"
                >
                  Read More
                </span>
              </div>
              <p>
                This is an automated message. If it does not answer your question, just reply to this message and we will get back to you as soon as possible.
              </p>
              <p>
                Jane Smith
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
`;

