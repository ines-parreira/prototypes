                      <span
                        class="wrapper group horizontal"
                      >
                        <input
                          class="input isAlignedRight"
                          max="200"
                          min="-20"
                          type="number"
                          value="0"
                        />
                        <span
                          class="suffix"
                        >
                          px
                        </span>
                        <span
                          class="controls group vertical"
                        >
                          <button
                            class="wrapper button wrapper small fill secondary small top"
                            type="button"
                          >
                            <i
                              class="material-icons icon"
                            >
                              arrow_drop_up
                            </i>
                          </button>
                          <button
                            class="wrapper button wrapper small fill secondary small bottom"
                            type="button"
                          >
                            <i
                              class="material-icons icon"
                            >
                              arrow_drop_down
                            </i>
                          </button>
                        </span>
                      </span>
                    </div>
                    <div
                      class="fieldset formGroup"
                    >
                      <label
                        class="bold"
                      >
                        Move widget up / down
                        <span
                          id="move-widget-up-down"
                        >
                          <i
                            class="material-icons-outlined tooltipIcon"
                          >
                            info
                          </i>
                        </span>
                      </label>
                      <span
                        class="wrapper group horizontal"
                      >
                        <input
                          class="input isAlignedRight"
                          max="200"
                          min="-20"
                          type="number"
                          value="0"
                        />
                        <span
                          class="suffix"
                        >
                          px
                        </span>
                        <span
                          class="controls group vertical"
                        >
                          <button
                            class="wrapper button wrapper small fill secondary small top"
                            type="button"
                          >
                            <i
                              class="material-icons icon"
                            >
                              arrow_drop_up
                            </i>
                          </button>
                          <button
                            class="wrapper button wrapper small fill secondary small bottom"
                            type="button"
                          >
                            <i
                              class="material-icons icon"
                            >
                              arrow_drop_down
                            </i>
                          </button>
                        </span>
                      </span>
                    </div>
                  </div>
                </div>
              </div>
              <div>
                <button
                  class="wrapper fill primary medium isDisabled"
                  disabled=""
                  type="submit"
                >
                  <svg
                    class="spinner gloom spinner medium"
                    preserveAspectRatio="xMidYMid meet"
                    role="status"
                    viewBox="0 0 20 20"
                    width="100%"
                  >
                    <circle
                      class="dot"
                      cx="10"
                      cy="10"
                      fill="none"
                      r="6"
                      stroke-width="2"
                    />
                    <circle
                      class="circle"
                      cx="10"
                      cy="10"
                      fill="none"
                      r="6"
                      stroke-width="2"
                    />
                    <span
                      class="sr-only"
                    >
                      Loading...
                    </span>
                  </svg>
                  Save changes
                </button>
              </div>
            </div>
          </form>
        </div>
        <div
          class="col"
        >
          <div
            class="preview"
          >
            <div
              class="container"
            >
              <span
                class="mb-3 group horizontal"
              >
                <button
                  class="wrapper fill primary medium left"
                  type="button"
                >
                  During business hours
                </button>
                <button
                  class="wrapper fill secondary medium right"
                  type="button"
                >
                  Outside business hours
                </button>
              </span>
              <div
                class="preview"
              >
                <div
                  class="dialog"
                >
                  <div
                    class="header"
                    style="background-color: rgb(13, 135, 221);"
                  >
                    <div
                      class="agents"
                    >
                      <div
                        class="agent first"
                        style="border-color: #0d87dd;"
                      >
                        <i
                          class="material-icons"
                        >
                          person
                        </i>
                      </div>
                      <div
                        class="agent middle"
                        style="border-color: #0d87dd;"
                      >
                        <i
                          class="material-icons"
                        >
                          person
                        </i>
                        <div
                          class="onlineMarker"
                        />
                      </div>
                      <div
                        class="agent last"
                        style="border-color: #0d87dd;"
                      >
                        <i
                          class="material-icons"
                        >
                          person
                        </i>
                      </div>
                    </div>
                    <div
                      class="details"
                    >
                      <div
                        class="appName"
                      >
                        hellochatintegration
                      </div>
                      <div
                        class="introductionText"
                      >
                        How can we help?
                      </div>
                    </div>
                  </div>
                  <div
                    class="content"
                  >
                    <div>
                      <div
                        class="conversationTimestamp"
                      >
                        June 24
                      </div>
                      <div
                        class="bubble primary firstMessageOfAppUser"
                        style="background-color: rgb(13, 135, 221);"
                      >
                        Hey there
                      </div>
                      <div
                        class="bubble primary lastMessage"
                        style="background-color: rgb(13, 135, 221);"
                      >
                        I'm wondering about the status of my order, I've been waiting for a while now and it has not arrived yet.
                      </div>
                      <div
                        class="messageTimestamp"
                      >
                        <span>
                          6 minutes ago
                          . 
                        </span>
                        <span
                          class="messageStatus"
                        >
                          Delivered
                        </span>
                      </div>
                    </div>
                    <div
                      class="appMakerMessageWrapper"
                    >
                      <div
                        class="component avatar"
                        style="width: 35px; height: 35px;"
                      >
                        <div
                          class="initials"
                          style="width: 35px; height: 35px; font-size: 14.583333333333334px;"
                        >
                          <span
                            style="line-height: 37px;"
                          />
                        </div>
                      </div>
                      <div>
                        <div
                          class="user"
                        />
                        <div
                          class="bubble firstMessageOfAppMaker"
                        >
                          Sure, what's your email / order number?
                        </div>
                      </div>
                    </div>
                  </div>
                  <div
                    class="poweredBy"
                  >
                    <div>
                      <span>
                        Powered by
                      </span>
                      <img
                        alt="powered-by"
                        src="test-file-stub"
                      />
                    </div>
                  </div>
                  <div
                    class="footer"
                  >
                    <div
                      class="placeholder"
                    >
                      Type a message...
                    </div>
                    <i
                      class="icon camera"
                    />
                  </div>
                </div>
                <div
                  class="button bottom-right"
                  style="background-color: rgb(13, 135, 221);"
                >
                  <div
                    class="iconWrapper"
                  >
                    <i
                      class="icon"
                    />
                    <div
                      class="shadow"
                    />
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
`;

