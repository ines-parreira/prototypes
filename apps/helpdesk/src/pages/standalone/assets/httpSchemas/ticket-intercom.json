{
    "url": "https://api.intercom.io/messages",
    "body": {
        "from": {
            "type": "lead",
            "id": "{{leadId}}"
        },
        "body": "{{ticket.messages[-1]['body_html']}}",
        "subject": "Handover: {{ticket.subject}}",
        "referer": "https://twitter.com/bob"
    },
    "headers": {
        "X-Intercom-Version": "2.0",
        "Authorization": "Bearer {{accessToken}}",
        "Intercom-Version": "2.13"
    }
}
