    "components": {
        "schemas": {
            "CampaignSchema": {
                "title": "CampaignSchema",
                "required": ["id", "rules"],
                "type": "object",
                "properties": {
                    "id": {"title": "Id", "type": "string"},
                    "rules": {
                        "title": "Rules",
                        "type": "array",
                        "items": {"$ref": "#/components/schemas/RuleSchema"}
                    }
                }
            },
            "CustomDomainOperationSchema": {
                "title": "CustomDomainOperationSchema",
                "required": ["hostname"],
                "type": "object",
                "properties": {
                    "hostname": {
                        "title": "Hostname",
                        "pattern": "^(((?!-))(xn--)?[a-z0-9][a-z0-9-_]{0,61}[a-z0-9]{0,1}\\.){1,}([a-z]{2,})$",
                        "type": "string"
                    }
                }
            },
            "CustomDomainSchema": {
                "title": "CustomDomainSchema",
                "required": ["hostname", "status"],
                "type": "object",
                "properties": {
                    "hostname": {"title": "Hostname", "type": "string"},
                    "status": {"title": "Status", "type": "string"}
                }
            },
            "EvaluatedCampaignSchema": {
                "title": "EvaluatedCampaignSchema",
                "required": ["id", "rules"],
                "type": "object",
                "properties": {
                    "id": {"title": "Id", "type": "string"},
                    "rules": {
                        "title": "Rules",
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/EvaluatedRuleSchema"
                        }
                    }
                }
            },
            "EvaluatedRuleSchema": {
                "title": "EvaluatedRuleSchema",
                "required": ["key", "operator", "value", "matches"],
                "type": "object",
                "properties": {
                    "key": {"$ref": "#/components/schemas/RuleType"},
                    "operator": {"$ref": "#/components/schemas/RuleOperator"},
                    "value": {"title": "Value", "type": "string"},
                    "matches": {"title": "Matches", "type": "boolean"}
                }
            },
            "EvaluationRequestSchema": {
                "title": "EvaluationRequestSchema",
                "required": [
                    "guest_id",
                    "account_id",
                    "revenue_addon_id",
                    "campaigns"
                ],
                "type": "object",
                "properties": {
                    "guest_id": {"title": "Guest Id", "type": "string"},
                    "account_id": {"title": "Account Id", "type": "integer"},
                    "revenue_addon_id": {
                        "title": "Revenue Addon Id",
                        "type": "string"
                    },
                    "campaigns": {
                        "title": "Campaigns",
                        "type": "array",
                        "items": {"$ref": "#/components/schemas/CampaignSchema"}
                    }
                }
            },
            "EvaluationResponseSchema": {
                "title": "EvaluationResponseSchema",
                "required": ["campaigns"],
                "type": "object",
                "properties": {
                    "campaigns": {
                        "title": "Campaigns",
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/EvaluatedCampaignSchema"
                        }
                    }
                }
            },
            "HTTPValidationError": {
                "title": "HTTPValidationError",
                "type": "object",
                "properties": {
                    "detail": {
                        "title": "Detail",
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ValidationError"
                        }
                    }
                }
            },
            "InstallationSchema": {
                "title": "InstallationSchema",
                "required": [
                    "id",
                    "account_id",
                    "shop_integration_id",
                    "status",
                    "config",
                    "created_datetime"
                ],
                "type": "object",
                "properties": {
                    "id": {"title": "Id", "type": "string"},
                    "account_id": {"title": "Account Id", "type": "integer"},
                    "shop_integration_id": {
                        "title": "Shop Integration Id",
                        "type": "integer"
                    },
                    "status": {"$ref": "#/components/schemas/StatusEnum"},
                    "config": {"title": "Config", "type": "object"},
                    "created_datetime": {
                        "title": "Created Datetime",
                        "type": "string",
                        "format": "date-time"
                    },
                    "deactivated_datetime": {
                        "title": "Deactivated Datetime",
                        "type": "string",
                        "format": "date-time"
                    },
                    "bundle_url": {"title": "Bundle Url", "type": "string"}
                }
            },
            "InstallationUpdateConfigSchema": {
                "title": "InstallationUpdateConfigSchema",
                "required": ["config"],
                "type": "object",
                "properties": {"config": {"title": "Config", "type": "object"}}
            },
            "JWTTokenSchema": {
                "title": "JWTTokenSchema",
                "required": ["token"],
                "type": "object",
                "properties": {"token": {"title": "Token", "type": "string"}}
            },
            "RuleOperator": {
                "title": "RuleOperator",
                "enum": [
                    "eq",
                    "neq",
                    "gt",
                    "gte",
                    "lt",
                    "lte",
                    "in",
                    "notIn",
                    "containsAll",
                    "containsAny",
                    "notContains"
                ],
                "type": "string",
                "description": "An enumeration."
            },
            "RuleSchema": {
                "title": "RuleSchema",
                "required": ["key", "operator", "value"],
                "type": "object",
                "properties": {
                    "key": {"$ref": "#/components/schemas/RuleType"},
                    "operator": {"$ref": "#/components/schemas/RuleOperator"},
                    "value": {"title": "Value", "type": "string"}
                }
            },
            "RuleType": {
                "title": "RuleType",
                "enum": [
                    "orders_count",
                    "amount_spent",
                    "ordered_products",
                    "customer_tags",
                    "country_code"
                ],
                "type": "string",
                "description": "An enumeration."
            },
            "StatusEnum": {
                "title": "StatusEnum",
                "enum": ["draft", "installed", "uninstalled"],
                "type": "string",
                "description": "An enumeration."
            },
            "URLClickSchema": {
                "title": "URLClickSchema",
                "required": ["created_datetime"],
                "type": "object",
                "properties": {
                    "client_ip": {"title": "Client Ip", "type": "string"},
                    "client_agent": {"title": "Client Agent", "type": "string"},
