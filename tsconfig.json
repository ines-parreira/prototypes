{
    "compilerOptions": {
        "forceConsistentCasingInFileNames": true,
        "declaration": false,
        "module": "esnext",
        "moduleResolution": "node",
        "pretty": true,
        "sourceMap": false,
        "target": "es5",
        "lib": ["es2015", "dom"],
        "jsx": "react",
        "allowSyntheticDefaultImports": true,
        "noUnusedLocals": false,
        "allowJs": true,
        "checkJs": false,
        "strict": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "baseUrl": "./g/static/private/js",
        "typeRoots": ["./g/static/private/js/types", "./node_modules/@types"],
        "paths": {
            "react-chartjs-2": ["./types/react-chartjs-2.d.ts"]
        },
        "types": ["stripe-v2", "webpack-env", "twemoji"]
    },
    "include": ["**/*.ts", "**/*.d.ts", "**/*.tsx"]
}
