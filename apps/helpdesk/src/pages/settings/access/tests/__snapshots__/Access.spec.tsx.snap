            </p>
            <div>
              <label
                aria-checked="false"
                class="ui-label-label-a11c label"
                for="twoFAEnforcementToggle"
                role="switch"
              >
                <input
                  class="input"
                  disabled=""
                  id="twoFAEnforcementToggle"
                  name="twoFAEnforcementToggle"
                  type="checkbox"
                />
                <div
                  class="slider"
                />
                Require 2FA for all users
              </label>
            </div>
          </div>
          <button
            class="btn btn-primary"
            type="submit"
          >
            Save changes
          </button>
        </form>
      </div>
    </div>
  </div>
</div>
