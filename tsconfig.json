{
    "compilerOptions": {
        "forceConsistentCasingInFileNames": true,
        "declaration": false,
        "module": "esnext",
        "moduleResolution": "node",
        "pretty": true,
        "sourceMap": false,
        "target": "es6",
        "lib": ["es2015", "dom", "dom.iterable"],
        "jsx": "react",
        "allowSyntheticDefaultImports": true,
        "noUnusedLocals": false,
        "skipLibCheck": true,
        "strict": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "baseUrl": "./src",
        "typeRoots": ["./src/types", "./node_modules/@types"],
        "resolveJsonModule": true,
        "paths": {
            "react-chartjs-2": ["./types/react-chartjs-2.d.ts"]
        },
        "types": ["facebook-js-sdk", "stripe-v2", "webpack-env"]
    },
    "include": [
        "**/*.ts",
        "**/*.d.ts",
        "**/*.tsx",
        "sa.config.ts",
        "scripts/deprecated-monitoring/deprecated.monitoring.ts",
        "rspack.app.config.ts",
        "rspack.vendors.config.ts",
        "rspack.sharedWorker.config.ts"
    ],
    "exclude": ["node_modules", "build"]
}
