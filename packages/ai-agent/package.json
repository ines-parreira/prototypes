{
    "name": "@repo/ai-agent",
    "version": "1.0.0",
    "description": "AI Agent package",
    "private": true,
    "exports": {
        ".": "./src/index.ts"
    },
    "dependencies": {
        "@gorgias/design-tokens": "0.10.5",
        "classnames": "2.2.6"
    },
    "scripts": {
        "format:check": "prettier --check .",
        "format:fix": "prettier --write .",
        "lint": "oxlint --quiet",
        "test": "vitest --configLoader=runner",
        "test:ci:cover": "vitest --configLoader=runner --coverage",
        "test:watch": "vitest --configLoader=runner --watch",
        "typecheck": "tsc -p ./tsconfig.json --noEmit true"
    },
    "peerDependencies": {
        "react": "catalog:react",
        "react-dom": "catalog:react",
        "@gorgias/axiom": "catalog:axiom",
        "@gorgias/analytics-ui-kit": "catalog:analytics-ui-kit"
    },
    "devDependencies": {
        "@repo/config": "workspace:*",
        "@testing-library/dom": "catalog:test",
        "@testing-library/jest-dom": "catalog:test",
        "@testing-library/react": "catalog:test",
        "@testing-library/user-event": "catalog:test",
        "@trivago/prettier-plugin-sort-imports": "catalog:prettier",
        "@types/react": "catalog:react",
        "@types/react-dom": "catalog:react",
        "@types/classnames": "2.2.10",
        "@vitest/coverage-v8": "catalog:test",
        "oxlint": "catalog:oxlint",
        "prettier": "catalog:prettier",
        "react": "catalog:react",
        "react-dom": "catalog:react",
        "typescript": "catalog:typescript",
        "vitest": "catalog:test"
    }
}
