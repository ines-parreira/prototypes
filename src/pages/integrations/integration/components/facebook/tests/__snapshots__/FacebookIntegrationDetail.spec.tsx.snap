            confirmationContent="Are you sure you want to delete this integration? All associated views and rules will be disabled."
            intent="destructive"
            isLoading={false}
            onConfirm={[Function]}
          >
            <ButtonIconLabel
              icon="delete"
            >
              Delete Page
            </ButtonIconLabel>
          </ConfirmButton>
        </div>
      </Col>
    </Row>
  </Container>
</div>
`;

