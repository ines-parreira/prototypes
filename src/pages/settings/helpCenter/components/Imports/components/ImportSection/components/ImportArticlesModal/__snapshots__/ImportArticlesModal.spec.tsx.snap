exports[`<ImportArticlesModal /> snapshots file selected 1`] = `
<body>
  <div />
  <div
    aria-describedby="modal-3-desc"
    aria-labelledby="modal-3-title"
    aria-modal="true"
    class="modal"
    role="dialog"
  >
    <div
      class="dialog large"
    >
      <div
        class="modalContent"
      >
        <div
          class="wrapper"
        >
          <div>
            <div
              class="title"
              id="modal-3-title"
            >
              Import articles
            </div>
            <div
              class="subtitle"
            />
          </div>
          <button
            aria-disabled="false"
            class="ui-button-wrapper-a432 material-icons icon ui-iconbutton-wrapper-7e5b ui-iconbutton-medium-7e5b ui-button-ghost-a432 ui-button-secondary-a432"
            type="button"
          >
            <span
              class="ui-button-content-a432"
            >
              <i
                aria-hidden="true"
                class="material-icons ui-buttonicon-icon-74a9 ui-buttonicon-medium-74a9 material-icons"
              >
                close
              </i>
            </span>
          </button>
        </div>
        <div
          class="wrapper"
          id="modal-3-desc"
        >
          <div>
            <input
              accept=".csv"
              data-testid="import-articles-modal-file-upload"
              style="display: none;"
              type="file"
            />
            <div>
              <div
                class="fileSelectedArea"
              >
                <div>
                  <i
                    class="material-icons mr-2"
                  >
                    insert_drive_file
                  </i>
                  Imported Articles.csv
                </div>
                <div>
                  <button
                    aria-disabled="false"
                    class="wrapper fill secondary small"
                    type="button"
                  >
                    <span
                      class="content"
                    >
                      Replace File
                    </span>
                  </button>
                </div>
              </div>
            </div>
            <p
              class="m-0 mt-2"
            >
              <a
                href="#"
              >
                Download this CSV template
              </a>
               
              to automatically match fields.
            </p>
          </div>
        </div>
        <div
          class="wrapper modalFooter"
        >
          <button
            aria-disabled="false"
            class="wrapper fill secondary medium"
            type="button"
          >
            <span
              class="content"
            >
              Cancel
            </span>
          </button>
          <button
            aria-disabled="false"
            class="wrapper fill primary medium"
            type="button"
          >
            <span
              class="content"
            >
              Import File
            </span>
          </button>
        </div>
      </div>
    </div>
  </div>
</body>
`;

