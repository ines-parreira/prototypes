      >
        Returns flow
      </h3>
      <div
        class="wrapper"
      >
        <div
          class="mb-3 d-flex justify-content-between align-items-baseline"
        >
          <h5
            class="mb-0 d-flex header"
          >
            Products with most return requests
          </h5>
          <button
            class="csvButton btn btn-secondary"
            type="button"
          >
            <i
              class="material-icons mr-1 csvButtonIcon"
            >
              file_download
            </i>
            CSV
          </button>
        </div>
        <table
          class="table table table-hover"
        >
          <thead>
            <tr>
              <th
                class="product"
              >
                <span
                  class="cell-wrapper"
                >
                  PRODUCT
                </span>
              </th>
              <th
                class="number"
              >
                <span
                  class="cell-wrapper"
                >
                  RETURN REQUESTS
                </span>
              </th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td
                class="lineCell product link-full-td"
              >
                <span
                  class="cell-wrapper cell-content"
                >
                  <div
                    class="container"
                  >
                    <div
                      class="product-image"
                      style="background-image: url(https://cdn.shopify.com/s/files/1/0518/0525/7901/products/RadHat_100x100.png?v=1608219661);"
                    />
                    <h5
                      class="product-name"
                    >
                      Hat
                    </h5>
                  </div>
                </span>
              </td>
              <td
                class="lineCell number link-full-td"
              >
                <span
                  class="cell-wrapper cell-content"
                >
                  6
                </span>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
`;
