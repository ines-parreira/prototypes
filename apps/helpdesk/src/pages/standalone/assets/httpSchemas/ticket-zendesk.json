{
    "url": "https://{{subdomain}}.zendesk.com/api/v2/tickets",
    "body": {
        "ticket": {
            "comment": {
                "body": "{{ticket.messages[-1]['body_text']}}"
            },
            "priority": "high",
            "subject": "Handover: {{ticket.subject}}"
        }
    },
    "headers": {
        "Authorization": "Basic {{basicToken}}"
    }
}
