exports[`<BillingUsage/> should display danger progress bar 1`] = `
<div
  class="usage-progress progress"
>
  <div
    aria-valuemax="100"
    aria-valuemin="0"
    aria-valuenow="63"
    class="progress-bar progressBar"
    role="progressbar"
    style="width: 63%;"
  />
  <div
    aria-valuemax="100"
    aria-valuemin="0"
    aria-valuenow="37"
    class="progress-bar remainingProgressBar isDanger"
    role="progressbar"
    style="width: 37%;"
  />
</div>
`;

exports[`<BillingUsage/> should display loader 1`] = `
