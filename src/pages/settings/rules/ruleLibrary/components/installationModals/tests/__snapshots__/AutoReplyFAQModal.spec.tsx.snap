// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`<AutoReplyFAQModal/> should render the autoclose spam body when Automate is subscribed 1`] = `
<div
  class="managedRule autoReplyFAQ"
>
  <div
    class="container"
  >
    <div
      class="description"
    >
      <div
        class="count"
      >
        <div
          class="targetTitle"
        >
          install to target up to
        </div>
        <div
          class="targetValue"
        >
          <span
            class="bold"
          >
            10
          </span>
           
          <span
            class="ticketsPerMonth"
          >
            tickets/month
          </span>
        </div>
      </div>
      <div
        class="descriptionBlock"
      >
        <h4>
          How it works
        </h4>
        <p>
          This rule detects customer questions in incoming emails, replies with relevant articles from your help center, and closes the ticket. If customers reply, the ticket will reopen so you never miss a response.
        </p>
      </div>
      <div
        class="descriptionBlock"
      >
        <h4>
          Customize it
        </h4>
        <p>
          Personalize the message body and signature.
        </p>
      </div>
      <div
        class="descriptionBlock"
      >
        checkbox
      </div>
    </div>
    <div
      class="example"
    >
      <div
        class="exampleContainer bordered"
      >
        <div
          class="fakeMessage"
        >
          <div
            class="component square clientAvatar"
            style="width: 28px; height: 28px;"
          >
            <div
              class="initials"
              style="width: 28px; height: 28px; font-size: 11.666666666666668px;"
            >
              <span
                style="line-height: 30px;"
              >
                Cn
              </span>
            </div>
          </div>
          <div
            class="ml-3"
          >
            <div
              class="name"
            >
              Client Name
            </div>
            <div>
              What is the estimated delivery time for orders?
            </div>
          </div>
        </div>
        <div
          class="fakeMessage"
        >
          <div>
            <div
              class="component hasImage square autoResponderAvatar"
              style="width: 28px; height: 28px;"
            >
              <div
                class="initials"
                style="width: 28px; height: 28px; font-size: 11.666666666666668px;"
              >
                <span
                  style="line-height: 30px;"
                />
              </div>
              <img
                alt="avatar"
                class="gravatar"
                src="/assets/img/icons/logo.png"
              />
            </div>
          </div>
          <div
            class="ml-3"
          >
            <div
              class="name autoResponder"
            >
              Autoresponder
            </div>
            <div>
              <p>
                Hi Client Name,
              </p>
              <p>
                Thank you for contacting us!
              </p>
              <p>
                We found some answers from our Help Center that might provide the information you’re looking for.
              </p>
              <div
                class="container FAQArticle"
              >
                <div
                  class="articleTitle"
                >
                  What’s your shipping policy?
                </div>
                <p
                  class="articleDescription"
                >
                  Delivery times are based on where you’re located. We ship our orders from California…
                </p>
                <span
                  class="articleLink"
                >
                  Read More
                </span>
              </div>
              <div
                class="container FAQArticle"
              >
                <div
                  class="articleTitle"
                >
                  Shipping timelines during peak season
                </div>
                <p
                  class="articleDescription"
                >
                  During Black Friday, Cyber Monday and Christmas our orders may take longer to deliver…
                </p>
                <span
                  class="articleLink"
                >
                  Read More
                </span>
              </div>
              <div
                class="container FAQArticle"
              >
                <div
                  class="articleTitle"
                >
                  Do you support express shipping?
                </div>
                <p
                  class="articleDescription"
                >
                  If you’d like your order to ship faster, we support express shipping! Simply select this as your preferred shipping during checkout…
                </p>
                <span
                  class="articleLink"
                >
                  Read More
                </span>
              </div>
              <p>
                This is an automated message. If it does not answer your question, just reply to this message and we will get back to you as soon as possible.
              </p>
              <p>
                Jane Smith
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
`;

