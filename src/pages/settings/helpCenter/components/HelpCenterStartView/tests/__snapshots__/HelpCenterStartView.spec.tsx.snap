exports[`<HelpCenterStartView /> should render the About component 1`] = `
<div>
  <div
    class="full-width"
  >
    <div
      class="page-header pageHeader"
    >
      <h1
        class="d-flex align-items-center"
      >
        Help Center
      </h1>
    </div>
    <nav
      class="navbar navbar"
    >
      <a
