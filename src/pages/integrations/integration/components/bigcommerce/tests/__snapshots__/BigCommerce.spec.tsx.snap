            </div>
            <span
              class="groupAddon right isDisabled"
            >
              .mybigcommerce.com
            </span>
          </span>
          <div
            class="mb-4"
          >
            <div>
              <label
                aria-checked="true"
                class="label label"
                for="sync_customer_notes"
                role="switch"
              >
                <input
                  checked=""
                  class="input"
                  disabled=""
                  id="sync_customer_notes"
                  name="sync_customer_notes"
                  type="checkbox"
                />
                <div
                  class="slider"
                />
                Synchronize customer notes between Gorgias and BigCommerce
              </label>
              <div
                class="caption caption"
              >
                When editing notes in both places at the same time, the first one saved will be synchronized.
                <br />
                Notes will not be synchrorized for customers who are associated with more than one BigCommerce store.
              </div>
            </div>
          </div>
          <div>
            <button
