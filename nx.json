{
    "$schema": "./node_modules/nx/schemas/nx-schema.json",
    "tasksRunnerOptions": {
        "default": {
            "runner": "nx/tasks-runners/default",
            "options": {
                "cache": true,
                "cacheDirectory": ".nx/cache"
            }
        }
    },
    "targetDefaults": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "inputs": [
                "production"
            ],
            "cache": true
        },
        "test": {
            "inputs": [
                "default"
            ],
            "cache": true
        },
        "lint": {
            "inputs": [
                "default"
            ],
            "cache": true
        },
        "typecheck": {
            "inputs": [
                "default"
            ],
            "cache": true
        },
        "format:check": {
            "inputs": [
                "default"
            ],
            "cache": true
        },
        "format:fix": {
            "inputs": [
                "default"
            ],
            "cache": false
        },
        "lint:unused": {
            "inputs": [
                "default"
            ],
            "cache": true
        }
    }
}
