          <div
            class=""
          >
            <input
              class="form-control"
              id="id-confirm_new_password"
              pattern="^(?=.*?[A-Z])(?=.*?[a-z])(?=.*?[0-9]).{14,128}$"
              placeholder="Confirm new password"
              required=""
              title="Password must be between 14 and 128 characters long and contain at least 1 lower case letter, 1 upper case letter and 1 digit."
              type="password"
              value=""
            />
          </div>
        </div>
        <button
          class="wrapper updatePasswordButton primary medium"
        >
          Update Password
        </button>
