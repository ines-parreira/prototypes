exports[`<EmailDomainVerification/> render() should render the page when there is no domain - mailgun 1`] = `
<div>
  <p>
    No domain and DKIM configuration has been created yet.
  </p>
  <div
    class="keySelectionSection form-group"
  >
    <label
      class="control-label"
    >
      DKIM key size
    </label>
    <div>
      <div
        class="dropdown"
      >
        <div
          aria-expanded="false"
          aria-haspopup="true"
          class=""
          data-toggle="dropdown"
        >
          <div
            class="select dropdown-toggle selectFullWidth"
          >
            <span
              class="label"
              style="min-width: 10px; opacity: 1;"
            >
              1024 (Default)
            </span>
            <input
              autocomplete="chrome-off"
              class="input"
              style="min-width: 10px;"
              type="text"
              value=""
            />
            <i
              class="material-icons dropdownIcon"
            >
              arrow_drop_down
            </i>
          </div>
        </div>
        <div
          aria-hidden="true"
          class="options optionsFullWidth dropdown-menu"
          role="menu"
          tabindex="-1"
        >
          
          <button
            class="option option--focused dropdown-item"
            role="menuitem"
            tabindex="0"
            type="button"
          >
            <span>
              2048
            </span>
          </button>
        </div>
      </div>
    </div>
  </div>
  <button
    class="wrapper fill primary medium"
    color="primary"
    type="submit"
  >
    Add Domain
  </button>
</div>
`;

