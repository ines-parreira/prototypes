            rel="noopener noreferrer"
            target="_blank"
          >
            sales tax
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
`;

exports[`BillingPaymentMethod Shopify should render a button to reactivate billing 1`] = `
<div
  class="wrapper"
>
  <h4
    class="header"
  >
    <i
      class="icon material-icons"
    >
      credit_card
    </i>
    Payment method
  </h4>
  <div
    class="card"
  >
    <div
      class="card-body"
    >
      <div
        class="content"
      >
        <i
          class="statusIcon material-icons text-warning md-2"
        >
          warning
        </i>
         
        Billing with Shopify is inactive. Please reactivate to avoid account cancellation.
         
        <a
          class="float-right"
          href="/integrations/shopify/billing/activate/"
        >
          <button
            class="wrapper fill primary medium"
            type="button"
          >
            Reactivate billing with Shopify
          </button>
        </a>
      </div>
    </div>
  </div>
</div>
`;

