exports[`KeyMetricStat should render a key metrics chart with distribution and donut components 1`] = `
<div
  className="metrics"
>
  <div
    className="metric"
    key="total_sent-0"
  >
    <div
      className="label"
    >
      Survey sent
      <span>
        <StatsHelpIcon
          className="info-icon"
          id="title-total_sent-0"
        />
        <Tooltip
          placement="top"
          target="title-total_sent-0"
        >
          Total number of customer satisfaction surveys sent
        </Tooltip>
      </span>
    </div>
    <div
      className="mt-3 statsDisplay"
    >
      -
    </div>
  </div>
  <div
    className="metric"
    key="response_rate-1"
  >
    <div
      className="label"
    >
      Response rate
      <span>
        <StatsHelpIcon
          className="info-icon"
          id="title-response_rate-1"
        />
        <Tooltip
          placement="top"
          target="title-response_rate-1"
        >
          Total number of responses for surveys sent
        </Tooltip>
      </span>
    </div>
    <div
      className="mt-3 statsDisplay"
    >
      -
    </div>
  </div>
  <div
    className="metric"
    key="average_rating-2"
  >
    <div
      className="label"
    >
      Average rating
      <span>
        <StatsHelpIcon
          className="info-icon"
          id="title-average_rating-2"
        />
        <Tooltip
          placement="top"
          target="title-average_rating-2"
        >
          Average score given by the customers
        </Tooltip>
      </span>
    </div>
    <div
      className="mt-3 statsDisplay"
    >
      <DonutKeyMetricStat
        differenceComponent={
          <span
            className="diff"
            id="value-average_rating-2"
          >
            <StatPercentageDiff
              label={10}
              percentage={10}
            />
            <Tooltip
              placement="top"
              target="value-average_rating-2"
            >
              Compared to : Sep 05, 2017 - Sep 06, 2017
            </Tooltip>
          </span>
        }
        fill="warning"
        formattedValue={20}
        height={320}
        innerRadius={0.83}
        label="10%"
        maxValue={5}
        outerRadius={0.95}
        startAngle={0}
        total={null}
        value={20}
        width={320}
      />
    </div>
  </div>
  <div
    className="metric"
    key="response_distribution-3"
  >
    <div
      className="label"
    >
      Response Distribution
      <span>
        <StatsHelpIcon
          className="info-icon"
          id="title-response_distribution-3"
        />
        <Tooltip
          placement="top"
          target="title-response_distribution-3"
        >
          Percentage of responses, grouped by the given score
        </Tooltip>
      </span>
    </div>
    <div
      className="mt-3 statsDisplay"
    >
      <DistributionKeyMetricStat
        config={
          Immutable.Map {
            "name": "response_distribution",
            "label": "Response Distribution",
            "tooltip": "Percentage of responses, grouped by the given score",
            "type": "distribution",
            "variant": "star",
            "minValue": 1,
            "maxValue": 5,
          }
        }
        formattedValue={
          Immutable.Map {
            "1": 12,
            "2": 38,
            "3": 14.5,
            "4": 14.5,
            "5": 21,
          }
        }
      />
    </div>
  </div>
</div>
`;
