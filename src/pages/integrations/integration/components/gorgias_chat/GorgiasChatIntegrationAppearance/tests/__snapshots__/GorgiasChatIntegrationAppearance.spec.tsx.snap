exports[`<GorgiasChatIntegrationAppearance/> render() should submit and call the createGorgiasChatIntegration with 2nd store name option selected - myStore2  1`] = `
<div>
  <div
    class="full-width"
  >
    <div
      class="page-header pageHeader"
    >
      <nav
        aria-label="breadcrumb"
        class=""
      >
