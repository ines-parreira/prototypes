// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`<AutoReplyWismoModal/> should render the autoclose spam body when automation add-on is not subscribed 1`] = `
<div
  class="managedRule autoReplyWismo"
>
  <div
    class="container"
  >
    <div
      class="description"
    >
      <div
        class="count"
      >
        <div
          class="targetTitle"
        >
          install to target up to
        </div>
        <div
          class="targetValue"
        >
          <span
            class="bold"
          >
            10
          </span>
           
          <span
            class="ticketsPerMonth"
          >
            tickets/month
          </span>
        </div>
      </div>
      <div
        class="descriptionBlock"
      >
        <h4>
          How it works
        </h4>
        <p>
          This rule detects emails related to order status or tracking, replies with tracking links for the shopper’s last 3 orders, and auto-closes the ticket. If shoppers reply, the ticket will reopen so you never miss a response.
        </p>
      </div>
      <div
        class="descriptionBlock"
      >
        <p
          class="addendum"
        >
          This rule requires an active Shopify integration.
        </p>
      </div>
      <div
        class="descriptionBlock"
      >
        <h4>
          Customize it
        </h4>
        <p>
          Personalize the message and exclude email addresses from this rule.
        </p>
      </div>
      <div
        class="descriptionBlock"
      />
    </div>
    <div
      class="example"
    >
      <div
        class="exampleContainer bordered"
      >
        <div
          class="fakeMessage"
        >
          <div
            class="component clientAvatar"
            style="width: 28px; height: 28px;"
          >
            <div
              class="initials"
              style="width: 28px; height: 28px; font-size: 11.666666666666668px;"
            >
              <span
                style="line-height: 30px;"
              >
                Cn
              </span>
            </div>
          </div>
          <div
            class="ml-3"
          >
            <div
              class="name"
            >
              Client Name
            </div>
            <div>
              Hey, do you have a tracking number so I can double check?
            </div>
          </div>
        </div>
        <div
          class="fakeMessage"
        >
          <div>
            <div
              class="component hasImage autoResponderAvatar"
              style="width: 28px; height: 28px;"
            >
              <div
                class="initials"
                style="width: 28px; height: 28px; font-size: 11.666666666666668px;"
              >
                <span
                  style="line-height: 30px;"
                />
              </div>
              <img
                alt="avatar"
                class="gravatar"
                src="/assets/img/icons/logo.png"
              />
            </div>
          </div>
          <div
            class="ml-3"
          >
            <div
              class="name autoResponder"
            >
              Autoresponder
            </div>
            <div>
              <p>
                Hi Client Name,
              </p>
              <p>
                It looks like you’re reaching out about your order status. Is this tracking information helpful?
              </p>
              <div
                class="container orderTracking"
              >
                <div
                  class="orderTitleContainer"
                >
                  <div
                    class="orderTitle"
                  >
                    Order number
                  </div>
                  <div
                    class="orderPrice"
                  >
                    Price
                  </div>
                </div>
                <div
                  class="fulfillmentContainer"
                >
                  <div
                    class="product"
                  >
                    <div
                      class="productTitle"
                    >
                      Product 1
                    </div>
                    <div
                      class="productPrice"
                    >
                      Price x1
                    </div>
                  </div>
                  <div
                    class="product"
                  >
                    <div
                      class="productTitle"
                    >
                      Product 2
                    </div>
                    <div
                      class="productPrice"
                    >
                      Price x2
                    </div>
                  </div>
                  <div
                    class="trackingLink"
                  >
                    loremipsum.com/tracking-1234
                  </div>
                </div>
                <div
                  class="fulfillmentContainer"
                >
                  <div
                    class="product"
                  >
                    <div
                      class="productTitle"
                    >
                      Product 3
                    </div>
                    <div
                      class="productPrice"
                    >
                      Price x1
                    </div>
                  </div>
                  <div
                    class="trackingLink"
                  >
                    loremipsum.com/tracking-4321
                  </div>
                </div>
              </div>
              <p>
                If you need more help you can reply to this email and we will get back to you as soon as possible.
              </p>
              <p>
                Agent Name
              </p>
            </div>
          </div>
        </div>
      </div>
      <p
        class="legend"
      >
        See auto-response example above
      </p>
    </div>
  </div>
</div>
`;

