          <a
            activeclassname="active"
            class="link isNested"
            to="/app/automation/self-service/shopify/My shop/preferences/order-management"
          >
            Order management
          </a>
        </div>
      </div>
    </div>
    <div
      data-candu-id="navbar-menu-spacer"
    />
    <button
      class="dropdown-toggle dropdown-toggle-dropup"
    >
      <div>
        Alex Plugaru
      </div>
      <div
        class="component hasImage"
        style="width: 36px; height: 36px;"
      >
        <div
          class="initials"
          style="width: 36px; height: 36px; font-size: 15px;"
        >
          <span
            style="line-height: 38px;"
          >
            AP
          </span>
        </div>
        <img
          alt="avatar"
          class="gravatar"
          src="https://config.gorgias.io/production/picture"
        />
        <div
          class="badge"
          style="background-color: rgb(36, 214, 157);"
        />
      </div>
    </button>
  </div>
</div>
`;

