            <Button
              className=""
              color="warning"
              disabled={false}
              onClick={[Function]}
              outline={true}
              tag="button"
              type="button"
            >
              Deactivate integration
            </Button>
            <ConfirmButton
              className="float-right"
              color="secondary"
              confirm={[Function]}
              confirmColor="success"
              content="Are you sure you want to delete this integration?"
              disabled={false}
              loading={false}
              placement="bottom"
              skip={false}
              title="Are you sure?"
              type="button"
            >
              <i
