            >
              <div
                class="fileDropArea"
                data-testid="import-articles-modal-file-drop-area"
              >
                <div>
                  <i
                    class="material-icons modalCloudIcon"
                  >
                    cloud_upload
                  </i>
                  <b
                    class="dropAreaText"
                  >
                    Drop your CSV here, or
                     
                    <a
                      href=""
                    >
                      browse
                    </a>
                  </b>
                </div>
              </div>
              <div
                class="fileDropArea disabled"
              >
                <span
                  class="supportedProvidersText"
                >
                  Currently supported providers:
                </span>
                <div
                  class="providersLogosContainer"
                >
                  <svg
                    class="ui-loadingspinner-spinner-4660 ui-loadingspinner-gloom-4660 ui-loadingspinner-medium-4660"
                    preserveAspectRatio="xMidYMid meet"
                    role="status"
                    viewBox="0 0 20 20"
                  >
                    <circle
                      class="ui-loadingspinner-dot-4660"
                      cx="10"
                      cy="10"
                      fill="none"
                      r="6"
                      stroke-width="2"
                    />
                    <circle
                      class="ui-loadingspinner-circle-4660"
                      cx="10"
                      cy="10"
                      fill="none"
                      r="6"
                      stroke-width="2"
                    />
                    <span
                      class="sr-only"
                    >
                      Loading...
                    </span>
                  </svg>
                </div>
                <b
                  class="dropAreaText"
                >
                  Import from another provider
