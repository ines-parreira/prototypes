                  Type a message...
                </div>
                <i
                  class="icon camera"
                />
              </div>
            </div>
            <div
              class="button bottom-right"
              style="background-color: rgb(13, 135, 221);"
            >
              <div
                class="iconWrapper"
              >
                <i
                  class="icon"
                />
                <div
                  class="shadow"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
`;

