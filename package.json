{
    "name": "gorgias",
    "version": "1.0.0",
    "description": "Gorgias",
    "main": "src/App.js",
    "private": true,
    "repository": "https://github.com/gorgias/gorgias",
    "scripts": {
        "types": "tsc -p ./tsconfig.json --allowJs false --noEmit true",
        "eslint": "eslint --quiet src/\"$1\"",
        "stylelint:less": "stylelint \"src/**/*.less\"",
        "lint": "run-p stylelint:less eslint",
        "quality": "run-s lint types",
        "jest": "TZ=UTC LC_ALL=\"en_US.UTF-8\" NODE_ICU_DATA=node_modules/full-icu jest",
        "storybook": "start-storybook -s ./src",
        "test": "run-s quality jest",
        "test:debug": "node --inspect-brk ./node_modules/.bin/jest -i",
        "test:cover": "run-s quality \"jest --coverage\"",
        "test:update": "yarn jest -u",
        "test:watch": "yarn jest --watch",
        "test:ci": "run-s quality test:ci:cover",
        "test:ci:cover": "yarn run jest --coverage --ci --runInBand",
        "chromatic": "chromatic",
        "build-storybook": "build-storybook",
        "dll": "node --max_old_space_size=2048 ./node_modules/.bin/webpack --env.dll",
        "patch-package": "patch-package",
        "get-color-tokens": "curl https://gorgias.zeroheight.com/api/token_file/369202d08337/share > src/assets/tokens/colors.json",
        "get-typography-tokens": "curl https://gorgias.zeroheight.com/api/token_file/661b2877ff41/share > src/assets/tokens/typography.json",
        "get-layout-tokens": "curl https://gorgias.zeroheight.com/api/token_file/86729f185c53/share > src/assets/tokens/layout.json",
        "generate-design-tokens": "run-p get-color-tokens get-typography-tokens get-layout-tokens && node scripts/generateDesignTokens && prettier --write ./src/assets/tokens/**/* ./src/assets/css/**/*",
        "postinstall": "run-s patch-package dll",
        "build": "NODE_ENV=production run-s dll && NODE_ENV=production webpack && NODE_ENV=production webpack --config webpack.sharedWorker.config.js",
        "serve": "webpack --config webpack.sharedWorker.config.js; webpack-dev-server --inline --hot --progress --debug",
        "serve:sharedWorker": "webpack -w --config webpack.sharedWorker.config.js",
        "uglify-file": "terser --compress --mangle --",
        "helpcenter:fetch-openapi": "curl http://localhost:4001/api/help-center/api-json > ./src/rest_api/help_center_api/help-center.openapi.json && prettier --write ./src/rest_api/help_center_api/help-center.openapi.json",
        "helpcenter:generate-types": "typegen ./src/rest_api/help_center_api/help-center.openapi.json > ./src/rest_api/help_center_api/client.generated.d.ts",
        "helpcenter:update-client": "yarn run helpcenter:fetch-openapi && yarn run helpcenter:generate-types",
        "gorgiaschat:generate-openapi:public": "p2o ./src/rest_api/gorgias_chat_api/gorgias-chat-api.postman_collection.json -f ./src/rest_api/gorgias_chat_api/gorgias-chat-api.openapi.json -o ./src/rest_api/gorgias_chat_api/gorgias-chat-api.p2o_options.json",
        "gorgiaschat:generate-types:public": "typegen ./src/rest_api/gorgias_chat_api/gorgias-chat-api.openapi.json > ./src/rest_api/gorgias_chat_api/client.generated.d.ts",
        "gorgiaschat:generate-openapi:protected": "p2o ./src/rest_api/gorgias_chat_protected_api/gorgias-chat-protected-api.postman_collection.json -f ./src/rest_api/gorgias_chat_protected_api/gorgias-chat-protected-api.openapi.json -o ./src/rest_api/gorgias_chat_protected_api/gorgias-chat-protected-api.p2o_options.json",
        "gorgiaschat:generate-types:protected": "typegen ./src/rest_api/gorgias_chat_protected_api/gorgias-chat-protected-api.openapi.json > ./src/rest_api/gorgias_chat_protected_api/client.generated.d.ts",
        "gorgiaschat:update-client": "yarn run gorgiaschat:generate-openapi:public && yarn run gorgiaschat:generate-types:public && yarn run gorgiaschat:generate-openapi:protected && yarn run gorgiaschat:generate-types:protected",
        "click-tracking:fetch-openapi": "curl http://localhost:8095/openapi.json > ./src/rest_api/click_tracking_api/click-tracking.openapi.json && prettier --write ./src/rest_api/click_tracking_api/click-tracking.openapi.json",
        "click-tracking:generate-types": "typegen ./src/rest_api/click_tracking_api/click-tracking.openapi.json > ./src/rest_api/click_tracking_api/client.generated.d.ts",
        "click-tracking:update-client": "yarn run click-tracking:fetch-openapi && yarn run click-tracking:generate-types"
    },
    "author": "Alex Plugaru <alex@gorgias.com>",
