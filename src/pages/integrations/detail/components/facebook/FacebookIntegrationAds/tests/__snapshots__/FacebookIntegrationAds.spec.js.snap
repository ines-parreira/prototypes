                                  className="progress-bar color-NaN progress-bar-striped"
                                  role="progressbar"
                                  style={
                                    Object {
                                      "width": "0%",
                                    }
                                  }
                                />
                              </Progress>
                            </div>
                          </Progress>
                          <div
                            className="legendContainer"
                          >
                            <div
                              className="legend"
                              key="legend-1"
                            >
                              <div
                                className="color-NaN progress-bar-striped legendColor"
                              />
                              integration 1
                               
                              (
                              0
                               active ads)
                            </div>
                          </div>
                        </div>
                      </CardBody>
                    </div>
                  </Card>
                </AdsOverviewCard>
                <AdAccountsCard
                  accounts={Immutable.Seq []}
                  loadingAdAccounts={Immutable.List []}
                  updateAdAccount={[Function]}
                />
                <AdsCard
                  accountTotalAds={0}
                  ads={Immutable.Seq []}
                  loadingAds={Immutable.List []}
                  maxAccountAds={100}
                  timezone="America/Los_Angeles"
                  updateAd={[Function]}
                />
              </div>
            </div>
          </Col>
        </div>
      </Container>
    </div>
  </FacebookIntegrationAds>
</Connect(FacebookIntegrationAds)>
`;
