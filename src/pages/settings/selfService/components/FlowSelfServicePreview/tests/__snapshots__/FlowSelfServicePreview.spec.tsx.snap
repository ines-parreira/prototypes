exports[`<ChatIntegrationPreview/> render() displays thread page with answer 1`] = `
<div>
  <div
    class="container"
  >
    <div
      class="mb-4 btn-group"
      role="group"
    >
      <button
        class="btn btn-secondary"
        type="button"
      >
        Landing Page
      </button>
      <button
        class="btn btn-info"
        type="button"
      >
        Message Thread
      </button>
    </div>
    <div
      class="preview"
    >
      <div
        class="dialog"
      >
        <div
          class="header"
          style="background-color: rgb(13, 135, 221);"
        >
          <div
            class="agents"
          >
            <div
              class="agent first"
              style="border-color: #0d87dd;"
            >
              <i
                class="material-icons"
              >
                person
              </i>
            </div>
            <div
              class="agent middle"
              style="border-color: #0d87dd;"
            >
              <i
                class="material-icons"
              >
                person
              </i>
              <div
                class="onlineMarker"
              />
            </div>
            <div
              class="agent last"
              style="border-color: #0d87dd;"
            >
              <i
                class="material-icons"
              >
                person
              </i>
            </div>
          </div>
          <div
            class="details"
            style="color: rgb(255, 255, 255);"
          >
            <div
              class="appName"
            >
              Chat
            </div>
            <div
              class="introductionText"
            >
              How can we help?
            </div>
          </div>
        </div>
        <div
          class="content"
        >
          <div>
            <div
              class="conversationTimestamp"
            >
              January 24
            </div>
            <div
              class="bubble primary firstMessageOfAppUser lastMessage"
              style="background-color: rgb(13, 135, 221); color: rgb(255, 255, 255);"
            >
              question
            </div>
          </div>
          <div
            class="appMakerMessageWrapper"
          >
            <div
              class="component hasImage avatar"
              style="width: 35px; height: 35px;"
            >
              <div
                class="initials"
                style="width: 35px; height: 35px; font-size: 14.583333333333334px;"
              >
                <span
                  style="line-height: 37px;"
                >
                  AP
                </span>
              </div>
              <img
                alt="avatar"
                class="gravatar"
                src="https://config.gorgias.io/production/picture"
              />
            </div>
            <div>
              <div
                class="user"
              >
                Alex Plugaru
              </div>
              <div
                class="bubble firstMessageOfAppMaker"
              >
                <div>
                  response
                </div>
              </div>
              <div
                class="bubble firstMessageOfAppMaker"
              >
                Was this helpful?
              </div>
            </div>
          </div>
        </div>
        <div
          class="content quick-replies-content"
        >
          <div
            class="quick-replies-wrapper"
          >
            <button
              class="btn btn-reply-action reply"
              style="color: rgb(13, 135, 221); border-color: #0d87dd;"
            >
              Yes, thank you
            </button>
            <button
              class="btn btn-reply-action reply"
              style="color: rgb(13, 135, 221); border-color: #0d87dd;"
            >
              No, I need more help
            </button>
          </div>
        </div>
        <div
          class="poweredBy"
        >
          <div>
            <span>
              Powered by
            </span>
            <img
              alt="powered-by"
              src="test-file-stub"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
`;

