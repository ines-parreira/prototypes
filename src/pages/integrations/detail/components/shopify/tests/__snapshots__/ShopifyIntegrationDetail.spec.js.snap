          >
            Shopify
          </Link>
        </BreadcrumbItem>
        <BreadcrumbItem
          active={true}
          tag="li"
        >
          foo
        </BreadcrumbItem>
      </Breadcrumb>
    }
  />
  <Container
    className="page-container"
    fluid={true}
    tag="div"
  >
    <Row
      tag="div"
    >
      <Col
        md="8"
        tag="div"
        widths={
          Array [
            "xs",
            "sm",
            "md",
            "lg",
            "xl",
          ]
        }
      >
        <p>
          All your Shopify customers have been imported. You can now see their info in the sidebar. 
          <Link
            onlyActiveOnIndex={false}
            style={Object {}}
            to="/app/customers"
          >
            Review your customers.
          </Link>
        </p>
        <Form
          onSubmit={[Function]}
          tag="form"
        >
          <div
            className="mb-4"
          >
            <InputField
              disabled={true}
              error={null}
              label="Store name"
              name="name"
              onChange={[Function]}
              placeholder="ex: \\"acme\\" for acme.myshopify.com"
              required={true}
              rightAddon=".myshopify.com"
              type="text"
              value="foo"
            />
          </div>
          <div
            className="mb-2"
            key="input"
          >
            <Label
              className="control-label"
              tag="label"
              widths={
                Array [
                  "xs",
                  "sm",
                  "md",
                  "lg",
                  "xl",
                ]
              }
            >
              Synchronization settings
            </Label>
            <BooleanField
              help=""
              label="Synchronize customer notes"
              name="sync_customer_notes"
              onChange={[Function]}
              type="checkbox"
              value={true}
            />
          </div>
          <div
            className="text-faded mb-4"
            key="help"
          >
            If this option is enabled, updating a customer's note in Shopify will also update it in Gorgias, and updating it in Gorgias will also update it in Shopify:
            <ul>
              <li>
                if two people are editing a single customer's note at the same time in Shopify and Gorgias, 
                <b>
                  the first one to save the data will overwrite the other one's modifications
                </b>
              </li>
              <li>
                if a single Gorgias customer is associated with two or more Shopify customers on two or more Shopify stores, 
                <b>
                  its note will not be synchronized from Shopify
                </b>
                , and 
                <b>
                  updating the Gorgias customer note won't update any Shopify customer note
                </b>
              </li>
            </ul>
          </div>
          <div>
            <Button
              className="mr-2"
              color="success"
              disabled={false}
              tag="button"
              type="submit"
            >
