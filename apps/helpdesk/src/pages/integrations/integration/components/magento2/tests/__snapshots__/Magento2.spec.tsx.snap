              class="ui-label-abbr-a11c"
              title="required"
            >
              *
            </abbr>
          </label>
          <span
            class="mb-4 wrapper group horizontal"
          >
            <span
              class="groupAddon left"
            >
              https:///
            </span>
            <div
              class="wrapper right isNested"
            >
              <input
                class="input"
                data-resizable="false"
                id="store-field"
                name="admin-url-suffix"
                placeholder="ex: admin_45f1c"
                required=""
                type="text"
                value=""
              />
            </div>
          </span>
          <div
            data-name="box"
            style="justify-content: space-between; display: flex;"
          >
            <div
              data-name="box"
              style="display: flex; gap: 12px;"
            >
              <button
                aria-disabled="true"
                class="ui-button-wrapper-a432 ui-button-md-a432 ui-button-primary-a432 ui-button-isdisabled-a432"
                data-disabled="true"
                data-name="button"
                data-rac=""
                data-react-aria-pressable="true"
                disabled=""
