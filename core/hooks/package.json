{
    "name": "@repo/hooks",
    "version": "1.0.0",
    "description": "Non domain specific utility hooks for the monorepo",
    "private": true,
    "exports": {
        ".": "./src/index.ts"
    },
    "scripts": {
        "format:check": "prettier --check .",
        "format:fix": "prettier --write .",
        "lint": "oxlint --quiet",
        "test": "jest",
        "test:ci:cover": "TZ=UTC LC_ALL=\"en_US.UTF-8\" NODE_DISABLE_COMPILE_CACHE=1 NODE_OPTIONS=\"--max-old-space-size=4096\" jest --coverage --ci --maxWorkers=2 --testTimeout=10000 --silent --forceExit",
        "test:update": "jest -u",
        "test:watch": "jest --watch",
        "typecheck": "tsc -p ./tsconfig.json --noEmit true"
    },
    "peerDependencies": {
        "copy-to-clipboard": "catalog:copy-to-clipboard",
        "lodash": "catalog:lodash",
        "qs": "catalog:qs",
        "react": "catalog:react",
        "react-dom": "catalog:react"
    },
    "devDependencies": {
        "@jest/expect": "catalog:test",
        "@repo/testing": "workspace:*",
        "@repo/config": "workspace:*",
        "@repo/types": "workspace:*",
        "@swc/core": "catalog:test",
        "@swc/jest": "catalog:test",
        "@testing-library/dom": "catalog:test",
        "@testing-library/jest-dom": "catalog:test",
        "@testing-library/react": "catalog:test",
        "@testing-library/user-event": "catalog:test",
        "@trivago/prettier-plugin-sort-imports": "catalog:prettier",
        "@types/jest": "catalog:test",
        "@types/jsdom": "catalog:test",
        "@types/lodash": "catalog:lodash",
        "@types/qs": "catalog:qs",
        "@types/react": "catalog:react",
        "@types/react-dom": "catalog:react",
        "@types/testing-library__jest-dom": "catalog:test",
        "jest": "catalog:test",
        "jest-environment-jsdom": "catalog:test",
        "jest-fixed-jsdom": "catalog:test",
        "jest-immutable-matchers": "catalog:test",
        "jest-junit": "catalog:test",
        "jest-launchdarkly-mock": "catalog:test",
        "jest-matcher-utils": "catalog:test",
        "jest-mock": "catalog:test",
        "lodash": "catalog:lodash",
        "oxlint": "catalog:oxlint",
        "prettier": "catalog:prettier",
        "react": "catalog:react",
        "react-dom": "catalog:react",
        "swc_mut_cjs_exports": "catalog:test",
        "typescript": "catalog:typescript"
    }
