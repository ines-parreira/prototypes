                    },
                    {
                      "label": "In a few minutes",
                      "value": "reply-in-minutes",
                    },
                    {
                      "label": "In a few hours",
                      "value": "reply-in-hours",
                    },
                  ]
                }
                selectedValue="reply-dynamic"
              />
            </div>
          </div>
          <div
            className="formSection"
          >
            <h4
              className="title mb-1"
            >
              Forward chat replies to customer emails
            </h4>
            <p
              className="mb-3"
            >
              When customers don't see your live chat response after an hour, Gorgias will automatically send your message to the customer's email address (if available). Customers also receive satisfaction surveys for chat tickets via email.
            </p>
            <Label
              className="control-label"
              for="linkedEmailIntegration"
              tag="label"
              widths={
                [
                  "xs",
                  "sm",
                  "md",
                  "lg",
                  "xl",
                ]
              }
            >
              Select which email address sends these messages
            </Label>
            <SelectField
              allowCustomValue={false}
              fixedWidth={false}
              fullWidth={true}
              id={null}
              isSearchable={true}
              onChange={[Function]}
              onSearchChange={[Function]}
              options={[]}
              placeholder="Select an email integration"
              required={false}
              singular="option"
              style={{}}
              value={null}
            />
          </div>
        </div>
        <ForwardRef(Button)
          isDisabled={true}
          isLoading={true}
          type="submit"
        >
          Save Changes
        </ForwardRef(Button)>
      </Form>
    </GorgiasChatIntegrationPreviewContainer>
  </div>
</Fragment>
`;

