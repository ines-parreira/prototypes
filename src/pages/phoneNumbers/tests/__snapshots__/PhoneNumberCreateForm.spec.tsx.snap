exports[`<PhoneNumberCreateForm/> render() should render 1`] = `
<div
  class="row"
>
  <div
    class="col-lg-6"
  >
    <p>
      Create a new phone number in Gorgias or forward calls from an existing number to a Gorgias internal number. To learn more about forwarding existing calls, check out
       
      <a
        href="https://docs.gorgias.com/voice-and-phone/gorgias-phone-integration"
        rel="noopener noreferrer"
        target="_blank"
      >
        our phone docs
      </a>
      .
    </p>
  </div>
</div>
`;

