                                  </label>
                                </Label>
                                <div
                                  className=""
                                >
                                  <Input
                                    className="field"
                                    id="id-timezone"
                                    onChange={[Function]}
                                    type="select"
                                    value="US/Pacific"
                                  >
                                    <select
                                      className="field form-control"
                                      id="id-timezone"
                                      onChange={[Function]}
                                      value="US/Pacific"
                                    >
                                      <option
                                        key="UTC"
                                        value="UTC"
                                      >
                                        UTC
                                      </option>
                                      <option
                                        key="US/Pacific"
                                        value="US/Pacific"
                                      >
                                        US/Pacific
                                      </option>
                                      <option
                                        key="Australia/AUR"
                                        value="Australia/AUR"
                                      >
                                        Australia/AUR
                                      </option>
                                    </select>
                                  </Input>
                                </div>
                              </div>
                            </FormGroup>
                          </InputField>
