exports[`<TwoFactorAuthenticationModal /> render() should render modal with QR Code step 1`] = `
<body
  class="modal-open"
>
  <div />
  <div
    style="position: relative; z-index: 1050; display: block;"
    tabindex="-1"
  >
    <div
      class=""
    >
      <div
        class="modal show"
        role="dialog"
        style="display: block;"
        tabindex="-1"
      >
        <div
          class="modal-dialog"
          role="document"
          style="max-width: 600px;"
        >
          <div
            class="modal-content"
          >
            <div
              class="modal-header"
            >
              <h5
                class="modal-title"
              >
                Setup 2FA
              </h5>
              <button
                aria-label="Close"
                class="close"
                type="button"
              >
                <span
                  aria-hidden="true"
                >
                  ×
                </span>
              </button>
            </div>
            <div
              class="modal-body modal-body"
            >
              <div
                class="banner bannerInfo"
              >
                <img
                  alt="icon"
                  class="icon"
                  src="test-file-stub"
                />
                <div
                  class="infoBannerText"
                >
                  <span>
                    For security reasons, your admin requires you to setup two-factor authentication in order to access your account.
                  </span>
                </div>
              </div>
              
              <div
                class="headingBold"
              >
                Step 1: Download an authenticator app
              </div>
              <div
                class="textSection"
              >
                Download and install any authenticator app (
                <a
                  href="https://support.google.com/accounts/answer/1066447"
                  rel="noreferrer"
                  target="_blank"
                >
                  Eg. Google Authenticator
                </a>
                ) on your phone.
              </div>
              <div
                class="headingBold"
              >
                Step 2: Scan the QR code
              </div>
              <div
                class="textSection"
              >
                Open the authenticator app and scan the image below using your phone’s camera.
              </div>
              <div
                class="qrCodeContainer"
              >
                <img
                  alt="The QR Code to scan"
                  id="qrCodeImage"
                  src="data:image/png;base64,"
                />
              </div>
              <div
                class="cantScanQrCodeContainer"
              >
                <span
                  class="link"
                >
                  Can't scan the QR code?
                </span>
              </div>
            </div>
            <div
              class="modal-footer modal-footer"
            >
              <button
                class="btn btn-secondary"
                type="button"
              >
                Cancel
              </button>
              <button
                class="btn btn-primary"
                type="button"
              >
                Continue
              </button>
            </div>
          </div>
        </div>
      </div>
      <div
        class="modal-backdrop show"
      />
    </div>
  </div>
</body>
`;

