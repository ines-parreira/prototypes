          active={true}
          tag="li"
        >
          Facebook Pages setup
        </BreadcrumbItem>
      </Breadcrumb>
    }
  />
  <Container
    className="page-container"
    fluid={true}
    tag="div"
  >
    <h1>
      Facebook Pages setup
    </h1>
    <p>
      One last step: choose the pages you want to manage with Gorgias.
      <br />
      If you just wanted to re-activate your Facebook integration or update your permissions: it's done, you can leave this page.
    </p>
    <Form
      onSubmit={[Function]}
      tag="form"
    >
      <div
        className="mb-4"
      >
        <p
          className="font-weight-medium"
        >
          We found 
          1
           pages associated with your account. Please activate the pages you want to use with Gorgias:
        </p>
        <div
          className="mb-2"
        >
          <div
            className="page"
            key="1"
          >
            <div
              className="d-flex flex-wrap flex-md-nowrap"
            >
              <div
                className="mr-auto"
              >
                <div>
                  <img
                    alt="facebook logo"
                    className="image rounded mr-3 mb-2 mb-md-0 icon"
                    src="https://gorgias.io/page-image-link.png"
                  />
                  <div
                    className="details mr-3 text-faded"
                  >
                    <h3
                      className="name mr-3"
                    >
                      My page
                    </h3>
                    <span
                      className="mr-3"
                    >
                      [
                      Moderator
                      ]
                    </span>
                    <span>
                      A page about stuff
                    </span>
                  </div>
                </div>
              </div>
              <ToggleButton
                onChange={[Function]}
                value={false}
              />
            </div>
            <div
              className="settings"
            >
              <p
                className="font-weight-medium"
              >
                Choose the Facebook channels you want to use to communicate with your customers:
              </p>
              <div
                className="d-md-flex"
              >
                <FormGroup
                  className="mr-5"
                  tag="div"
                >
                  <BooleanField
                    disabled={false}
                    label="Enable Messenger"
                    name="1.messenger_enabled"
                    onChange={[Function]}
                    type="checkbox"
                    value={false}
                  />
                  <BooleanField
                    disabled={false}
                    label="Enable Facebook posts, comments and ads comments"
                    name="1.posts_enabled"
                    onChange={[Function]}
                    type="checkbox"
                    value={false}
                  />
                  <BooleanField
                    disabled={false}
                    label="Enable Facebook recommendations"
                    name="1.recommendations_enabled"
                    onChange={[Function]}
                    type="checkbox"
                    value={false}
                  />
                  <BooleanField
                    disabled={false}
                    label="Enable Facebook mentions"
                    name="1.mentions_enabled"
                    onChange={[Function]}
                    type="checkbox"
                    value={false}
                  />
                  <BooleanField
                    disabled={false}
                    label="Enable Instagram comments"
                    name="1.instagram_comments_enabled"
                    onChange={[Function]}
                    type="checkbox"
                    value={false}
                  />
                  <BooleanField
                    disabled={false}
                    label="Enable Instagram mentions"
                    name="1.instagram_mentions_enabled"
                    onChange={[Function]}
                    type="checkbox"
                    value={false}
                  />
                  <table>
                    <tbody>
                      <tr>
                        <td
                          className="pl-0"
                        >
                          <BooleanField
                            disabled={false}
                            label="Enable Instagram direct messages"
                            name="1.instagram_direct_message_enabled"
                            onChange={[Function]}
                            type="checkbox"
                            value={false}
                          />
                        </td>
                        <td
                          className="pl-0"
                        />
                      </tr>
                    </tbody>
                  </table>
                  <BooleanField
                    disabled={false}
                    label="Enable Instagram ads"
                    name="1.instagram_ads_enabled"
                    onChange={[Function]}
                    type="checkbox"
                    value={false}
                  />
                </FormGroup>
              </div>
              <div>
                <p
                  className="font-weight-medium"
                >
                  Import your Facebook data:
                </p>
                <div
                  className="d-md-flex"
                >
                  <FormGroup
                    className="mr-5"
                    tag="div"
                  >
                    <BooleanField
                      disabled={false}
                      label="Import 30 days of history (posts and comments) as closed tickets"
                      name="1.import_history_enabled"
                      onChange={[Function]}
                      type="checkbox"
                      value={false}
                    />
                  </FormGroup>
                </div>
              </div>
            </div>
          </div>
        </div>
        <Pagination
          currentPage={1}
          onChange={[Function]}
          pageCount={1}
        />
      </div>
      <div>
        <Button
          className=""
          color="success"
          disabled={true}
          tag="button"
          type="submit"
        >
          Save changes
        </Button>
      </div>
    </Form>
  </Container>
</div>
