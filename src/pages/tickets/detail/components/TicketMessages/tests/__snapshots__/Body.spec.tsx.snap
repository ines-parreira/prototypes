exports[`Body should display the Facebook carousel if there's matching metadata 1`] = `
<div
  class="component"
>
  <div>
    <div
      class="content white-space"
    >
      text 
      <a
        class="linkified"
        href="http://gorgias.io/"
        rel="noreferrer noopener"
        target="_blank"
      >
        http://gorgias.io/
      </a>
    </div>
    
  </div>
  <div
    class="carousel"
  >
    <div
      class="slick-slider slick-initialized"
    >
      
      <div
        class="slick-list"
      >
        <div
          class="slick-track"
          style="opacity: 1; transform: translate3d(0px, 0px, 0px);"
        >
          <div
            aria-hidden="false"
            class="slick-slide slick-active slick-current"
            data-index="0"
            style="outline: none; width: 0px;"
            tabindex="-1"
          >
            <div>
              <div
                class="carouselCardContainer"
                style="width: 100%; display: inline-block;"
                tabindex="-1"
              >
                <div
                  class="carouselCard card"
                >
                  <img
                    class="carouselImage card-img-top"
                    src="https://cdn.shopify.com/s/files/1/1632/0429/products"
                    width="100%"
                  />
                  <div
                    class="card-body"
                  >
                    <div
                      class="card-title"
                    >
                      Fixie bike
                    </div>
                    <div
                      class="card-subtitle"
                    >
                      $200.00
                    </div>
                  </div>
                  <span
                    class="buttons group vertical"
                  >
                    <button
                      class="wrapper fill secondary medium top"
                      role="link"
                      type="button"
                    >
                      View details
                    </button>
                    <button
                      class="wrapper fill primary medium middle isDisabled"
                      disabled=""
                      type="button"
                    >
                      Share
                    </button>
                    <button
                      class="wrapper fill secondary medium bottom"
                      role="link"
                      type="button"
                    >
                      Buy now
                    </button>
                  </span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      
    </div>
  </div>
</div>
`;

