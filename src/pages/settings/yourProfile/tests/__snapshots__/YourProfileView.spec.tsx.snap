  [
    {
      "bio": "CTO",
      "email": "alex@gorgias.io",
      "language": "en",
      "name": "Alex Plugaru",
      "password_confirmation": "a-password",
      "timezone": "EST",
    },
  ],
]
`;

exports[`YourProfileView _saveProfilePicture should remove profile picture 1`] = `
[
  [
    {
      "meta": {
        "profile_picture_url": null,
      },
    },
  ],
]
`;

exports[`YourProfileView _saveProfilePicture should save profile picture 1`] = `
[
  [
    {
      "meta": {
        "profile_picture_url": "https://config.gorgias.io/production/blabla",
      },
    },
  ],
]
`;

exports[`YourProfileView render should expand to show the phone number field when enabling call forwarding 1`] = `
<span
  class="ml-2 dropdown-toggle"
>
  +
  1
</span>
`;

