            />
          </div>
        </div>
        <div
          class="pl-lg-5 col-12 col-lg-5 col-xl-5"
        >
          <div
            class="content"
          >
            <div
              class="flex align-items-center"
            >
              <div
                class="badge"
              >
                <i
                  class="material-icons mr-1"
                >
                  warning
                </i>
                Legacy plan
              </div>
              <i
                class="material-icons upgradeChevron"
              >
                chevron_right
              </i>
              <div
                class="badge"
              >
                Enterprise Plan
              </div>
            </div>
            <h1
              class="contentTitle"
            >
              Feature
            </h1>
            <div
              class="description"
            >
              <p>
                Feature description
              </p>
            </div>
