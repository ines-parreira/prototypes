                <li
                  class="tab-item nav-item"
                >
                  <a
                    class="tabLink nav-link"
                    href="#"
                  >
                    Any other website
                  </a>
                </li>
                <li
                  class="tab-item nav-item"
                >
                  <a
                    class="tabLink nav-link"
                    href="#"
                  >
                    Google Tag Manager
                  </a>
                </li>
              </ul>
              <div
                class="tab-content"
              >
                <div
                  class="tab-pane active"
                >
                  <div
                    class="wrapper"
                  >
