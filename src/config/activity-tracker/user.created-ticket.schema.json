{
    "$ref": "#/definitions/UserCreatedTicketSchema",
    "definitions": {
        "UserCreatedTicketSchema": {
            "type": "object",
            "properties": {
                "accountId": {
                    "type": "integer"
                },
                "userId": {
                    "type": "integer"
                },
                "sessionId": {
                    "type": "string",
                    "format": "uuid"
                },
                "sessionStartedAt": {
                    "type": "string",
                    "format": "date-time"
                },
                "clientId": {
                    "type": "string",
                    "minLength": 6,
                    "maxLength": 6,
                    "description": "The id of the tab / client where the event was captured. On mobile, this will be the device id."
                },
                "path": {
                    "type": "string",
                    "minLength": 1,
                    "description": "The path of the page where the event was captured."
                },
                "entityId": {
                    "type": "integer"
                },
                "entityType": {
                    "type": "string",
                    "const": "ticket"
                },
                "temporaryId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "The temporary id of the ticket draft that became this ticket."
                }
            },
            "required": [
                "accountId",
                "userId",
                "sessionId",
                "sessionStartedAt",
                "clientId",
                "path",
                "entityId",
                "entityType",
                "temporaryId"
            ],
            "additionalProperties": false,
            "description": "1.0.0 ### Event triggered when a ticket is created by the user."
        }
    },
    "$schema": "http://json-schema.org/draft-07/schema#"
}
