                        >
                          arrow_drop_up
                        </i>
                      </button>
                      <button
                        class="wrapper button wrapper small fill secondary small bottom"
                        type="button"
                      >
                        <i
                          class="material-icons icon"
                        >
                          arrow_drop_down
                        </i>
                      </button>
                    </span>
                  </span>
                  <strong
                    class="limitsTooltip"
                    id="chat-messaging-tooltip"
                  >
                    Chat & Messaging
                  </strong>
                   
                  tickets
                </label>
              </div>
              <div
                class="limitsSection"
              >
                <label
                  class="limitLabel"
                >
                  <span
                    class="limitInput wrapper group horizontal"
                  >
                    <input
                      class="input"
                      max="500"
                      min="0"
                      required=""
                      step="1"
                      type="number"
                      value="4"
                    />
                    <span
                      class="controls group vertical"
                    >
                      <button
                        class="wrapper button wrapper small fill secondary small top"
                        type="button"
                      >
                        <i
                          class="material-icons icon"
                        >
                          arrow_drop_up
                        </i>
                      </button>
                      <button
                        class="wrapper button wrapper small fill secondary small bottom"
                        type="button"
                      >
                        <i
                          class="material-icons icon"
                        >
                          arrow_drop_down
                        </i>
                      </button>
                    </span>
                  </span>
                  <strong
                    class="limitsTooltip"
                    id="other-text-tooltip"
                  >
                    Other text
