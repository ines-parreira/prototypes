                >
                  <div>
                    <label
                      aria-checked="true"
                      class="ui-label-label-a11c ui-togglefield-label-9b7c"
                      role="switch"
                    >
                      <input
                        checked=""
                        class="ui-togglefield-input-9b7c"
                        disabled=""
                        name="disable-email-capture-toggle"
                        type="checkbox"
                      />
                      <div
                        class="ui-togglefield-slider-9b7c"
                      />
                      <div>
                        <b>
                          Enable email capture
                        </b>
                      </div>
                    </label>
                  </div>
                </div>
                <fieldset
                  class=""
                  name="radio-field-59"
                >
                  <div
                    class="option"
                  >
                    <label
                      class="ui-label-label-a11c label"
                      for="optional"
                    >
                      <input
                        checked=""
                        class="input"
                        id="optional"
                        name="radio-field-59"
                        type="radio"
                      />
                      Optional
                    </label>
                  </div>
                  <div
                    class="option"
                  >
                    <label
                      class="ui-label-label-a11c label"
                      for="always-required"
                    >
                      <input
                        class="input"
                        id="always-required"
                        name="radio-field-59"
                        type="radio"
                      />
                      Required
                    </label>
                  </div>
                </fieldset>
              </div>
              <div
                class="formSection"
              >
                <h4
                  class="title mb-1"
                >
                  Auto-reply with wait time
                </h4>
                <p
                  class="mb-4"
                >
                  During
                   
                  <a
                    href="/app/settings/business-hours"
                  >
                    business hours
                  </a>
                  , let customers know how fast they can expect a response with an auto-reply. A message is sent in new chat tickets after 30 seconds without replies from an agent.
                </p>
                <div
                  class="mb-4 d-flex align-items-center"
                >
                  <div>
                    <label
                      aria-checked="true"
                      aria-label="auto-responder-toggle"
                      class="ui-label-label-a11c ui-togglefield-label-9b7c"
                      role="switch"
                    >
                      <input
                        aria-label="auto-responder-toggle"
                        checked=""
                        class="ui-togglefield-input-9b7c"
                        disabled=""
                        name="auto-responder-toggle"
                        type="checkbox"
                      />
                      <div
                        class="ui-togglefield-slider-9b7c"
                      />
                      <div />
                    </label>
                  </div>
                  <div
                    class="ml-1"
                  >
                    <b>
                      Send auto-reply with wait time
                    </b>
                  </div>
                </div>
                <div
                  class="mb-3"
                >
                  <fieldset
                    class="mb-2 radioFieldSet"
                    name="radio-field-60"
                  >
                    <div
                      class="option"
                    >
                      <label
                        class="ui-label-label-a11c label"
                        for="reply-dynamic"
                      >
                        <input
                          checked=""
                          class="input"
                          id="reply-dynamic"
                          name="radio-field-60"
                          type="radio"
                        />
                        <div>
                          Dynamic wait time (recommended)
                          <span
                            class="tooltipIcon"
                            id="dynamic-wait-time-option"
                          >
                            <i
                              class="material-icons"
                            >
                              info_outline
                            </i>
                          </span>
                          <p
                            class="dynamicDescription"
                          >
                            Customers can only send live chat messages when an agent is available in Gorgias
                          </p>
                        </div>
                      </label>
                    </div>
                    <div
                      class="option"
                    >
                      <label
                        class="ui-label-label-a11c label"
                        for="reply-in-minutes"
                      >
                        <input
                          class="input"
                          id="reply-in-minutes"
                          name="radio-field-60"
                          type="radio"
                        />
                        In a few minutes
                      </label>
                    </div>
                    <div
                      class="option"
                    >
                      <label
                        class="ui-label-label-a11c label"
                        for="reply-in-hours"
                      >
                        <input
                          class="input"
                          id="reply-in-hours"
                          name="radio-field-60"
                          type="radio"
                        />
                        In a few hours
                      </label>
                    </div>
                  </fieldset>
                </div>
              </div>
              <div
                class="formSection"
              >
                <h4
                  class="title mb-1"
                >
                  Forward chat replies to customer emails
                </h4>
                <p
                  class="mb-3"
                >
                  When customers don't see your live chat response after an hour, Gorgias will automatically send your message to the customer's email address (if available). Customers also receive satisfaction surveys for chat tickets via email.
                </p>
                <label
                  class="control-label"
                  for="linkedEmailIntegration"
                >
                  Select which email address sends these messages
                </label>
                <div>
                  <div
                    class="dropdown"
                  >
                    <div
                      aria-expanded="false"
                      aria-haspopup="true"
                      class=""
                      data-toggle="dropdown"
                    >
                      <div
                        class="select dropdown-toggle selectFullWidth"
                      >
                        <span
                          class="label placeholder"
                          data-testid="selected-linkedEmailIntegration"
                          style="min-width: 10px; opacity: 1;"
                        >
                          Select an email integration
                        </span>
                        <input
                          autocomplete="chrome-off"
                          class="input"
                          id="linkedEmailIntegration"
                          style="min-width: 10px;"
                          type="text"
                          value=""
                        />
                        <i
                          class="material-icons dropdownIcon"
                        >
                          arrow_drop_down
                        </i>
                      </div>
                    </div>
                    <div
                      aria-hidden="true"
                      class="options optionsFullWidth dropdown-menu"
                      role="menu"
                      tabindex="-1"
                    >
                      <h6
                        class="dropdown-header"
                        tabindex="-1"
                      >
                        No result
                      </h6>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <button
              aria-disabled="false"
              class="ui-button-wrapper-a432 ui-button-md-a432 ui-button-primary-a432"
              data-name="button"
              data-rac=""
              data-react-aria-pressable="true"
              id="react-aria-:r16:"
              tabindex="0"
              type="submit"
            >
              <div
