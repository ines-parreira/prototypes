        <button
          aria-disabled="false"
          class="wrapper button wrapper small fill secondary small"
          id="toolbar-button-11"
          type="button"
        >
          <i
            class="material-icons icon"
          >
            insert_photo
          </i>
        </button>
        <button
          aria-disabled="false"
          class="wrapper button wrapper small fill secondary small"
          id="toolbar-button-12"
          type="button"
        >
          <i
            class="material-icons icon"
          >
            insert_emoticon
          </i>
        </button>
        <button
          aria-disabled="false"
          class="wrapper wrapper ghost small ghost secondary small"
          id="contactFormButton"
          type="button"
        >
          <i
