                        "onEntering": [Function],
                        "onExit": [Function],
                        "onExited": [Function],
                        "onExiting": [Function],
                        "tag": "div",
                        "timeout": 150,
                        "unmountOnExit": true,
                      }
                    }
                  >
                    <i
                      className="material-icons md-3 mr-3"
                    >
                      warning
                    </i>
                    Create an Instagram account for this page and you will be able to enable Instagram comments.
                  </Alert>
                </div>
              </div>
              <p
                className="font-weight-medium"
              >
                Import your Facebook data:
              </p>
              <div
                className="d-md-flex"
              >
                <FormGroup
                  className="mr-5"
                  tag="div"
                >
                  <BooleanField
                    label="Import 30 days of history (posts and comments) as closed tickets"
                    name="1.import_history_enabled"
