            </div>
          </div>
          <div
            class="mb40 form-group"
          >
            <h3
              class="heading-section-semibold"
            >
              Unassignment settings
            </h3>
            <div>
              <label
                class="label label"
                for="unassign_on_reply"
              >
                <input
                  checked=""
                  class="input"
                  id="unassign_on_reply"
                  name="unassign_on_reply"
                  type="checkbox"
                />
