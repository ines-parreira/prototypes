                              src="/assets/img/icons/bot-icon.svg"
                            />
                          </div>
                          <div>
                            <div
                              class="title"
                            >
                              hellochatintegration Bot
                            </div>
                            <div
                              class="bubble firstMessageOfAppMaker"
                            >
                              Thanks for reaching out! Leave us your email and an agent will get back to you in about 5 minutes.
                            </div>
                            <div
                              class="optionalEmailCapture"
                            >
                              <div
                                class="inputLabel"
                              >
                                Get notified by email
                              </div>
                              <div
                                class="inputWrapper"
                              >
                                <input
                                  class="input"
                                  placeholder="your@email.com"
                                  readonly=""
                                  type="email"
                                />
                                <button
                                  style="background-color: rgb(13, 135, 221);"
                                >
                                  <i
                                    class="material-icons"
                                    style="color: rgb(255, 255, 255);"
                                  >
                                    chevron_right
                                  </i>
                                </button>
                              </div>
                            </div>
                            <div
                              class="automatedTimestamp"
                            >
                              Automated
                            </div>
                          </div>
                        </div>
                        <div
                          class="appMakerMessageWrapper"
                        >
                          <div
                            class="avatar avatar"
                          />
                          <div>
                            <div
                              class="user"
                            />
                            <div
                              class="bubble firstMessageOfAppMaker"
                            >
                              Hi there, thanks for your patience! Sure, let me check. What's your order number?
                            </div>
                          </div>
                        </div>
                      </div>
                      <div
                        class="poweredBy"
                      >
                        <div>
                          <span>
                            Powered by
                          </span>
