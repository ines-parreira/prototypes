        <a
          class="dropdown-item dropdown-item menu-item"
          role="menuitem"
          tabindex="0"
          to="/app/customers"
        >
          <i
            class="material-icons mr-2 icon"
          >
            people
          </i>
          Customers
        </a>
        <a
          class="dropdown-item dropdown-item menu-item"
          role="menuitem"
          tabindex="0"
          to="/app/stats"
        >
          <i
            class="material-icons mr-2 icon"
          >
            bar_chart
          </i>
          Statistics
        </a>
        <a
          class="dropdown-item dropdown-item menu-item"
          role="menuitem"
          tabindex="0"
          to="/app/settings"
        >
          <i
            class="material-icons mr-2 icon"
          >
            settings
          </i>
          Settings
        </a>
      </div>
    </div>
    <div
      class="navbar-content"
    >
      <div
        class="category"
      >
        <a
          activeclassname="active"
          class="link"
          to="/app/automation"
        >
          Overview
        </a>
      </div>
      <a
        activeclassname="active"
        class="link"
        to="/app/automation/macros"
      >
        Macros
      </a>
      <a
        activeclassname="active"
        class="link"
        to="/app/automation/rules"
      >
        Rules
      </a>
      <a
        activeclassname="active"
        class="link"
        to="/app/automation/ticket-assignment"
      >
        Ticket assignment
      </a>
      <div
        class="category"
      >
        <h4
          class="category-title"
        >
          <div
            class="title"
          >
            <i
              class="material-icons icon"
            >
              auto_awesome
            </i>
            automation add-on
          </div>
        </h4>
        <div
          class="mt-3"
        >
          <div
            class="section d-flex align-items-center flex-grow"
          >
            <div
              class="toggleSectionIconWrapper"
            >
              <i
                class="toggleSectionIcon material-icons"
              >
                arrow_drop_down
              </i>
            </div>
            <div
              class="nameWrapper d-flex align-items-center flex-grow"
              title="My shop"
            >
              <div
                class="iconWrapper"
              >
                <img
                  alt="Shopify logo"
                  role="presentation"
                  src="test-file-stub"
                />
              </div>
              <span
                class="name"
              >
                My shop
              </span>
            </div>
          </div>
          <a
            activeclassname="active"
            class="link isNested"
            to="/app/automation/self-service/shopify/My shop/preferences/quick-response"
          >
            Quick responses
