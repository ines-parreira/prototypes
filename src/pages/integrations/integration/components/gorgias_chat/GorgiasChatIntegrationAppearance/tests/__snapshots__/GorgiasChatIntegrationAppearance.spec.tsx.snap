exports[`<GorgiasChatIntegrationAppearance/> render() should preselect shopify integration if there's only one available 1`] = `
<div>
  <div
    class="full-width"
  >
    <div
      class="page-header pageHeader"
    >
      <nav
        aria-label="breadcrumb"
        class=""
      >
        <ol
          class="breadcrumb"
        >
          <li
            class="breadcrumb-item"
          >
            <a
              to="/app/settings/channels/gorgias_chat"
            >
              Chat
            </a>
          </li>
          <li
            class="breadcrumb-item"
          >
            New Chat
          </li>
        </ol>
      </nav>
    </div>
    <div
      class="pageContainer container-fluid"
    >
      <div
        class="row"
      >
        <div
          class="col"
        >
          <form
            class=""
          >
            <div
              class="form"
            >
              <div
                class="formSection"
              >
                <h2
                  class="title"
                >
                  Select a platform type
                </h2>
                <div
                  class="platformTypeContainer"
                >
                  <div
                    aria-checked="true"
                    aria-label="Ecommerce platforms"
                    class="wrapper selected"
                    role="radio"
                    tabindex="0"
                  >
                    <div>
                      <label
                        class="label label"
                        for="ecommerce-platforms"
                      >
                        <input
                          checked=""
                          class="input"
                          id="ecommerce-platforms"
                          tabindex="-1"
                          type="radio"
                        />
                        Ecommerce platforms
                      </label>
                      <div
                        class="caption caption"
                      >
                        Shopify, Magento, BigCommerce
                      </div>
                    </div>
                  </div>
                  <div
                    aria-checked="false"
                    aria-label="Any other website"
                    class="wrapper"
                    role="radio"
                    tabindex="0"
                  >
                    <div>
                      <label
                        class="label label"
                        for="any-other-website"
                      >
                        <input
                          class="input"
                          id="any-other-website"
                          tabindex="-1"
                          type="radio"
                        />
                        Any other website
                      </label>
                      <div
                        class="caption caption"
                      >
                        Websites, knowledge bases, etc.
                      </div>
                    </div>
                  </div>
                </div>
                <label
                  class="label"
                >
                  Connect a store
                  <abbr
                    aria-label="required"
                    class="abbr"
                    title="required"
                  >
                    *
                  </abbr>
                </label>
                <div
                  class="connectStoreDescription"
                >
                  Connect a store to use Automation Add-on features in chat and to enable 1-click install for Shopify.
                </div>
                <div
                  class="wrapper"
                >
                  <div
                    class="dropdown dropdown"
                  >
                    <button
                      aria-expanded="false"
                      aria-haspopup="true"
                      class="dropdown-toggle btn btn-secondary"
                      type="button"
                    >
                      <span
                        class="dropdownValue"
                      >
