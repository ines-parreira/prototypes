                      class="option dropdown-item"
                      role="menuitem"
                      tabindex="0"
                      type="button"
                    >
                      <span>
                        Armed Forces Pacific
                      </span>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div
          class="row"
        >
          <div
            class="col"
          >
            <div
              class="InputField required form-group"
              color=""
            >
              <label
                class="control-label"
                for="id-city"
              >
                City
              </label>
              <div
                class=""
              >
                <input
                  class="form-control"
                  id="id-city"
                  placeholder="San Francisco"
                  required=""
                  type="text"
                  value=""
                />
              </div>
            </div>
          </div>
          <div
            class="col"
          >
            <div
              class="InputField form-group"
              color=""
            >
              <label
                class="control-label"
                for="id-zip"
              >
                ZIP/Postal code
              </label>
              <div
                class=""
              >
                <input
                  class="form-control"
                  id="id-zip"
                  type="text"
                  value=""
                />
              </div>
            </div>
          </div>
        </div>
      </div>
      <div
        class="formFooter modal-footer"
      >
        <button
          class="focusable btn btn-secondary"
          tabindex="0"
          type="button"
        >
          Cancel
        </button>
        <button
          class="focusable ml-auto btn btn-primary"
          type="submit"
        >
          Save changes
        </button>
      </div>
    </form>
  </div>
</div>
`;
