      data-testid="GorgiasChatIntegrationHeader"
    />
    <div
      class="pageContainer container-fluid"
    >
      <div
        class="row row"
      >
        <div
          class="col"
        >
          <form
            class=""
          >
            <div
              class="form"
            >
              <div
                class="formSection"
              >
                <div
                  class="InputField formGroup required form-group"
                  color=""
                >
                  <label
                    class="control-label"
                    for="id-input-42"
                  >
                    Chat title
                  </label>
                  <div
                    class=""
                  >
                    <input
                      class="field form-control"
                      id="id-input-42"
                      maxlength="100"
                      placeholder="Ex: Company Support"
                      required=""
                      type="text"
                      value="hellochatintegration"
                    />
                  </div>
                </div>
                <div
                  class="InputField formGroup form-group"
                  color=""
                >
                  <label
                    class="control-label"
                    for="id-input-42"
                  >
