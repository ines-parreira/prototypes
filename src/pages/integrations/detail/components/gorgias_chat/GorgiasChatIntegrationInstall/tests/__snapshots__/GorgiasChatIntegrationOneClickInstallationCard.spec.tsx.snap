exports[`<GorgiasChatIntegrationOneClickInstallationCard/> should NOT display the message "Note that this will automatically enable Self-Service" 1`] = `
<div>
  <div
    class="card card"
  >
    <div
      class="card-header card-header"
    >
      <h3>
        One-click installation
      </h3>
    </div>
    <div
      class="card-body card-body"
    >
      <p>
        Activate the customer chat widget on your Shopify store in one click.
      </p>
      <div
        class="one-click-installation"
      >
        <div
          class="one-click-installation-inner"
        >
          <img
            alt="shopify-logo"
