exports[`<AutoReplyWismoEditor/> should display an alert if no shopify integration 1`] = `
<div
  class="alert warning mb-3"
>
  <div
    class="iconContainer"
  >
    <img
      alt="icon"
      src="test-file-stub"
    />
  </div>
  <div
    class="content"
  >
    <span
      class="label"
    >
      This rule requires at least one Shopify integration to run.
    </span>
  </div>
</div>
`;

