                                                  className="option dropdown-item"
                                                  onClick={[Function]}
                                                  onMouseEnter={[Function]}
                                                  role="menuitem"
                                                  tabIndex="0"
                                                  type="button"
                                                >
                                                  Friday
                                                </button>
                                              </DropdownItem>
                                              <DropdownItem
                                                className="option"
                                                key="6"
                                                onClick={[Function]}
                                                onMouseEnter={[Function]}
                                                tag="button"
                                                toggle={true}
                                                type="button"
                                              >
                                                <button
                                                  className="option dropdown-item"
                                                  onClick={[Function]}
                                                  onMouseEnter={[Function]}
                                                  role="menuitem"
                                                  tabIndex="0"
                                                  type="button"
                                                >
                                                  Saturday
                                                </button>
                                              </DropdownItem>
                                              <DropdownItem
                                                className="option"
                                                key="7"
                                                onClick={[Function]}
                                                onMouseEnter={[Function]}
                                                tag="button"
                                                toggle={true}
                                                type="button"
                                              >
                                                <button
                                                  className="option dropdown-item"
                                                  onClick={[Function]}
                                                  onMouseEnter={[Function]}
                                                  role="menuitem"
                                                  tabIndex="0"
                                                  type="button"
                                                >
                                                  Sunday
                                                </button>
                                              </DropdownItem>
                                            </div>
                                          </DropdownMenu>
                                        </div>
                                      </Manager>
                                    </Dropdown>
                                  </UncontrolledDropdown>
                                </div>
                              </SelectField>
                              <Input
                                className="timeField"
                                name="fromTime"
                                onChange={[Function]}
                                pattern="[0-9][0-9]:[0-9][0-9]"
                                type="time"
                                value="11:00"
                              >
                                <input
                                  className="timeField form-control"
                                  name="fromTime"
                                  onChange={[Function]}
                                  pattern="[0-9][0-9]:[0-9][0-9]"
                                  type="time"
                                  value="11:00"
                                />
                              </Input>
                              <p>
                                to
                              </p>
                              <Input
                                className="timeField"
                                name="toTime"
                                onChange={[Function]}
                                pattern="[0-9][0-9]:[0-9][0-9]"
                                type="time"
                                value="17:00"
                              >
                                <input
                                  className="timeField form-control"
                                  name="toTime"
                                  onChange={[Function]}
                                  pattern="[0-9][0-9]:[0-9][0-9]"
                                  type="time"
                                  value="17:00"
                                />
                              </Input>
                            </div>
                          </BusinessHoursForm>
                          <div
                            className="deleteButton"
                            onClick={[Function]}
                          >
                            <i
                              className="material-icons red"
                            >
                              clear
                            </i>
                          </div>
                        </div>
                        <Button
                          color="secondary"
                          onClick={[Function]}
                          tag="button"
                          type="button"
                        >
                          <button
                            aria-label={null}
                            className="btn btn-secondary"
                            onClick={[Function]}
                            type="button"
                          >
                            <i
                              className="material-icons"
                            >
                              add
                            </i>
                             
                            Add business hours
                          </button>
                        </Button>
                      </div>
                      <InputField
                        label="Timezone"
                        name="timezone"
                        onChange={[Function]}
                        type="select"
                        value="US/Pacific"
                      >
                        <FormGroup
                          className="InputField"
                          color=""
                          tag="div"
                        >
                          <div
                            className="InputField form-group"
                            color=""
                          >
                            <Label
                              className="control-label"
                              htmlFor="id-timezone"
                              tag="label"
                              widths={
                                Array [
                                  "xs",
                                  "sm",
                                  "md",
                                  "lg",
                                  "xl",
                                ]
                              }
                            >
                              <label
                                className="control-label"
                                htmlFor="id-timezone"
                              >
                                Timezone
                              </label>
                            </Label>
                            <div
                              className=""
                            >
                              <Input
                                className=""
                                id="id-timezone"
                                onChange={[Function]}
                                type="select"
                                value="US/Pacific"
                              >
                                <select
                                  className="form-control"
                                  id="id-timezone"
                                  onChange={[Function]}
                                  value="US/Pacific"
                                >
                                  <option
                                    key="UTC"
                                    value="UTC"
                                  >
                                    UTC
                                  </option>
                                  <option
                                    key="US/Pacific"
                                    value="US/Pacific"
                                  >
                                    US/Pacific
                                  </option>
                                  <option
                                    key="Australia/AUR"
                                    value="Australia/AUR"
                                  >
                                    Australia/AUR
                                  </option>
                                </select>
                              </Input>
                            </div>
                          </div>
                        </FormGroup>
                      </InputField>
                    </div>
                  </Col>
                </div>
              </Row>
              <Button
                className=""
                color="success"
                disabled={false}
                tag="button"
                type="submit"
              >
                <button
                  aria-label={null}
                  className="btn btn-success"
                  disabled={false}
                  onClick={[Function]}
                  type="submit"
                >
                  Save changes
                </button>
              </Button>
            </form>
          </Form>
        </div>
      </Container>
    </div>
  </BusinessHours>
</Connect(BusinessHours)>
`;
