{
    "name": "@repo/helpdesk",
    "version": "1.0.0",
    "description": "Host application of the monorepo",
    "main": "src/main/init/index.tsx",
    "private": true,
    "scripts": {
        "typecheck": "tsc -p ./tsconfig.ci.json --noEmit true",
        "typecheck:watch": "tsc -p ./tsconfig.json --noEmit true --watch",
        "oxlint": "oxlint --quiet",
        "stylelint:less": "stylelint \"src/**/*.less\"",
        "lint": "run-p stylelint:less oxlint*",
        "format:check": "prettier --check --experimental-cli .",
        "format:fix": "prettier --write --experimental-cli .",
        "quality": "run-s lint typecheck",
        "jest": "TZ=UTC LC_ALL=\"en_US.UTF-8\" jest",
        "storybook:dev": "storybook dev -p 6006",
        "storybook:build": "node .storybook/scripts/build-and-normalize-stats.mjs",
        "storybook:build:docs": "storybook build --docs",
        "test": "jest",
        "test:debug": "node --inspect-brk ./node_modules/.bin/jest -i",
        "test:cover": "jest --coverage",
        "test:cover:changed": "jest --coverage --changedSince=main --onlyChanged --coverageReporters=lcov --coverageReporters=text-summary",
        "test:update": "jest -u",
        "test:watch": "jest --watch",
        "test:ci:cover": "TZ=UTC LC_ALL=\"en_US.UTF-8\" NODE_DISABLE_COMPILE_CACHE=1 NODE_OPTIONS=\"--max-old-space-size=4096\" jest --coverage --ci --maxWorkers=2 --testTimeout=10000 --silent --forceExit",
        "patch-package": "patch-package",
        "postinstall": "run-p patch-package",
        "build": "run-s build:clean build:app build:sharedWorker",
        "build:clean": "pnpm rimraf build/*",
        "build:app": "NODE_ENV=production rspack --config rspack.app.config.mjs",
        "build:sharedWorker": "NODE_ENV=production rspack --config rspack.workers.config.mjs",
        "serve": "run-s serve:app serve:sharedWorker",
        "serve:app": "NODE_ENV=development rspack serve --config rspack.app.config.mjs",
        "serve:sharedWorker": "NODE_ENV=development rspack -w --config rspack.workers.config.mjs",
        "helpcenter:fetch-openapi": "curl http://localhost:4002/api/help-center/api-json > ./src/rest_api/help_center_api/help-center.openapi.json && prettier --write --experimental-cli ./src/rest_api/help_center_api/help-center.openapi.json",
        "helpcenter:generate-types": "typegen ./src/rest_api/help_center_api/help-center.openapi.json > ./src/rest_api/help_center_api/client.generated.d.ts",
        "helpcenter:update-client": "pnpm helpcenter:fetch-openapi && pnpm helpcenter:generate-types",
        "migration:fetch-openapi": "curl http://localhost:8001/apidoc/openapi.json > ./src/rest_api/migration_api/migration.openapi.json && prettier --write --experimental-cli ./src/rest_api/migration_api/migration.openapi.json",
        "migration:generate-types": "typegen ./src/rest_api/migration_api/migration.openapi.json > ./src/rest_api/migration_api/client.generated.d.ts && prettier --write --experimental-cli ./src/rest_api/migration_api/client.generated.d.ts",
        "migration:update-client": "pnpm migration:fetch-openapi && pnpm migration:generate-types",
        "gorgiaschat:generate-openapi:protected": "p2o ./src/rest_api/gorgias_chat_protected_api/gorgias-chat-protected-api.postman_collection.json -f ./src/rest_api/gorgias_chat_protected_api/gorgias-chat-protected-api.openapi.json -o ./src/rest_api/gorgias_chat_protected_api/gorgias-chat-protected-api.p2o_options.json",
        "gorgiaschat:generate-types:protected": "typegen ./src/rest_api/gorgias_chat_protected_api/gorgias-chat-protected-api.openapi.json > ./src/rest_api/gorgias_chat_protected_api/client.generated.d.ts",
        "gorgiaschat:update-client": "pnpm gorgiaschat:generate-openapi:protected && pnpm gorgiaschat:generate-types:protected",
        "convert:fetch-openapi": "curl http://localhost:8095/openapi.json > src/rest_api/revenue_addon_api/revenue-addon.openapi.json && prettier --write --experimental-cli src/rest_api/revenue_addon_api/revenue-addon.openapi.json",
        "convert:generate-types": "typegen src/rest_api/revenue_addon_api/revenue-addon.openapi.json > src/rest_api/revenue_addon_api/client.generated.d.ts",
        "convert:update-client": "pnpm convert:fetch-openapi && pnpm convert:generate-types",
        "ssp-api:generate-types": "typegen ./src/rest_api/ssp_api/ssp-api.openapi.json > ./src/rest_api/ssp_api/client.generated.d.ts",
        "wf-api:fetch-openapi": "curl http://localhost:3100/docs-json > ./src/rest_api/workflows_api/wf-api.openapi.json && prettier --write --experimental-cli ./src/rest_api/workflows_api/wf-api.openapi.json",
        "wf-api:generate-types": "typegen ./src/rest_api/workflows_api/wf-api.openapi.json > ./src/rest_api/workflows_api/client.generated.d.ts",
        "dev:proxy": "DEV_ENV=proxy pnpm serve:app",
        "dev:local": "pnpm serve:app",
        "dev:workers:proxy": "DEV_ENV=proxy pnpm serve:sharedWorker"
    },
