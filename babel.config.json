{
    "presets": [
        [
            "@babel/env",
            {
                "targets": { "browsers": ["last 2 versions", "safari >= 7"] },
                "useBuiltIns": "usage",
                "corejs": "3.36.0",
                "loose": true
            }
        ],
        ["@babel/preset-react", { "runtime": "automatic" }],
        ["@babel/typescript", { "allExtensions": true, "isTSX": true }]
    ],
    "plugins": ["@babel/plugin-transform-class-properties"]
}
