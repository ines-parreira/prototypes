exports[`<AutoCloseSpamModal/> should render the autoclose spam body when automation add-on is not subscribed 1`] = `
<div
  class="managedRule autoCloseSpam"
>
  <div
    class="container"
  >
    <div
      class="description"
    >
      <div
        class="count"
      >
        <div
          class="targetTitle"
        >
          install to target up to
        </div>
        <div
          class="targetValue"
        >
          <span
            class="bold"
          >
            10
          </span>
           
          <span
            class="ticketsPerMonth"
          >
            tickets/month
          </span>
        </div>
      </div>
      <div
        class="descriptionBlock"
      >
        <h4>
          How it works
        </h4>
        <p>
          This rule detects and closes irrelevant emails that don’t require a response like newsletters and spam to save time spent filtering through tickets. Keep this rule at the top of your rules to ensure it always triggers first and prevents irrelevant billable tickets from being created.
        </p>
      </div>
      <div
        class="descriptionBlock"
      >
        <h4>
          Customize it
        </h4>
        <p>
          You can exclude email addresses from this rule, and ensure this rule always triggers on incoming emails from certain email addresses.
        </p>
      </div>
      <div
        class="descriptionBlock"
      >
        view creation checkbox
      </div>
    </div>
    <div
      class="container"
    >
      <div
        class="fakeTicket"
      >
        <div
          class="fakeTicketTitleWrapper"
        >
          <span
            class="fakeTicketTitle"
          >
            Newsletter
          </span>
          <div
            class="badge fakeTicketClosed"
            style="background-color: rgb(255, 234, 234); color: rgb(163, 46, 46);"
          >
            closed
          </div>
        </div>
        <div
          class="fakeTicketDescription"
        >
          Check out our new product!
        </div>
      </div>
      <div
        class="fakeTicket"
      >
        <div
          class="fakeTicketTitleWrapper"
        >
          <span
            class="fakeTicketTitle"
          >
            Product question
          </span>
        </div>
        <div
          class="fakeTicketDescription"
        >
          I have ordered...
        </div>
      </div>
      <div
        class="fakeTicket"
      >
        <div
          class="fakeTicketTitleWrapper"
        >
          <span
            class="fakeTicketTitle"
          >
            Promotion! -50%...
          </span>
          <div
            class="badge fakeTicketClosed"
            style="background-color: rgb(255, 234, 234); color: rgb(163, 46, 46);"
          >
            closed
          </div>
        </div>
        <div
          class="fakeTicketDescription"
        >
          Until Monday all of our products...
        </div>
      </div>
    </div>
  </div>
</div>
`;

