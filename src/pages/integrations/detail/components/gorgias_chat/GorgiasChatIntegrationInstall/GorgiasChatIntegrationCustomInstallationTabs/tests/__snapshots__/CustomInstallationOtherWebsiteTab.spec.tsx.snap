// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`<CustomInstallationOtherWebsiteTab/> should display the custom installation "other website" tab correcty 1`] = `
<div
  className="wrapper"
>
  <div
    className="instruction"
  >
    <div>
      <span
        className="instruction-number"
      >
        1
      </span>
    </div>
    <div
      className="instruction-text"
    >
      Edit the source code of your website which contains the closing HTML tag 
      <b>
        &lt;/body&gt;
      </b>
    </div>
  </div>
  <div
    className="instruction"
  >
    <div>
      <span
        className="instruction-number"
      >
        2
      </span>
    </div>
    <div
      className="instruction-text"
    >
      Just above this tag, copy and paste the code snippet below
    </div>
  </div>
  <div
    className="instruction"
  >
    <div>
      <span
        className="instruction-number"
      >
        3
      </span>
    </div>
    <div
      className="instruction-text"
    >
      Save the file and commit the changes
    </div>
  </div>
  <Alert
    type="warning"
  >
    Please note that by inserting this snippet on your webpage, it will load the chat on that specific webpage only. Make sure to insert the snippet on all the pages for which you wish to display the chat widget.
  </Alert>
  <WithClipboardComponent
    code="<script>installChat();</script>"
  />
</div>
`;
