// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`<AutoReplyReturnEditor/> should render component 1`] = `
<div
  class="container autoReplyReturn"
>
  <p>
    This rule detects emails related to return requests, auto-replies with the link to your return portal, and auto-closes the ticket. If shoppers reply, the ticket will reopen so you never miss a response.
  </p>
  <div
    class="listWrapper"
  >
    <div>
      <label
        class="label label"
        for="input-text-1"
      >
        Return portal URL
        <abbr
          aria-label="required"
          class="abbr"
          title="required"
        >
          *
        </abbr>
      </label>
      <div
        class="wrapper"
      >
        <input
          aria-describedby="input-text-1-caption"
          class="input"
          id="input-text-1"
          name="input-text-1"
          required=""
          type="url"
          value="https://exemple.com/?user={{current_user.name}}"
        />
      </div>
      <div
        class="caption"
        id="input-text-1-caption"
      >
        Enter the URL for your return portal.
      </div>
    </div>
  </div>
  <div
    class="listWrapper"
  >
    <h4>
      Exclusion email list
    </h4>
    <p>
      This rule will never trigger on incoming emails from the addresses below.
    </p>
    <div
      class="MultiSelectField allowList"
    >
      <div
        class="container"
      >
        <div
          class="inputContainer multiSelectOptionField-dropdown"
        >
          <div
            class="dropdown"
          >
            <div
              aria-expanded="false"
              aria-haspopup="true"
              class=""
              data-toggle="dropdown"
            >
              <input
                autocomplete="off"
                class="input"
                placeholder="Add emails..."
                value=""
              />
            </div>
            <div
              aria-hidden="true"
              class="options dropdown-menu"
              role="menu"
              tabindex="-1"
            >
              <h6
                class="dropdown-header"
                tabindex="-1"
              >
                No result
              </h6>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div
    class="listWrapper"
  >
    <h4>
      Message above return portal link
    </h4>
    <div
      class="field"
    >
      <div
