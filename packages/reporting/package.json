{
    "name": "@repo/reporting",
    "version": "1.0.0",
    "description": "Reporting domain",
    "private": true,
    "exports": {
        ".": "./src/index.ts"
    },
    "scripts": {
        "format:check": "prettier --check .",
        "format:fix": "prettier --write .",
        "lint": "oxlint --quiet",
        "lint:unused": "knip --directory ../.. --workspace @repo/reporting --no-progress",
        "test": "vitest run --configLoader=runner",
        "test:ci:cover": "vitest run --configLoader=runner --coverage --silent",
        "test:watch": "vitest watch --configLoader=runner",
        "typecheck": "tsc -p ./tsconfig.json --noEmit true"
    },
    "peerDependencies": {
        "@gorgias/analytics-ui-kit": "catalog:analytics-ui-kit",
        "@gorgias/axiom": "catalog:axiom",
        "@gorgias/design-tokens": "catalog:axiom",
        "classnames": "catalog:styles",
        "moment": "catalog:moment",
        "moment-timezone": "catalog:moment",
        "react": "catalog:react",
        "react-dnd": "catalog:react-dnd",
        "react-dnd-html5-backend": "catalog:react-dnd",
        "react-dom": "catalog:react",
        "react-is": "catalog:react"
    },
    "devDependencies": {
        "@gorgias/analytics-ui-kit": "catalog:analytics-ui-kit",
        "@gorgias/design-tokens": "catalog:axiom",
        "@repo/config": "workspace:*",
        "@repo/hooks": "workspace:*",
        "@repo/testing": "workspace:*",
        "@testing-library/dom": "catalog:test",
        "@testing-library/jest-dom": "catalog:test",
        "@testing-library/react": "catalog:test",
        "@testing-library/user-event": "catalog:test",
        "@trivago/prettier-plugin-sort-imports": "catalog:prettier",
        "@types/classnames": "catalog:styles",
        "@types/jest": "catalog:test",
        "@types/react": "catalog:react",
        "@types/react-dom": "catalog:react",
        "@vitest/coverage-v8": "catalog:test",
        "classnames": "catalog:styles",
        "moment": "catalog:moment",
        "moment-timezone": "catalog:moment",
        "oxlint": "catalog:oxlint",
        "prettier": "catalog:prettier",
        "react": "catalog:react",
        "react-dom": "catalog:react",
        "typescript": "catalog:typescript",
        "vitest": "catalog:test"
    },
    "dependencies": {
        "recharts": "catalog:recharts"
    }
}
