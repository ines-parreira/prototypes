exports[`<HelpCenterStartView /> should render the About component 1`] = `
<div>
  <div
    class="full-width"
  >
    <div
      class="page-header pageHeader"
    >
      <h1
        class="d-flex align-items-center"
      >
        Help Center
      </h1>
    </div>
    <nav
      class="navbar navbar"
    >
      <a
        aria-current="page"
        class="link active"
        href="/app/settings/help-center"
      >
        About
      </a>
      <a
        class="link"
        href="/app/settings/help-center/manage"
      >
        Manage
      </a>
    </nav>
    <header
      class="hero"
    >
      <i
        class="heroIcon material-icons-outlined"
      >
        live_help
      </i>
      <div>
        <h1
          class="heroHeading"
        >
          Help Center
        </h1>
        <p
          class="heroDescription"
        >
          Set up a free Help Center/FAQ site and let your customers find answers.
        </p>
        <div
          class="heroMeta"
        />
      </div>
    </header>
    <main
      class="main"
    >
      <section>
        <div
          class="longDescription"
        >
          <h2>
            About
          </h2>
          <div>
            <p>
              With the Gorgias native Help Center, you can set up help articles on your website for free. This is a great way to allow your customers to self serve and get instant answers before reaching out to your Support team. You can add images, videos, and GIFs to help your customers learn about your products and services in-depth!
            </p>
            <h2>
              Highlights
            </h2>
            <p />
            <ul>
              <li>
                Multiple help centers for multi-brands
              </li>
              <li>
                Multilingual, customizable settings to match with your brand;
              </li>
              <li>
                Contact cards (including contact form) to direct inquiries to one central location;
              </li>
              <li>
                Google Analytics to get insights about your customers behavior;
              </li>
              <li>
                Internal knowledge base to transfer knowledge with your team.
              </li>
            </ul>
            <p />
            <p />
            <h2>
              For Automate subscribers only:
            </h2>
            <ul>
              <li>
                Self-Service Flows available in the Help Center to deflect even more tickets;
              </li>
              <li>
                Articles Recommendations in chat.
              </li>
            </ul>
            <p />
          </div>
        </div>
        <ul
          class="screenshotList"
        >
          <li
            class="screenshotListItem"
          >
            <img
              alt="Screenshot number 1 of things this products allows you to do in Gorgias"
              class="screenshot"
              src="/assets/img/integrations/screenshots/helpcenter-1.png"
            />
          </li>
        </ul>
      </section>
      <div
        class="infoCard card"
      >
        <div
          class="card-body"
        >
          <div
            class="actionWrapper"
          >
            <a
              href="/app/settings/help-center/new"
            >
              <button
                aria-disabled="false"
                class="wrapper full-width fill primary medium"
                type="button"
              >
                <span
                  class="content"
                >
                  Create Help Center
                </span>
              </button>
            </a>
          </div>
          <h2
            class="categoryTitle cardTitle"
          >
            Resources
          </h2>
          <ul
            class="cardList"
          >
            <li>
              <a
                class="actionLink"
                href="https://docs.gorgias.com/en-US/articles/help-center-18396"
                rel="noopener noreferrer"
                target="_blank"
              >
                <i
                  class="material-icons-outlined actionIcon actionIconBigger"
                >
                  description
                </i>
                Documentation
              </a>
            </li>
            <li>
              <a
                class="actionLink"
                href="https://link.gorgias.com/helpcenter-webinar"
                rel="noopener noreferrer"
                target="_blank"
              >
                <i
                  class="material-icons actionIcon"
                >
                  ondemand_video
                </i>
                live webinar
              </a>
            </li>
          </ul>
          <h2
            class="categoryTitle cardTitle"
          >
            Support
          </h2>
          <ul
            class="cardList"
          >
            <li>
              <a
                class="actionLink"
                href="mailto:support@gorgias.com"
                rel="noopener noreferrer"
                target="_blank"
              >
                <i
                  class="material-icons actionIcon"
                >
                  mail
                </i>
                support@gorgias.com
              </a>
            </li>
          </ul>
        </div>
      </div>
    </main>
  </div>
</div>
`;

